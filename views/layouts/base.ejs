<% var esCliente = typeof usuario !== 'undefined' && usuario && usuario.rol === 'cliente'; %>
<% var esAdmin = typeof usuario !== 'undefined' && usuario && usuario.rol === 'admin'; %>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof titulo !== 'undefined' ? titulo + ' · Cartera' : 'Cartera' %></title>
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#2563eb" />
  <link rel="icon" href="/icons/icon-192.png" />
  <link rel="stylesheet" href="/css/output.css" />
  <link rel="stylesheet" href="/vendor/sweetalert2/sweetalert2.min.css" />
  <script src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
  <script src="/vendor/chartjs/chart.umd.min.js"></script>
  <script src="/js/moneda-input.js"></script>
  <% if (esAdmin) { %>
    <link rel="stylesheet" href="/vendor/datatables/style.css" />
    <script src="/vendor/datatables/umd/simple-datatables.js"></script>
    <link rel="stylesheet" href="/vendor/tom-select/css/tom-select.css" />
    <script src="/vendor/tom-select/js/tom-select.complete.min.js"></script>
    <!-- Aplica la preferencia del sidebar antes de pintar, para evitar parpadeo. -->
    <script>try { if (localStorage.getItem('sidebar-collapsed') === '1') document.documentElement.classList.add('sidebar-collapsed'); } catch (e) {}</script>
  <% } %>
</head>
<body class="min-h-screen bg-slate-50">
  <!-- Loader de navegación entre vistas (se muestra al ir a otra página). -->
  <div id="nav-loader" role="status" aria-live="polite">
    <div class="loader"></div>
    <span class="sr-only">Cargando…</span>
  </div>
  <% if (esAdmin) { %>
    <%- include('../partials/sidebar-admin') %>
    <div id="sidebar-backdrop" class="fixed inset-0 z-30 bg-slate-900/50"></div>
  <% } else if (esCliente) { %>
    <%- include('../partials/header-cliente') %>
  <% } %>

  <main class="<%= esAdmin ? 'app-main max-w-[1600px] px-6 sm:px-8' : esCliente ? 'mx-auto max-w-lg px-4 sm:px-6 pb-24' : 'mx-auto max-w-6xl px-4 sm:px-6' %> py-6">
    <% if (esAdmin) { %>
      <!-- Barra pegajosa con el botón para abrir el menú. Se queda arriba al
           hacer scroll y su fondo evita que el contenido quede por debajo. -->
      <div id="barra-toggle" class="-mx-6 -mt-6 mb-2 border-b border-slate-100 bg-slate-50 px-6 py-1.5 sm:-mx-8 sm:px-8">
        <button type="button" id="btn-abrir-sidebar" aria-label="Abrir menú"
          style="display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:.75rem;background:linear-gradient(145deg,#f8fafc 0%,#e2e8f0 60%,#cbd5e1 100%);color:#475569;border:1px solid rgba(255,255,255,.9);box-shadow:0 4px 10px rgba(100,116,139,.25),0 1px 3px rgba(0,0,0,.1),inset 0 1px 0 rgba(255,255,255,.95);transition:transform .15s ease,box-shadow .15s ease;"
          onmouseover="this.style.transform='translateY(-1px)';this.style.boxShadow='0 6px 16px rgba(100,116,139,.35),0 2px 6px rgba(0,0,0,.12),inset 0 1px 0 rgba(255,255,255,.95)'"
          onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 4px 10px rgba(100,116,139,.25),0 1px 3px rgba(0,0,0,.1),inset 0 1px 0 rgba(255,255,255,.95)'">
          <svg style="width:18px;height:18px;filter:drop-shadow(0 1px 1px rgba(0,0,0,.15))" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    <% } %>
    <%- body %>
  </main>

  <% if (esCliente) { %>
    <%- include('../partials/bottom-nav-cliente') %>
  <% } else if (!esAdmin) { %>
    <%- include('../partials/footer') %>
  <% } %>

  <%- include('../partials/flash-script') %>
  <% if (esAdmin) { %>
    <%- include('../partials/modal-explica') %>
  <% } %>
  <script src="/js/main.js"></script>
  <% if (esAdmin) { %>
    <script src="/js/tablas.js"></script>
    <script src="/js/dashboard.js"></script>
  <% } %>
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js').catch(() => {});
    }
  </script>
</body>
</html>
