<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nueva contraseña · Cash R&amp;R</title>
  <link rel="icon" type="image/svg+xml" href="/img/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/img/favIcon.ico" />
  <link rel="shortcut icon" type="image/x-icon" href="/img/favIcon.ico" />
  <link rel="stylesheet" href="/css/output.css?v=<%= typeof assetV !== 'undefined' ? assetV : '1' %>" />
  <link rel="stylesheet" href="/vendor/sweetalert2/sweetalert2.min.css" />
  <script src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
  <%- include('../partials/auth-styles') %>
</head>
<body class="login-body">
  <main class="login-wrap">
    <!-- Marca -->
    <section class="brand">
      <div class="brand-frame">
        <img src="/img/login%20mejorado.webp" alt="Cash R&amp;R Financiadora" />
      </div>
    </section>

    <!-- Formulario -->
    <section class="login-card">
      <p class="eyebrow">Restablecer contraseña</p>
      <h1 class="login-title">Nueva contraseña</h1>
      <p class="login-sub">Escribe el código que recibiste por WhatsApp y elige tu contraseña nueva.</p>

      <% if (typeof exito !== 'undefined' && exito) { %>
        <div class="aviso aviso-ok">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m22 4-10 10.01-3-3"/></svg>
          <span><%= exito %></span>
        </div>
      <% } %>

      <% if (error) { %>
        <div class="aviso aviso-err">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
          <span><%= error %></span>
        </div>
      <% } %>

      <form action="/auth/nueva-clave" method="POST" id="form-clave" data-no-loading>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

        <div class="field">
          <label for="usuario">Usuario</label>
          <div class="control">
            <span class="ico">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </span>
            <input type="text" id="usuario" name="usuario" required autocomplete="username"
                   value="<%= typeof usuario !== 'undefined' ? usuario : '' %>" placeholder="ej. juan.cobrador" />
          </div>
        </div>

        <div class="field">
          <label for="codigo">Código de WhatsApp</label>
          <div class="control">
            <span class="ico">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
            </span>
            <input type="text" id="codigo" name="codigo" required inputmode="numeric" pattern="[0-9]{6}"
                   maxlength="6" placeholder="6 dígitos" autocomplete="one-time-code"
                   style="letter-spacing:.4em;font-weight:600;" />
          </div>
        </div>

        <div class="field">
          <label for="password">Nueva contraseña</label>
          <div class="control">
            <span class="ico">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
            </span>
            <input type="password" id="password" name="password" placeholder="Mínimo 8 caracteres" required minlength="8" autocomplete="new-password" />
            <button type="button" class="toggle-eye" data-toggle="password" aria-label="Mostrar contraseña">
              <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>

        <div class="field">
          <label for="password2">Repetir contraseña</label>
          <div class="control">
            <span class="ico">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
            </span>
            <input type="password" id="password2" name="password2" placeholder="Repite la contraseña" required minlength="8" autocomplete="new-password" />
            <button type="button" class="toggle-eye" data-toggle="password2" aria-label="Mostrar contraseña">
              <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>

        <button type="submit" class="btn-entrar" id="btn-guardar">
          Guardar contraseña
          <svg class="arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </button>
      </form>

      <div class="forgot">
        <a href="/auth/recuperar">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
          Solicitar un código nuevo
        </a>
      </div>
    </section>
  </main>

  <script>
    (function () {
      // Mostrar/ocultar contraseña.
      document.querySelectorAll('.toggle-eye[data-toggle]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var input = document.getElementById(btn.getAttribute('data-toggle'));
          if (!input) return;
          input.type = input.type === 'password' ? 'text' : 'password';
          input.focus();
        });
      });

      // El código es numérico: se descarta cualquier otra cosa al pegar o teclear.
      var codigo = document.getElementById('codigo');
      if (codigo) {
        codigo.addEventListener('input', function () {
          codigo.value = codigo.value.replace(/\D/g, '').slice(0, 6);
        });
      }

      // Validación rápida antes de enviar (el servidor la repite: esto es solo
      // para no hacer un viaje de ida y vuelta por un error obvio).
      var form = document.getElementById('form-clave');
      if (form) {
        form.addEventListener('submit', function (e) {
          var p1 = document.getElementById('password').value;
          var p2 = document.getElementById('password2').value;
          if (p1.length < 8) {
            e.preventDefault();
            Swal.fire({ icon: 'error', title: 'Contraseña muy corta', text: 'Debe tener al menos 8 caracteres.', confirmButtonColor: '#16a34a' });
            return;
          }
          if (p1 !== p2) {
            e.preventDefault();
            Swal.fire({ icon: 'error', title: 'No coinciden', text: 'Las dos contraseñas deben ser iguales.', confirmButtonColor: '#16a34a' });
          }
        });
      }
    })();
  </script>
</body>
</html>
