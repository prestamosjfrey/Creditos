<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Recuperar contraseña · Cash R&amp;R</title>
  <link rel="icon" type="image/svg+xml" href="/img/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/img/favIcon.ico" />
  <link rel="shortcut icon" type="image/x-icon" href="/img/favIcon.ico" />
  <link rel="stylesheet" href="/css/output.css?v=<%= typeof assetV !== 'undefined' ? assetV : '1' %>" />
  <%- include('../partials/auth-styles') %>
</head>
<body class="login-body">
  <main class="login-wrap">
    <!-- Marca -->
    <section class="brand">
      <div class="brand-frame">
        <img src="/img/login%20mejorado.webp" alt="Cash R&amp;R Financiadora" />
      </div>
    </section>

    <!-- Formulario -->
    <section class="login-card">
      <p class="eyebrow">Recuperar acceso</p>
      <h1 class="login-title">¿Olvidaste tu contraseña?</h1>
      <p class="login-sub">Escribe tu correo y te enviaremos un enlace para restablecerla.</p>

      <% if (exito) { %>
        <div class="aviso aviso-ok">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m22 4-10 10.01-3-3"/></svg>
          <span><%= exito %></span>
        </div>
      <% } %>
      <% if (error) { %>
        <div class="aviso aviso-err">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
          <span><%= error %></span>
        </div>
      <% } %>

      <form action="/auth/recuperar" method="POST" data-no-loading>
        <div class="field">
          <label for="email">Correo electrónico</label>
          <div class="control">
            <span class="ico">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
            </span>
            <input type="email" id="email" name="email" placeholder="correo@ejemplo.com" required autofocus autocomplete="email" value="<%= (valores && valores.email) || '' %>" />
          </div>
        </div>

        <button type="submit" class="btn-entrar">
          Enviar enlace
          <svg class="arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </button>
      </form>

      <div class="forgot">
        <a href="/auth/login">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7M19 12H5"/></svg>
          Volver a iniciar sesión
        </a>
      </div>

      <div class="divisor"></div>
      <p class="foot">
        Uso exclusivo para personal autorizado
      </p>
    </section>
  </main>
</body>
</html>
