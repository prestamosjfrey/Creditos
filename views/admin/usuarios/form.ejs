<%
  var esEdicion = !!usuario;
  var accion = esEdicion ? '/admin/usuarios/' + usuario.id + '/editar' : '/admin/usuarios';
  var icoInput = 'pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400';
  // Los pasos del asistente solo aplican al CREAR. Al editar se muestra todo junto.
  var pasos = [
    { n: 1, titulo: 'Acceso' },
    { n: 2, titulo: 'Datos de contacto' },
    { n: 3, titulo: 'Recuperación' },
  ];
%>

<form action="<%= accion %>" method="POST" id="form-usuario" class="mx-auto max-w-3xl">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

  <div class="overflow-hidden rounded-3xl border border-slate-100 bg-white shadow-sm">

    <!-- ===== Cabecera (centrada) ===== -->
    <div class="flex flex-col items-center gap-2 border-b border-slate-100 p-6 text-center sm:p-8">
      <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-blue-100 text-blue-600">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M18 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0ZM3 19.235v-.11a6.375 6.375 0 0 1 12.75 0v.109A12.318 12.318 0 0 1 9.374 21c-2.331 0-4.512-.645-6.374-1.766Z" /></svg>
      </span>
      <div>
        <h1 class="text-2xl font-bold text-slate-800"><%= esEdicion ? 'Editar usuario' : 'Crear usuario' %></h1>
        <p class="mt-0.5 text-sm text-slate-400">
          <%= esEdicion ? 'Actualiza la información de este usuario.' : 'Completa la información para registrar un nuevo usuario en el sistema.' %>
        </p>
      </div>
    </div>

    <% if (!esEdicion) { %>
      <!-- ===== Indicador de pasos (lo muestra el JS) ===== -->
      <div id="stepper" class="hidden border-b border-slate-100 px-6 py-4 sm:px-8">
        <div class="mx-auto flex max-w-md items-center">
          <% pasos.forEach(function (p, i) { %>
            <div class="flex items-center <%= i < pasos.length - 1 ? 'flex-1' : '' %>">
              <div class="flex flex-col items-center gap-1">
                <span class="step-dot flex h-8 w-8 items-center justify-center rounded-full border-2 border-slate-200 bg-white text-xs font-semibold text-slate-400" data-dot="<%= p.n %>"><%= p.n %></span>
                <span class="step-label hidden text-[11px] font-medium text-slate-400 sm:block" data-label="<%= p.n %>"><%= p.titulo %></span>
              </div>
              <% if (i < pasos.length - 1) { %>
                <span class="step-line mx-1 h-0.5 flex-1 rounded bg-slate-200" data-line="<%= p.n %>"></span>
              <% } %>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>

    <div class="space-y-6 p-6 sm:p-8">

      <!-- ================= PASO 1 · ACCESO ================= -->
      <section class="paso" data-paso="1">
        <div class="mb-4 flex items-center gap-3">
          <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-blue-100 text-blue-600">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" /></svg>
          </span>
          <div>
            <h2 class="font-semibold text-blue-700">Acceso</h2>
            <p class="text-xs text-slate-400">Datos para iniciar sesión en el sistema.</p>
          </div>
        </div>

        <div class="space-y-4">
          <div>
            <label class="label-field" for="usuario">Nombre de usuario</label>
            <div class="relative">
              <svg class="<%= icoInput %>" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.5 20.25a7.5 7.5 0 0 1 15 0" /></svg>
              <% if (esEdicion) { %>
                <input class="input-field bg-slate-50 pl-10 text-slate-500" type="text" id="usuario" value="<%= usuario.usuario %>" disabled />
              <% } else { %>
                <input class="input-field pl-10" type="text" id="usuario" name="usuario" required minlength="3" maxlength="30"
                       pattern="[a-zA-Z0-9._-]+" value="<%= valores.usuario || '' %>"
                       placeholder="juan.cobrador" autocomplete="off" />
              <% } %>
            </div>
            <p class="mt-1 text-xs text-slate-400">
              <% if (esEdicion) { %>El usuario no se puede cambiar: es su identidad de acceso.<% } else { %>Con esto inicia sesión. Solo letras, números, punto y guion. No se podrá cambiar después.<% } %>
            </p>
          </div>

          <% if (!esEdicion) { %>
            <div>
              <label class="label-field" for="password">Contraseña</label>
              <div class="flex gap-2">
                <div class="relative flex-1">
                  <svg class="<%= icoInput %>" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" /></svg>
                  <input class="input-field pl-10" type="text" id="password" name="password" required minlength="8"
                         value="<%= valores.password || '' %>" placeholder="Mínimo 8 caracteres" autocomplete="new-password" />
                </div>
                <button type="button" id="btn-generar" class="btn-secondary inline-flex items-center gap-1.5 whitespace-nowrap text-xs">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" /></svg>
                  Generar
                </button>
              </div>

              <!-- Checklist en vivo: cada requisito se marca al cumplirse. Las
                   mismas reglas se validan en el servidor (REGLAS_PASSWORD en
                   middlewares/validar.js), esto es solo la guía visual. -->
              <ul id="checklist-password" class="mt-2 grid grid-cols-1 gap-1 text-xs sm:grid-cols-2">
                <li class="req flex items-center gap-1.5 text-slate-400" data-regla="length">
                  <svg class="ico-x h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/></svg>
                  <svg class="ico-ok hidden h-3.5 w-3.5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                  Mínimo 8 caracteres
                </li>
                <li class="req flex items-center gap-1.5 text-slate-400" data-regla="mayus">
                  <svg class="ico-x h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/></svg>
                  <svg class="ico-ok hidden h-3.5 w-3.5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                  Una mayúscula (A-Z)
                </li>
                <li class="req flex items-center gap-1.5 text-slate-400" data-regla="minus">
                  <svg class="ico-x h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/></svg>
                  <svg class="ico-ok hidden h-3.5 w-3.5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                  Una minúscula (a-z)
                </li>
                <li class="req flex items-center gap-1.5 text-slate-400" data-regla="numero">
                  <svg class="ico-x h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/></svg>
                  <svg class="ico-ok hidden h-3.5 w-3.5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                  Un número (0-9)
                </li>
                <li class="req flex items-center gap-1.5 text-slate-400" data-regla="especial">
                  <svg class="ico-x h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/></svg>
                  <svg class="ico-ok hidden h-3.5 w-3.5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                  Un carácter especial (@ # $ …)
                </li>
              </ul>
              <p class="mt-1.5 text-xs text-slate-400">Se la dictas al empleado. Podrá cambiarla al entrar.</p>
            </div>
          <% } %>
          <!-- El rol NO se pide: todos son administradores (lo fija el servidor). -->
        </div>
      </section>

      <!-- ================= PASO 2 · DATOS DE CONTACTO ================= -->
      <section class="paso" data-paso="2">
        <div class="mb-4 flex items-center gap-3">
          <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-blue-100 text-blue-600">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.5 20.25a7.5 7.5 0 0 1 15 0" /></svg>
          </span>
          <div>
            <h2 class="font-semibold text-blue-700">Datos de contacto</h2>
            <p class="text-xs text-slate-400">Información de contacto del usuario.</p>
          </div>
        </div>

        <div class="space-y-4">
          <div>
            <label class="label-field" for="nombre_completo">Nombre completo</label>
            <div class="relative">
              <svg class="<%= icoInput %>" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.5 20.25a7.5 7.5 0 0 1 15 0" /></svg>
              <input class="input-field pl-10" type="text" id="nombre_completo" name="nombre_completo" required
                     value="<%= (valores && valores.nombre_completo) || '' %>" placeholder="Juan Pérez" />
            </div>
          </div>

          <div>
            <label class="label-field" for="email">Correo electrónico</label>
            <div class="relative">
              <svg class="<%= icoInput %>" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
              <input class="input-field pl-10 pr-10" type="email" id="email" name="email"
                     data-excluir="<%= esEdicion ? usuario.id : '' %>"
                     value="<%= (valores && valores.email) || '' %>" placeholder="juan.perez@gmail.com" />
              <!-- Indicador de estado (lo controla el JS): spinner / check / equis. -->
              <span id="email-estado" class="absolute right-3 top-1/2 -translate-y-1/2"></span>
            </div>
            <p id="email-msg" class="mt-1 text-xs text-slate-400">Único por usuario. También sirve para iniciar sesión.</p>
          </div>

          <div>
            <label class="label-field" for="telefono">Teléfono / WhatsApp</label>
            <div class="relative">
              <svg class="<%= icoInput %>" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
              <input class="input-field pl-10" type="text" id="telefono" name="telefono"
                     value="<%= (valores && valores.telefono) || '' %>" placeholder="+57 320 123 4567" />
            </div>
            <p class="mt-1 text-xs text-slate-400">Con indicativo del país. Aquí llegará el código de recuperación.</p>
          </div>
        </div>
      </section>

      <!-- ================= PASO 3 · RECUPERACIÓN ================= -->
      <section class="paso" data-paso="3">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div class="flex items-center gap-3">
            <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-blue-100 text-blue-600">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" /></svg>
            </span>
            <div>
              <h2 class="font-semibold text-blue-700">Recuperación de cuenta</h2>
              <p class="text-xs text-slate-400">Apikey de CallMeBot para enviarle el código por WhatsApp.</p>
            </div>
          </div>
          <button type="button" id="btn-mas-info"
                  class="inline-flex shrink-0 items-center gap-1 rounded-lg border border-slate-200 px-3 py-1.5 text-xs font-medium text-slate-500 transition hover:bg-slate-50">
            Más información
            <svg id="ico-mas-info" class="h-4 w-4 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" /></svg>
          </button>
        </div>

        <div class="mt-4">
          <label class="label-field" for="callmebot_apikey">Apikey de CallMeBot <span class="font-normal text-slate-400">(opcional)</span></label>
          <div class="relative">
            <svg class="<%= icoInput %>" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z" /></svg>
            <input class="input-field pl-10" type="text" id="callmebot_apikey" name="callmebot_apikey"
                   value="" placeholder="<%= esEdicion ? 'Dejar vacío para no cambiarla' : 'ej. 123456' %>" autocomplete="off" />
          </div>
          <p class="mt-1 text-xs text-slate-400">
            <% if (esEdicion) { %>Vacío = no se toca. Escribe <code class="rounded bg-slate-100 px-1">-</code> para borrarla.<% } else { %>Sin esto, el empleado no podrá recuperar su contraseña solo (podrás restablecérsela tú).<% } %>
          </p>

          <div id="mas-info" class="mt-3 hidden rounded-xl bg-slate-50 p-3 text-xs leading-relaxed text-slate-500">
            <p class="mb-1 font-medium text-slate-600">Cómo consigue el empleado su apikey</p>
            <ol class="list-decimal space-y-0.5 pl-4">
              <li>Guarda en sus contactos el número de CallMeBot: <strong>+34 644 91 07 79</strong></li>
              <li>Le envía por WhatsApp, tal cual y en inglés: <em>«I allow callmebot to send me messages»</em></li>
              <li>En un par de minutos el bot le responde con su apikey personal</li>
              <li>Te la pasa y la pegas aquí</li>
            </ol>
            <p class="mt-1">
              Instrucciones oficiales:
              <a href="https://www.callmebot.com/blog/free-api-whatsapp-messages/" target="_blank" rel="noopener noreferrer" class="text-blue-600 underline">callmebot.com</a>
            </p>
          </div>
        </div>
      </section>
    </div>

    <!-- ===== Pie con acciones ===== -->
    <div class="flex items-center justify-between gap-3 border-t border-slate-100 bg-slate-50/60 px-6 py-4 sm:px-8">
      <!-- Izquierda: Cancelar (paso 1 / edición) o Atrás (pasos 2-3). -->
      <a href="/admin/usuarios" id="btn-cancelar" class="btn-secondary inline-flex items-center gap-1.5">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>
        Cancelar
      </a>
      <button type="button" id="btn-atras" class="btn-secondary hidden items-center gap-1.5">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
        Atrás
      </button>

      <!-- Derecha: Siguiente (pasos 1-2) o el submit final. -->
      <div class="flex items-center gap-3">
        <button type="button" id="btn-siguiente" class="btn-primary hidden items-center gap-1.5">
          Siguiente
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        </button>
        <button type="submit" id="btn-enviar" class="btn-primary inline-flex items-center gap-1.5">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M18 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0ZM3 19.235v-.11a6.375 6.375 0 0 1 12.75 0v.109A12.318 12.318 0 0 1 9.374 21c-2.331 0-4.512-.645-6.374-1.766Z" /></svg>
          <%= esEdicion ? 'Guardar cambios' : 'Crear usuario' %>
        </button>
      </div>
    </div>
  </div>
</form>

<% if (error) { %>
  <%- include('../../partials/flash-script', { flashError: error, flashExito: null }) %>
<% } %>

<script>
  (function () {
    var inputPass = document.getElementById('password');

    // --- Checklist de contraseña segura (mismas reglas que el servidor) ---
    var REGLAS = {
      length:   function (v) { return v.length >= 8; },
      mayus:    function (v) { return /[A-Z]/.test(v); },
      minus:    function (v) { return /[a-z]/.test(v); },
      numero:   function (v) { return /\d/.test(v); },
      especial: function (v) { return /[^A-Za-z0-9]/.test(v); },
    };
    // ¿la contraseña cumple TODAS las reglas? (lo usa el asistente para avanzar)
    function passwordCumple(v) {
      return Object.keys(REGLAS).every(function (k) { return REGLAS[k](v); });
    }

    function pintarChecklist() {
      if (!inputPass) return;
      var v = inputPass.value;
      document.querySelectorAll('#checklist-password .req').forEach(function (li) {
        var ok = REGLAS[li.dataset.regla](v);
        li.classList.toggle('text-emerald-600', ok);
        li.classList.toggle('text-slate-400', !ok);
        li.querySelector('.ico-ok').classList.toggle('hidden', !ok);
        li.querySelector('.ico-x').classList.toggle('hidden', ok);
      });
    }
    if (inputPass) { inputPass.addEventListener('input', pintarChecklist); pintarChecklist(); }

    // --- Generar contraseña que CUMPLE la política (evita 0/O, 1/l/I) ---
    var btnGen = document.getElementById('btn-generar');
    if (btnGen && inputPass) {
      btnGen.addEventListener('click', function () {
        var abc = 'abcdefghijkmnpqrstuvwxyz', ABC = 'ABCDEFGHJKLMNPQRSTUVWXYZ', num = '23456789', esp = '@#$*-';
        var pick = function (s) { return s[Math.floor(Math.random() * s.length)]; };
        // Uno de cada tipo garantizado + relleno.
        inputPass.value = pick(ABC) + pick(abc) + pick(abc) + pick(num) + pick(num) + pick(abc) + pick(esp) + pick(abc);
        pintarChecklist();
      });
    }

    // --- Verificación del correo en vivo ---
    // Consulta al servidor si el correo ya está en uso. El resultado se guarda
    // en `estadoCorreo` y el asistente lo usa para no dejar avanzar el paso 2.
    var inputEmail = document.getElementById('email');
    var emailEstado = document.getElementById('email-estado');
    var emailMsg = document.getElementById('email-msg');
    // 'vacio' | 'invalido' | 'verificando' | 'libre' | 'ocupado' | 'error'
    var estadoCorreo = 'vacio';
    var SVG_SPIN = '<svg class="h-4 w-4 animate-spin text-slate-400" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 0 1 8-8V0C5.4 0 0 5.4 0 12h4z"/></svg>';
    var SVG_OK   = '<svg class="h-4 w-4 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>';
    var SVG_BAD  = '<svg class="h-4 w-4 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>';

    function ponMsg(texto, color) {
      if (emailMsg) { emailMsg.textContent = texto; emailMsg.className = 'mt-1 text-xs ' + color; }
    }

    if (inputEmail) {
      var excluir = inputEmail.dataset.excluir || '';
      var timer = null;
      var ultimaConsulta = 0;

      function chequearCorreo() {
        var email = inputEmail.value.trim();
        if (!email) {
          estadoCorreo = 'vacio';
          if (emailEstado) emailEstado.innerHTML = '';
          ponMsg('Único por usuario. También sirve para iniciar sesión.', 'text-slate-400');
          return;
        }
        // Un correo mal formado ni se consulta.
        if (!inputEmail.checkValidity()) {
          estadoCorreo = 'invalido';
          if (emailEstado) emailEstado.innerHTML = '';
          ponMsg('El correo no tiene un formato válido.', 'text-red-500');
          return;
        }

        estadoCorreo = 'verificando';
        if (emailEstado) emailEstado.innerHTML = SVG_SPIN;
        ponMsg('Verificando…', 'text-slate-400');

        var esta = ++ultimaConsulta; // descarta respuestas viejas si se sigue escribiendo
        var url = '/admin/usuarios/verificar-correo?email=' + encodeURIComponent(email) +
                  (excluir ? '&excluir=' + encodeURIComponent(excluir) : '');
        fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' }, credentials: 'same-origin' })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (esta !== ultimaConsulta) return;           // llegó una respuesta vieja
            if (data.email !== inputEmail.value.trim()) return; // el correo cambió
            if (data.disponible) {
              estadoCorreo = 'libre';
              if (emailEstado) emailEstado.innerHTML = SVG_OK;
              ponMsg('Correo disponible.', 'text-emerald-600');
            } else {
              estadoCorreo = 'ocupado';
              if (emailEstado) emailEstado.innerHTML = SVG_BAD;
              ponMsg('Ese correo ya lo usa el usuario "' + (data.usuario || '') + '". Usa otro.', 'text-red-500');
            }
          })
          .catch(function () {
            if (esta !== ultimaConsulta) return;
            estadoCorreo = 'error';
            if (emailEstado) emailEstado.innerHTML = '';
            ponMsg('No se pudo verificar el correo. Se comprobará al guardar.', 'text-amber-600');
          });
      }

      // Debounce: espera a que deje de escribir para no consultar en cada tecla.
      inputEmail.addEventListener('input', function () {
        clearTimeout(timer);
        timer = setTimeout(chequearCorreo, 450);
      });
      inputEmail.addEventListener('blur', function () { clearTimeout(timer); chequearCorreo(); });

      // Si viene precargado (reintento tras un error del servidor), se verifica.
      if (inputEmail.value.trim()) chequearCorreo();
    }

    // --- Plegar/desplegar instrucciones de CallMeBot ---
    var btnInfo = document.getElementById('btn-mas-info'), caja = document.getElementById('mas-info'), ico = document.getElementById('ico-mas-info');
    if (btnInfo && caja) {
      btnInfo.addEventListener('click', function () {
        var oculto = caja.classList.toggle('hidden');
        if (ico) ico.style.transform = oculto ? '' : 'rotate(180deg)';
      });
    }

    // --- Asistente por pasos (SOLO al crear) ---
    // Mejora progresiva: sin JS, los 3 bloques se ven de corrido y el submit
    // funciona igual. Con JS, se convierte en un asistente paso a paso.
    var esEdicion = <%= esEdicion ? 'true' : 'false' %>;
    var form = document.getElementById('form-usuario');
    var pasos = Array.prototype.slice.call(document.querySelectorAll('.paso'));
    var stepper = document.getElementById('stepper');
    if (esEdicion || pasos.length < 2 || !stepper) return; // edición: una sola pantalla

    var btnAtras = document.getElementById('btn-atras');
    var btnCancelar = document.getElementById('btn-cancelar');
    var btnSiguiente = document.getElementById('btn-siguiente');
    var btnEnviar = document.getElementById('btn-enviar');
    var total = pasos.length;
    var actual = 1;

    // La validación la lleva el JS por paso: se desactiva la del navegador para
    // que un campo oculto de otro paso no bloquee con "no es enfocable".
    form.setAttribute('novalidate', 'novalidate');
    stepper.classList.remove('hidden');

    function pintarStepper() {
      document.querySelectorAll('[data-dot]').forEach(function (d) {
        var n = Number(d.dataset.dot);
        d.className = 'step-dot flex h-8 w-8 items-center justify-center rounded-full border-2 text-xs font-semibold ' +
          (n < actual ? 'border-blue-600 bg-blue-600 text-white'
           : n === actual ? 'border-blue-600 bg-white text-blue-600'
           : 'border-slate-200 bg-white text-slate-400');
        d.innerHTML = n < actual
          ? '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>'
          : n;
      });
      document.querySelectorAll('[data-label]').forEach(function (l) {
        l.className = 'step-label hidden text-[11px] font-medium sm:block ' +
          (Number(l.dataset.label) === actual ? 'text-blue-700' : 'text-slate-400');
      });
      document.querySelectorAll('[data-line]').forEach(function (ln) {
        ln.className = 'step-line mx-1 h-0.5 flex-1 rounded ' + (Number(ln.dataset.line) < actual ? 'bg-blue-600' : 'bg-slate-200');
      });
    }

    function mostrarPaso(n) {
      actual = n;
      pasos.forEach(function (p) { p.style.display = Number(p.dataset.paso) === n ? '' : 'none'; });

      // Izquierda: Cancelar en el paso 1, Atrás en los demás.
      btnCancelar.classList.toggle('hidden', n !== 1);
      btnAtras.classList.toggle('hidden', n === 1);
      btnAtras.classList.toggle('inline-flex', n !== 1);

      // Derecha: Siguiente hasta el penúltimo; el submit solo en el último.
      var ultimo = n === total;
      btnSiguiente.classList.toggle('hidden', ultimo);
      btnSiguiente.classList.toggle('inline-flex', !ultimo);
      btnEnviar.classList.toggle('hidden', !ultimo);
      btnEnviar.classList.toggle('inline-flex', ultimo);

      pintarStepper();
      form.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // Valida solo los campos del paso visible antes de avanzar.
    function pasoValido(n) {
      var seccion = pasos[n - 1];
      var campos = seccion.querySelectorAll('input, select, textarea');
      for (var i = 0; i < campos.length; i++) {
        if (!campos[i].checkValidity()) { campos[i].reportValidity(); return false; }
      }
      // La complejidad de la contraseña no la cubre checkValidity (solo mira
      // minlength): se comprueba aparte contra el checklist.
      if (inputPass && seccion.contains(inputPass) && !passwordCumple(inputPass.value)) {
        inputPass.setCustomValidity('La contraseña no cumple todos los requisitos de seguridad.');
        inputPass.reportValidity();
        inputPass.setCustomValidity('');
        return false;
      }

      // El correo debe estar verificado y libre antes de pasar del paso 2.
      if (inputEmail && seccion.contains(inputEmail) && inputEmail.value.trim()) {
        if (estadoCorreo === 'ocupado') {
          avisarCorreo('Ese correo ya está en uso. Elige otro para continuar.');
          return false;
        }
        if (estadoCorreo === 'invalido') {
          avisarCorreo('El correo no tiene un formato válido.');
          return false;
        }
        if (estadoCorreo === 'verificando') {
          avisarCorreo('Espera un momento: se está verificando el correo.');
          return false;
        }
      }
      return true;
    }

    // Enfoca el correo y muestra el aviso bajo el campo.
    function avisarCorreo(texto) {
      if (inputEmail) inputEmail.focus();
      if (typeof ponMsg === 'function') ponMsg(texto, 'text-red-500');
    }

    btnSiguiente.addEventListener('click', function () {
      if (pasoValido(actual) && actual < total) mostrarPaso(actual + 1);
    });
    btnAtras.addEventListener('click', function () {
      if (actual > 1) mostrarPaso(actual - 1);
    });

    // Al enviar, revalida todos los pasos por si acaso; si algo falla, lleva al
    // paso del error.
    form.addEventListener('submit', function (e) {
      for (var n = 1; n <= total; n++) {
        if (!pasoValido(n)) { e.preventDefault(); mostrarPaso(n); return; }
      }
    });

    mostrarPaso(1);
  })();
</script>
