<%
  // Iconos por reporte. Se resuelven aquí para que el catálogo del servicio
  // (services/reportes.service.js) no tenga que saber de SVGs.
  var ICONOS = {
    salida:     '<path stroke-linecap="round" stroke-linejoin="round" d="M12 19V5m0 0-7 7m7-7 7 7" />',
    entrada:    '<path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m0 0 7-7m-7 7-7-7" />',
    alerta:     '<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />',
    ganancia:   '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.307a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.28m5.94 2.28-2.28 5.941" />',
    caja:       '<path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 0 0-2.25-2.25H15a3 3 0 1 1-6 0H5.25A2.25 2.25 0 0 0 3 12m18 0v6a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 18v-6m18 0V9a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 9v3" />',
    calendario: '<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />',
    clientes:   '<path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />',
    deuda:      '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125h17.25c.621 0 1.125.504 1.125 1.125v.375m-19.5 0v8.25a1.125 1.125 0 0 0 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-8.25M12 11.25a2.625 2.625 0 1 1 0-5.25 2.625 2.625 0 0 1 0 5.25Z" />'
  };
  var COLORES = {
    salida: 'bg-blue-100 text-blue-600', entrada: 'bg-emerald-100 text-emerald-600',
    alerta: 'bg-red-100 text-red-600', ganancia: 'bg-gold-100 text-gold-600',
    caja: 'bg-indigo-100 text-indigo-600', calendario: 'bg-sky-100 text-sky-600',
    clientes: 'bg-violet-100 text-violet-600', deuda: 'bg-orange-100 text-orange-600'
  };
  // Los reportes heredan el rango elegido aquí.
  var _qs = 'periodo=' + encodeURIComponent(rango.periodo || 'este_mes')
    + (rango.desde ? '&desde=' + encodeURIComponent(rango.desde) : '')
    + (rango.hasta ? '&hasta=' + encodeURIComponent(rango.hasta) : '');
%>

<div class="mb-6 flex flex-col items-center text-center gap-1">
  <h1 class="text-3xl font-bold text-slate-800">Reportes</h1>
  <p class="text-sm text-slate-400">Elige un periodo y entra al reporte que necesites.</p>
  <div class="mt-1 h-0.5 w-10 rounded-full bg-indigo-600"></div>
</div>

<%- include('_filtro', { accion: '/admin/reportes', rango: rango, periodos: periodos }) %>

<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
  <% reportes.forEach(function (r) { %>
    <a href="/admin/reportes/<%= r.clave %>?<%= _qs %>" class="card group transition hover:shadow-md">
      <div class="flex items-start gap-3">
        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full <%= COLORES[r.icono] || 'bg-slate-100 text-slate-600' %>">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><%- ICONOS[r.icono] || '' %></svg>
        </span>
        <div class="min-w-0">
          <p class="font-medium text-slate-800 group-hover:text-blue-700"><%= r.titulo %></p>
          <p class="mt-1 text-sm leading-snug text-slate-400"><%= r.descripcion %></p>
          <% if (r.sinRango) { %>
            <p class="mt-2 inline-block rounded-full bg-slate-100 px-2 py-0.5 text-[11px] font-medium text-slate-500">Foto de hoy · no usa el periodo</p>
          <% } %>
        </div>
      </div>
    </a>
  <% }); %>
</div>
