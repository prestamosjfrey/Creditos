<%
  // Filtro de rango compartido por el índice y por cada reporte.
  // `accion` es la URL a la que envía (la propia página).
  var _accion = typeof accion !== 'undefined' ? accion : '/admin/reportes';
  var _rango = rango || {};
  var _esPersonalizado = _rango.periodo === 'personalizado';
%>
<form method="GET" action="<%= _accion %>" class="card mb-5" id="filtro-reportes">
  <div class="flex flex-wrap items-end gap-3">
    <div class="min-w-[170px] flex-1">
      <label class="label-field" for="periodo">Periodo</label>
      <select class="input-field" id="periodo" name="periodo">
        <% periodos.forEach(function (p) { %>
          <option value="<%= p.clave %>" <%= _rango.periodo === p.clave ? 'selected' : '' %>><%= p.etiqueta %></option>
        <% }); %>
      </select>
    </div>

    <div class="campo-fecha <%= _esPersonalizado ? '' : 'hidden' %>">
      <label class="label-field" for="desde">Desde</label>
      <input class="input-field" type="date" id="desde" name="desde" value="<%= _rango.desde || '' %>" />
    </div>

    <div class="campo-fecha <%= _esPersonalizado ? '' : 'hidden' %>">
      <label class="label-field" for="hasta">Hasta</label>
      <input class="input-field" type="date" id="hasta" name="hasta" value="<%= _rango.hasta || '' %>" />
    </div>
  </div>

  <!-- Sin botón "Aplicar": el filtro se aplica al elegir. Si el navegador no
       ejecuta JavaScript, este botón aparece y el formulario sigue funcionando. -->
  <noscript>
    <div class="mt-3">
      <button type="submit" class="btn-primary">Aplicar</button>
    </div>
  </noscript>
</form>

<script>
  (function () {
    var form = document.getElementById('filtro-reportes');
    if (!form) return;
    var periodo = form.querySelector('#periodo');
    var desde = form.querySelector('#desde');
    var hasta = form.querySelector('#hasta');
    var campos = form.querySelectorAll('.campo-fecha');

    // Al elegir un periodo normal se aplica solo. Con "Personalizado" no se
    // envía todavía: primero hay que elegir las dos fechas.
    periodo.addEventListener('change', function () {
      var personalizado = periodo.value === 'personalizado';
      campos.forEach(function (c) { c.classList.toggle('hidden', !personalizado); });
      if (personalizado) {
        if (desde) desde.focus();
        return;
      }
      form.submit();
    });

    // En "Personalizado" se aplica en cuanto están las DOS fechas. Enviar con
    // una sola daría un rango a medias, así que se espera a tener ambas.
    [desde, hasta].forEach(function (campo) {
      if (!campo) return;
      campo.addEventListener('change', function () {
        if (desde.value && hasta.value) form.submit();
      });
    });
  })();
</script>
