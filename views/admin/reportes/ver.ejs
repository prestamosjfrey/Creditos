<%
  // Vista única para TODOS los reportes: se adapta al descriptor que devuelve
  // services/reportes.service.js ({ kpis, columnas, filas, grafica, ... }).
  // Añadir un reporte no requiere tocar esta vista.
  var _qs = 'periodo=' + encodeURIComponent(rango.periodo || 'este_mes')
    + (rango.desde ? '&desde=' + encodeURIComponent(rango.desde) : '')
    + (rango.hasta ? '&hasta=' + encodeURIComponent(rango.hasta) : '');

  function valorFormateado(v, tipo) {
    if (v === null || v === undefined || v === '') return '—';
    if (tipo === 'moneda') return formatCOP(v);
    if (tipo === 'pct') return v + '%';
    if (typeof v === 'number') return v.toLocaleString('es-CO');
    return v;
  }
%>

<div class="mb-5 flex flex-wrap items-start justify-between gap-3">
  <div>
    <a href="/admin/reportes" class="mb-1 inline-flex items-center gap-1 text-sm text-slate-400 transition hover:text-blue-600">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Todos los reportes
    </a>
    <h1 class="text-2xl font-bold text-slate-800"><%= reporte.titulo %></h1>
    <p class="mt-0.5 text-sm text-slate-400"><%= reporte.descripcion %></p>
  </div>

  <div class="flex items-center gap-2">
    <span class="rounded-full bg-slate-100 px-3 py-1.5 text-xs font-medium text-slate-600"><%= etiqueta %></span>
    <% if (datos.filas && datos.filas.length) { %>
      <a href="/admin/reportes/<%= reporte.clave %>/exportar?<%= _qs %>" class="btn-secondary inline-flex items-center gap-1.5">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
        Exportar CSV
      </a>
    <% } %>
  </div>
</div>

<% if (!reporte.sinRango) { %>
  <%- include('_filtro', { accion: '/admin/reportes/' + reporte.clave, rango: rango, periodos: periodos }) %>
<% } %>

<% if (datos.nota) { %>
  <div class="mb-5 flex items-start gap-2 rounded-xl bg-slate-50 p-3 text-xs text-slate-500">
    <svg class="mt-0.5 h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" /></svg>
    <span><%= datos.nota %></span>
  </div>
<% } %>

<!-- KPIs -->
<div class="mb-5 grid grid-cols-2 gap-3 lg:grid-cols-4">
  <% (datos.kpis || []).forEach(function (k) { %>
    <div class="card">
      <p class="text-xs font-medium uppercase tracking-wide text-slate-400"><%= k.etiqueta %></p>
      <p class="mt-1 text-xl font-bold text-slate-800 num"><%= valorFormateado(k.valor, k.tipo) %></p>
      <% if (k.cambio !== null && k.cambio !== undefined) { %>
        <p class="mt-1 text-xs font-medium <%= k.cambio >= 0 ? 'text-emerald-600' : 'text-red-600' %>">
          <%= k.cambio >= 0 ? '▲' : '▼' %> <%= Math.abs(k.cambio) %>% vs periodo anterior
        </p>
      <% } else if (k.nota) { %>
        <p class="mt-1 text-xs text-slate-400"><%= k.nota %></p>
      <% } %>
    </div>
  <% }); %>
</div>

<div class="mb-5 grid gap-4 <%= datos.resumenLateral ? 'lg:grid-cols-3' : '' %>">
  <!-- Gráfica -->
  <% if (datos.grafica && datos.grafica.labels && datos.grafica.labels.length) { %>
    <div class="card <%= datos.resumenLateral ? 'lg:col-span-2' : '' %>">
      <p class="mb-3 text-sm font-medium text-slate-700"><%= datos.grafica.etiqueta %></p>
      <div style="height:260px"><canvas id="grafica-reporte"></canvas></div>
    </div>
  <% } %>

  <!-- Desglose lateral (métodos de pago, tramos de mora, orígenes de caja…) -->
  <% if (datos.resumenLateral) { %>
    <div class="card">
      <p class="mb-3 text-sm font-medium text-slate-700"><%= datos.resumenLateral.titulo %></p>
      <% if (!datos.resumenLateral.filas.length) { %>
        <p class="py-6 text-center text-sm text-slate-400">Sin datos en este periodo.</p>
      <% } %>
      <div class="space-y-3">
        <% datos.resumenLateral.filas.forEach(function (f) { %>
          <div>
            <div class="flex items-baseline justify-between gap-2 text-sm">
              <span class="truncate text-slate-600"><%= f.etiqueta %></span>
              <span class="num shrink-0 font-medium text-slate-800"><%= formatCOP(f.valor) %></span>
            </div>
            <% if (f.pct !== null && f.pct !== undefined) { %>
              <div class="mt-1 h-1.5 overflow-hidden rounded-full bg-slate-100">
                <div class="h-full rounded-full bg-blue-500" style="width:<%= Math.max(2, f.pct) %>%"></div>
              </div>
            <% } %>
          </div>
        <% }); %>
      </div>
    </div>
  <% } %>
</div>

<!-- Detalle -->
<div class="card">
  <div class="mb-3 flex items-center justify-between">
    <p class="text-sm font-medium text-slate-700">Detalle</p>
    <span class="text-xs text-slate-400"><%= (datos.filas || []).length.toLocaleString('es-CO') %> registro(s)</span>
  </div>

  <% if (!datos.filas || !datos.filas.length) { %>
    <div class="py-12 text-center">
      <p class="text-sm text-slate-400">No hay datos para este periodo.</p>
      <p class="mt-1 text-xs text-slate-300">Prueba con un rango de fechas más amplio.</p>
    </div>
  <% } else { %>
    <div class="max-h-[600px] overflow-auto rounded-xl border border-slate-100">
      <table class="table-base w-full">
        <thead class="sticky top-0 bg-slate-50">
          <tr>
            <% datos.columnas.forEach(function (c) { %>
              <th class="<%= c.tipo === 'moneda' ? 'text-right' : '' %> whitespace-nowrap"><%= c.titulo %></th>
            <% }); %>
          </tr>
        </thead>
        <tbody>
          <% datos.filas.forEach(function (f) { %>
            <tr>
              <% datos.columnas.forEach(function (c) { %>
                <td class="<%= c.tipo === 'moneda' ? 'text-right num font-medium' : '' %> whitespace-nowrap">
                  <%= valorFormateado(f[c.clave], c.tipo) %>
                </td>
              <% }); %>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<% if (datos.grafica && datos.grafica.labels && datos.grafica.labels.length) { %>
<script>
  (function () {
    var ctx = document.getElementById('grafica-reporte');
    if (!ctx || !window.Chart) return;

    // JSON.stringify + escape de "</" para que un dato no pueda cerrar el
    // <script> e inyectar HTML.
    var labels = <%- JSON.stringify(datos.grafica.labels).replace(/<\//g, '<\\/') %>;
    var datos_ = <%- JSON.stringify(datos.grafica.datos).replace(/<\//g, '<\\/') %>;

    // Barras rojas cuando el valor es negativo (salidas en el flujo de caja).
    var colores = datos_.map(function (v) { return v < 0 ? '#ef4444' : '#16a34a'; });

    new Chart(ctx, {
      type: 'bar',
      data: { labels: labels, datasets: [{ data: datos_, backgroundColor: colores, borderRadius: 6, maxBarThickness: 48 }] },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function (c) {
                return new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(c.parsed.y);
              }
            }
          }
        },
        scales: {
          x: { grid: { display: false }, ticks: { color: '#94a3b8', font: { size: 11 } } },
          y: {
            grid: { color: '#f1f5f9' },
            ticks: {
              color: '#94a3b8', font: { size: 11 },
              callback: function (v) {
                // Miles/millones abreviados: un eje con cifras COP completas
                // se vuelve ilegible.
                var abs = Math.abs(v);
                if (abs >= 1000000) return (v / 1000000).toFixed(1).replace('.0', '') + 'M';
                if (abs >= 1000) return Math.round(v / 1000) + 'k';
                return v;
              }
            }
          }
        }
      }
    });
  })();
</script>
<% } %>
