<%
  // Estilo (color) + etiqueta legible por tipo de evento.
  function estiloEvento(tipo) {
    var m = {
      prestamo_creado:     'bg-blue-100 text-blue-700',
      prestamo_pagado:     'bg-emerald-100 text-emerald-700',
      abono_registrado:    'bg-emerald-100 text-emerald-700',
      cuota_pagada:        'bg-emerald-100 text-emerald-700',
      pago_interes:        'bg-amber-100 text-amber-700',
      cuota_mora:          'bg-red-100 text-red-700',
      cliente_creado:      'bg-violet-100 text-violet-700',
      cliente_editado:     'bg-slate-100 text-slate-600',
      cliente_activado:    'bg-emerald-100 text-emerald-700',
      cliente_desactivado: 'bg-amber-100 text-amber-700',
      documento_subido:    'bg-blue-100 text-blue-700',
      documento_eliminado: 'bg-red-100 text-red-700',
      caja_ingreso:        'bg-emerald-100 text-emerald-700',
      caja_egreso:         'bg-amber-100 text-amber-700',
    };
    return m[tipo] || 'bg-slate-100 text-slate-600';
  }
  var LABELS = {
    prestamo_creado: 'Préstamo creado', prestamo_pagado: 'Préstamo pagado',
    abono_registrado: 'Abono', cuota_pagada: 'Cuota pagada', pago_interes: 'Pago de interés',
    cuota_mora: 'Cuota en mora',
    cliente_creado: 'Cliente creado', cliente_editado: 'Cliente editado',
    cliente_activado: 'Cliente activado', cliente_desactivado: 'Cliente desactivado',
    documento_subido: 'Documento subido', documento_eliminado: 'Documento eliminado',
    caja_ingreso: 'Ingreso a caja', caja_egreso: 'Egreso de caja',
  };
  function etiqueta(tipo) { return LABELS[tipo] || tipo; }
  function fechaHora(iso) {
    var d = new Date(iso);
    var p = function (n) { return String(n).padStart(2, '0'); };
    return d.getFullYear() + '-' + p(d.getMonth() + 1) + '-' + p(d.getDate()) + ' · ' + p(d.getHours()) + ':' + p(d.getMinutes());
  }
  var cats = [['todos', 'Todos'], ['prestamos', 'Préstamos'], ['pagos', 'Pagos'], ['mora', 'Mora'], ['caja', 'Caja'], ['clientes', 'Clientes']];
%>

<style>
  @keyframes aud-float  { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
  @keyframes aud-orbit  { from{transform:rotateX(72deg) rotateZ(0deg)}   to{transform:rotateX(72deg) rotateZ(360deg)} }
  @keyframes aud-orbit2 { from{transform:rotateX(72deg) rotateZ(180deg)} to{transform:rotateX(72deg) rotateZ(540deg)} }
  @keyframes aud-shadow { 0%,100%{transform:translateX(-50%) scale(1);opacity:.35} 50%{transform:translateX(-50%) scale(.8);opacity:.18} }
  @keyframes aud-glow   { 0%,100%{opacity:.6} 50%{opacity:1} }
</style>
<div class="mb-6 flex flex-col items-center text-center gap-1">
  <div style="width:200px;height:124px;overflow:hidden;display:flex;align-items:center;justify-content:center;margin:0 auto .25rem;animation:aud-float 3s ease-in-out infinite;">
    <img src="/img/auditoria%20icono.webp" alt="Auditoría"
         style="width:224px;height:auto;max-width:none;" />
  </div>
  <h1 class="text-3xl font-bold text-slate-800">Auditoría</h1>
  <p class="text-sm text-slate-400">Bitácora inmutable de todo lo que ocurre en tu cartera.</p>
  <div class="mt-1 h-0.5 w-10 rounded-full bg-blue-600"></div>
</div>

<!-- Resumen por categoría -->
<%
  var _c = typeof conteos !== 'undefined' && conteos ? conteos : { total:0, prestamos:0, pagos:0, mora:0, caja:0, clientes:0 };
  // Íconos por categoría — MISMA fuente para las tarjetas y para los chips de abajo,
  // así el ícono de "Pagos" (etc.) es idéntico arriba y abajo.
  var icoPath = {
    todos:     '<rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/>',
    prestamos: '<rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18M9 16l2 2 4-4"/>',
    pagos:     '<rect x="2" y="5" width="20" height="14" rx="2"/><circle cx="12" cy="12" r="2.5"/><path d="M6 12h.01M18 12h.01"/>',
    mora:      '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
    caja:      '<rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 10h18"/><circle cx="12" cy="14" r="2"/>',
    clientes:  '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/>',
  };
  function icoSvg(cat, size) {
    return '<svg class="' + size + '" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">' + (icoPath[cat] || '') + '</svg>';
  }
  var tarjetas = [
    { cat:'todos',     bg:'bg-blue-100',    tx:'text-blue-600',    label:'Eventos registrados', valor:_c.total,     nota:'Total en el sistema' },
    { cat:'prestamos', bg:'bg-emerald-100', tx:'text-emerald-600', label:'Préstamos',           valor:_c.prestamos, nota:'Eventos registrados' },
    { cat:'pagos',     bg:'bg-violet-100',  tx:'text-violet-600',  label:'Pagos',               valor:_c.pagos,     nota:'Eventos registrados' },
    { cat:'mora',      bg:'bg-amber-100',   tx:'text-amber-600',   label:'Mora',                valor:_c.mora,      nota:'Eventos registrados' },
    { cat:'caja',      bg:'bg-cyan-100',    tx:'text-cyan-600',    label:'Caja',                valor:_c.caja,      nota:'Eventos registrados' },
    { cat:'clientes',  bg:'bg-indigo-100',  tx:'text-indigo-600',  label:'Clientes',            valor:_c.clientes,  nota:'Eventos registrados' },
  ];
%>
<div class="card mb-6 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 divide-slate-100 lg:divide-x">
  <% tarjetas.forEach(function(t, i) { %>
    <div class="flex items-center gap-3 <%= i > 0 ? 'lg:pl-4' : '' %>">
      <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full <%= t.bg %> <%= t.tx %>"><%- icoSvg(t.cat, 'h-5 w-5') %></span>
      <div class="min-w-0">
        <p class="text-xs text-slate-400 truncate"><%= t.label %></p>
        <p class="num text-2xl font-bold text-slate-800"><%= t.valor %></p>
        <p class="text-[11px] text-slate-400 truncate"><%= t.nota %></p>
      </div>
    </div>
  <% }); %>
</div>

<!-- Filtros + búsqueda + exportar -->
<div class="mb-4 flex flex-wrap items-center justify-center gap-2">
  <% cats.forEach(function(c) { var activo = (cat || 'todos') === c[0]; %>
    <a href="/admin/auditoria?cat=<%= c[0] %>"
       class="inline-flex items-center gap-1.5 rounded-full px-3.5 py-1.5 text-sm font-medium transition <%= activo ? 'bg-slate-800 text-white shadow-sm' : 'bg-white text-slate-500 ring-1 ring-slate-200 hover:bg-slate-50' %>">
      <%- icoSvg(c[0], 'h-4 w-4') %>
      <%= c[1] %>
    </a>
  <% }); %>

  <div class="relative w-full sm:w-64">
    <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
    </span>
    <input id="buscar-auditoria" type="text" placeholder="Buscar evento, cliente o referencia…"
      class="w-full rounded-full border border-slate-200 bg-white py-2 pl-9 pr-4 text-sm text-slate-600 focus:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-100" />
  </div>

  <div class="relative shrink-0">
    <button type="button" id="btn-exportar-auditoria"
      class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-600 transition hover:bg-slate-50">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12m0 0-4-4m4 4 4-4M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/></svg>
      Exportar
      <svg class="h-3.5 w-3.5 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
    </button>
    <div id="menu-exportar" class="hidden absolute right-0 top-full z-50 mt-2 w-44 overflow-hidden rounded-xl border border-slate-100 bg-white py-1 shadow-lg">
      <button type="button" id="exportar-json" class="flex w-full items-center gap-2 px-4 py-2 text-sm text-slate-600 transition hover:bg-slate-50">
        <svg class="h-4 w-4 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H7a2 2 0 0 0-2 2v4a2 2 0 0 1-2 2 2 2 0 0 1 2 2v4a2 2 0 0 0 2 2h1M16 3h1a2 2 0 0 1 2 2v4a2 2 0 0 0 2 2 2 2 0 0 0-2 2v4a2 2 0 0 1-2 2h-1"/></svg>
        Formato JSON
      </button>
    </div>
  </div>
</div>

<div class="card p-0">
  <% if (eventos.length === 0) { %>
    <p class="text-center text-sm text-slate-400 py-12">No hay eventos en esta categoría. Cada acción sobre préstamos, pagos, caja y clientes aparecerá aquí.</p>
  <% } else { %>
    <table class="table-base" data-datatable data-no-search>
      <thead>
        <tr>
          <th>Fecha</th>
          <th>Evento</th>
          <th>Descripción</th>
          <th>Cliente</th>
          <th>Cédula</th>
          <th>Registrado por</th>
        </tr>
      </thead>
      <tbody>
        <% eventos.forEach(function(ev) {
          var cli = ev.cliente || (ev.prestamo && ev.prestamo.perfiles) || null;
          var nombre = cli ? cli.nombre_completo : '';
          var doc = cli ? (cli.numero_documento || '') : '';
          var enlace = ev.prestamo_id ? ('/admin/prestamos/' + ev.prestamo_id) : (ev.cliente_id ? ('/admin/clientes/' + ev.cliente_id) : null);
        %>
          <tr>
            <td class="whitespace-nowrap text-slate-500 num"><%= fechaHora(ev.creado_en) %></td>
            <td><span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= estiloEvento(ev.tipo) %>"><%= etiqueta(ev.tipo) %></span></td>
            <td class="text-slate-700"><%= ev.descripcion %></td>
            <td>
              <% if (nombre && enlace) { %><a href="<%= enlace %>" class="font-medium text-slate-700 hover:text-blue-600 hover:underline"><%= nombre %></a>
              <% } else if (nombre) { %><span class="font-medium text-slate-700"><%= nombre %></span>
              <% } else { %><span class="text-slate-300">—</span><% } %>
            </td>
            <td class="num text-slate-500"><%= doc || '—' %></td>
            <td class="text-slate-500"><%= ev.actor ? ev.actor.nombre_completo : 'Sistema' %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</div>

<%
  // Datos para exportar (todos los eventos de la vista actual).
  var datosJson = eventos.map(function (ev) {
    var cli = ev.cliente || (ev.prestamo && ev.prestamo.perfiles) || null;
    return {
      fecha: fechaHora(ev.creado_en),
      tipo: ev.tipo,
      evento: etiqueta(ev.tipo),
      descripcion: ev.descripcion || '',
      cliente: cli ? cli.nombre_completo : null,
      cedula: cli ? (cli.numero_documento || null) : null,
      registrado_por: ev.actor ? ev.actor.nombre_completo : 'Sistema',
      creado_en: ev.creado_en,
      prestamo_id: ev.prestamo_id || null,
      cliente_id: ev.cliente_id || null,
    };
  });
%>
<script>
  (function () {
    // Búsqueda: conecta el input personalizado con la tabla (simple-datatables).
    var input = document.getElementById('buscar-auditoria');
    var tabla = document.querySelector('table[data-datatable]');
    if (input && tabla) {
      input.addEventListener('input', function () {
        var dt = tabla.datatableInstance;
        if (dt && typeof dt.search === 'function') dt.search(input.value);
      });
    }

    // Menú de exportar (abrir/cerrar).
    var btn = document.getElementById('btn-exportar-auditoria');
    var menu = document.getElementById('menu-exportar');
    if (btn && menu) {
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        menu.classList.toggle('hidden');
      });
      document.addEventListener('click', function () { menu.classList.add('hidden'); });
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape') menu.classList.add('hidden'); });
    }

    // Exportar a JSON.
    var datos = <%- JSON.stringify(datosJson).replace(/</g, '\\u003c') %>;
    var btnJson = document.getElementById('exportar-json');
    if (btnJson) {
      btnJson.addEventListener('click', function () {
        var json = JSON.stringify(datos, null, 2);
        var blob = new Blob([json], { type: 'application/json;charset=utf-8;' });
        var url = URL.createObjectURL(blob);
        var a = document.createElement('a');
        a.href = url;
        a.download = 'auditoria-<%= cat || "todos" %>-' + new Date().toISOString().slice(0, 10) + '.json';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
        if (menu) menu.classList.add('hidden');
      });
    }
  })();
</script>
