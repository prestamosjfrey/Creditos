<%
  function iniciales(nombre) {
    var p = (nombre || '').trim().split(/\s+/);
    return (((p[0] || '')[0] || '') + ((p[1] || '')[0] || '')).toUpperCase() || '?';
  }
  var paletas = [
    ['bg-blue-100', 'text-blue-600'], ['bg-violet-100', 'text-violet-600'],
    ['bg-emerald-100', 'text-emerald-600'], ['bg-amber-100', 'text-amber-600'],
    ['bg-rose-100', 'text-rose-600'], ['bg-cyan-100', 'text-cyan-600'],
  ];
  function paleta(nombre) {
    var s = nombre || 'A', suma = 0;
    for (var i = 0; i < s.length; i++) suma += s.charCodeAt(i);
    return paletas[suma % paletas.length];
  }
  var MESES = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];
  function fechaCorta(iso) {
    if (!iso) return '—';
    var d = new Date(iso + 'T00:00:00');
    return d.getDate() + ' ' + MESES[d.getMonth()] + ' ' + d.getFullYear();
  }
  var METODO = {
    efectivo: ['bg-emerald-50 text-emerald-600', 'Efectivo'],
    transferencia: ['bg-blue-50 text-blue-600', 'Transferencia'],
    nequi: ['bg-violet-50 text-violet-600', 'Nequi'],
    daviplata: ['bg-rose-50 text-rose-600', 'Daviplata'],
    otro: ['bg-slate-100 text-slate-500', 'Otro'],
  };
  var LABELS = { hoy: 'Hoy', ayer: 'Ayer', esta_semana: 'Esta semana', este_mes: 'Este mes', este_anio: 'Este año', personalizado: 'Personalizado' };
  var opciones = [['hoy', 'Hoy'], ['ayer', 'Ayer'], ['esta_semana', 'Esta semana'], ['este_mes', 'Este mes'], ['este_anio', 'Este año']];
%>

<style>
  @keyframes pag-float {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-10px); }
  }
  @keyframes pag-orbit {
    from { transform: rotateX(72deg) rotateZ(0deg); }
    to   { transform: rotateX(72deg) rotateZ(360deg); }
  }
  @keyframes pag-orbit2 {
    from { transform: rotateX(72deg) rotateZ(180deg); }
    to   { transform: rotateX(72deg) rotateZ(540deg); }
  }
  @keyframes pag-shadow {
    0%, 100% { transform: translateX(-50%) scale(1);   opacity: 0.35; }
    50%       { transform: translateX(-50%) scale(0.8); opacity: 0.18; }
  }
  @keyframes pag-glow {
    0%, 100% { opacity: 0.6; }
    50%       { opacity: 1;   }
  }
</style>

<div class="mb-8 flex flex-col items-center text-center gap-2">
  <div style="width:200px;height:124px;overflow:hidden;display:flex;align-items:center;justify-content:center;margin:0 auto 0.25rem;animation:pag-float 3s ease-in-out infinite;">
    <img src="/img/icono%20pagos.webp" alt="Pagos"
         style="width:224px;height:auto;max-width:none;" />
  </div>

  <h1 class="text-3xl font-bold text-slate-800">Pagos</h1>
  <p class="text-sm text-slate-400">Consulta y gestión de pagos registrados.</p>
  <div class="mt-1 h-0.5 w-10 rounded-full bg-violet-600"></div>
</div>

<!-- Filtro de periodo -->
<div class="mb-6 card py-3 px-4">
  <div class="flex flex-wrap items-center justify-center gap-2">
    <% opciones.forEach(function(o) { var act = periodo === o[0]; %>
      <a href="/admin/pagos?periodo=<%= o[0] %>"
         class="rounded-lg px-3 py-1.5 text-sm font-medium transition <%= act ? 'bg-blue-600 text-white' : 'text-slate-500 hover:bg-slate-100' %>">
        <%= o[1] %>
      </a>
    <% }); %>
    <span class="mx-1 h-5 w-px bg-slate-200"></span>
    <form method="GET" action="/admin/pagos" class="flex items-center gap-2">
      <input class="input-field py-1.5 text-sm" type="date" name="desde" value="<%= periodo === 'personalizado' ? (desde || '') : '' %>" />
      <span class="text-slate-300 text-sm">–</span>
      <input class="input-field py-1.5 text-sm" type="date" name="hasta" value="<%= periodo === 'personalizado' ? (hasta || '') : '' %>" />
      <button type="submit" class="rounded-lg px-3 py-1.5 text-sm font-medium text-slate-500 hover:bg-slate-100 transition">Aplicar</button>
    </form>
    <% if (periodo === 'personalizado' && desde && hasta) { %>
      <a href="/admin/pagos?periodo=esta_semana"
         class="inline-flex items-center justify-center rounded-lg text-white transition" title="Limpiar filtros"
         style="width:32px;height:32px;background:#ef4444;flex-shrink:0;" onmouseover="this.style.background='#dc2626'" onmouseout="this.style.background='#ef4444'">
        <svg style="width:15px;height:15px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </a>
    <% } %>
  </div>
</div>

<!-- Script anti-flash: aplica estado colapsado antes de pintar -->
<script>
  if (localStorage.getItem('pagos-stats-v') === '1') document.write('<style>#pagos-stats{display:none}</style>');
  if (localStorage.getItem('pagos-chart-v') === '1') document.write('<style>#pagos-chart-body{display:none}</style>');
</script>

<!-- Tarjetas -->
<div class="flex items-center justify-between mb-2">
  <span class="text-xs font-semibold text-slate-400 uppercase tracking-wide">Estadísticas</span>
  <button id="btn-toggle-stats" title="Mostrar / ocultar" class="flex items-center gap-1 rounded-lg px-2 py-1 text-xs text-slate-400 hover:bg-slate-100 transition">
    <svg id="ico-stats" style="width:14px;height:14px;transition:transform .25s" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m18 15-6-6-6 6"/></svg>
    <span id="lbl-stats">Ocultar</span>
  </button>
</div>
<div id="pagos-stats" class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <div class="card flex items-center gap-3">
    <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
    </span>
    <div>
      <p class="text-sm text-slate-400">Total en el período</p>
      <p class="num text-xl font-semibold text-slate-800"><%= formatCOP(stats.total) %></p>
      <% if (stats.cambioPct !== null) { %>
        <p class="text-xs <%= stats.cambioPct >= 0 ? 'text-emerald-600' : 'text-red-500' %>"><%= stats.cambioPct >= 0 ? '↑' : '↓' %> <%= Math.abs(stats.cambioPct) %>% vs período anterior</p>
      <% } else { %>
        <p class="text-xs text-slate-400">Sin período anterior</p>
      <% } %>
    </div>
  </div>

  <div class="card flex items-center gap-3">
    <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-blue-100 text-blue-600">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/></svg>
    </span>
    <div>
      <p class="text-sm text-slate-400">Pagos recibidos</p>
      <p class="num text-xl font-semibold text-slate-800"><%= stats.count %></p>
      <p class="text-xs text-slate-400">Transacciones</p>
    </div>
  </div>

  <div class="card flex items-center gap-3">
    <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-violet-100 text-violet-600">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M3 10h18M8 2v4M16 2v4"/></svg>
    </span>
    <div>
      <p class="text-sm text-slate-400">Promedio por día</p>
      <p class="num text-xl font-semibold text-slate-800"><%= formatCOP(stats.promedioDia) %></p>
    </div>
  </div>

  <div class="card flex items-center gap-3">
    <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-orange-100 text-orange-600">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m3 17 6-6 4 4 8-8"/><path d="M17 7h4v4"/></svg>
    </span>
    <div>
      <p class="text-sm text-slate-400">Mayor pago</p>
      <p class="num text-xl font-semibold text-slate-800"><%= stats.masAlto ? formatCOP(stats.masAlto.monto) : '—' %></p>
      <p class="text-xs text-slate-400"><%= stats.masAlto ? fechaCorta(stats.masAlto.fecha_pago) : '' %></p>
    </div>
  </div>
</div>

<!-- Tabla -->
<div class="card p-0">
  <table class="table-base" data-datatable>
    <thead>
      <tr>
        <th>Cliente</th>
        <th>Fecha</th>
        <th class="text-right">Monto</th>
        <th>Método</th>
        <th>Notas</th>
        <th data-sortable="false" class="text-right">Acción</th>
      </tr>
    </thead>
    <tbody>
      <% if (pagos.length === 0) { %>
        <tr><td colspan="6" class="px-3 py-6 text-center text-slate-500">No hay pagos en este período.</td></tr>
      <% } %>
      <% pagos.forEach(function(p) { var col = paleta(p.prestamos?.perfiles?.nombre_completo); var met = METODO[p.metodo] || METODO.otro; %>
        <tr>
          <td>
            <div class="flex items-center gap-3">
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full <%= col[0] %> <%= col[1] %> text-xs font-semibold"><%= iniciales(p.prestamos?.perfiles?.nombre_completo) %></span>
              <span class="font-medium text-slate-800"><%= p.prestamos?.perfiles?.nombre_completo || 'Cliente' %></span>
            </div>
          </td>
          <td class="text-slate-500"><%= fechaCorta(p.fecha_pago) %></td>
          <td class="num text-right font-semibold text-emerald-600"><%= formatCOP(p.monto) %></td>
          <td><span class="badge <%= met[0] %>"><%= met[1] %></span></td>
          <td class="text-slate-400"><%= p.notas || '—' %></td>
          <td class="text-right">
            <a href="/admin/prestamos/<%= p.prestamo_id %>" class="inline-flex items-center gap-1.5 text-blue-600 hover:underline text-sm">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
              Ver préstamo
            </a>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<!-- Gráfica -->
<div class="flex items-center justify-between mt-6 mb-2">
  <span class="text-xs font-semibold text-slate-400 uppercase tracking-wide">Gráfica</span>
  <button id="btn-toggle-chart" title="Mostrar / ocultar" class="flex items-center gap-1 rounded-lg px-2 py-1 text-xs text-slate-400 hover:bg-slate-100 transition">
    <svg id="ico-chart" style="width:14px;height:14px;transition:transform .25s" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m18 15-6-6-6 6"/></svg>
    <span id="lbl-chart">Ocultar</span>
  </button>
</div>
<div id="pagos-chart-body">
<div class="card">
  <h2 class="font-semibold text-slate-800 mb-3">Resumen de pagos</h2>
  <div class="flex flex-wrap items-center gap-1 mb-4">
      <% [['hoy','Hoy'],['ayer','Ayer'],['esta_semana','Esta semana'],['este_mes','Este mes'],['este_anio','Este año']].forEach(function(gg) { %>
        <button type="button" data-chartperiodo="<%= gg[0] %>"
          class="chart-periodo-btn rounded-lg px-3 py-1.5 text-sm font-medium transition <%= (gg[0] === periodo) ? 'bg-blue-600 text-white' : 'text-slate-500 hover:bg-slate-100' %>">
          <%= gg[1] %>
        </button>
      <% }); %>
      <span class="mx-1 h-5 w-px bg-slate-200"></span>
      <input id="chart-desde" class="input-field py-1.5 text-sm" type="date" style="width:140px;" />
      <span class="text-slate-300 text-sm">–</span>
      <input id="chart-hasta" class="input-field py-1.5 text-sm" type="date" style="width:140px;" />
      <button type="button" id="chart-aplicar" class="rounded-lg px-3 py-1.5 text-sm font-medium text-slate-500 hover:bg-slate-100 transition">Aplicar</button>
      <button type="button" id="chart-limpiar" title="Limpiar filtros"
        class="hidden inline-flex items-center justify-center rounded-lg text-white transition flex-shrink-0"
        style="width:32px;height:32px;background:#ef4444;"
        onmouseover="this.style.background='#dc2626'" onmouseout="this.style.background='#ef4444'">
        <svg style="width:15px;height:15px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <canvas id="chart-pagos" height="90"></canvas>
  </div><!-- /card -->
</div><!-- /pagos-chart-body -->

<script>
  window.__PAGOS__ = {
    pagos: <%- JSON.stringify(chartPagos).replace(/<\//g, '<\\/') %>,
    pagosAll: <%- JSON.stringify(chartPagosAll).replace(/<\//g, '<\\/') %>,
    desde: <%- JSON.stringify(desde) %>,
    hasta: <%- JSON.stringify(hasta) %>,
    gran: <%- JSON.stringify(granularidad) %>,
  };
  (function () {
    var D = window.__PAGOS__;
    var MESES = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];
    var DIAS = ['Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb', 'Dom'];
    var fmt = function (v) { return new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(v || 0); };
    function parse(iso) { return new Date(iso + 'T00:00:00'); }
    function isoOf(d) { return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0'); }
    function lunIdx(d) { return (d.getDay() + 6) % 7; }

    function bucketsDia() {
      var mapa = {}; D.pagos.forEach(function (p) { mapa[p.f] = (mapa[p.f] || 0) + p.m; });
      var dias = [], d = parse(D.desde), fin = parse(D.hasta);
      while (d <= fin) { dias.push(new Date(d)); d.setDate(d.getDate() + 1); }
      var conDS = dias.length <= 8, labels = [], valores = [];
      dias.forEach(function (dd) { labels.push((conDS ? DIAS[lunIdx(dd)] + ' ' : '') + dd.getDate() + ' ' + MESES[dd.getMonth()]); valores.push(mapa[isoOf(dd)] || 0); });
      return { labels: labels, valores: valores };
    }
    function bucketsSemana() {
      var mapa = {}; D.pagos.forEach(function (p) { var x = parse(p.f); x.setDate(x.getDate() - lunIdx(x)); var k = isoOf(x); mapa[k] = (mapa[k] || 0) + p.m; });
      var ini = parse(D.desde), fin = parse(D.hasta); var d = new Date(ini); d.setDate(d.getDate() - lunIdx(d));
      var labels = [], valores = [];
      while (d <= fin) { labels.push('Sem ' + d.getDate() + ' ' + MESES[d.getMonth()]); valores.push(mapa[isoOf(d)] || 0); d.setDate(d.getDate() + 7); }
      return { labels: labels, valores: valores };
    }
    function bucketsMes() {
      var mapa = {}; D.pagos.forEach(function (p) { var x = parse(p.f); var k = x.getFullYear() + '-' + x.getMonth(); mapa[k] = (mapa[k] || 0) + p.m; });
      var ini = parse(D.desde), fin = parse(D.hasta); var d = new Date(ini.getFullYear(), ini.getMonth(), 1);
      var labels = [], valores = [];
      while (d <= fin) { labels.push(MESES[d.getMonth()] + ' ' + d.getFullYear()); valores.push(mapa[d.getFullYear() + '-' + d.getMonth()] || 0); d.setMonth(d.getMonth() + 1); }
      return { labels: labels, valores: valores };
    }
    function buckets(g) { return g === 'mes' ? bucketsMes() : g === 'semana' ? bucketsSemana() : bucketsDia(); }

    var canvas = document.getElementById('chart-pagos');
    if (canvas && window.Chart) {
      var labelPlugin = {
        id: 'vlabels',
        afterDatasetsDraw: function (c) {
          var meta = c.getDatasetMeta(0); if (meta.data.length > 14) return;
          var ctx = c.ctx, ds = c.data.datasets[0];
          meta.data.forEach(function (bar, i) { var v = ds.data[i]; if (!v) return; ctx.save(); ctx.fillStyle = '#475569'; ctx.font = 'bold 9px sans-serif'; ctx.textAlign = 'center'; ctx.fillText(fmt(v), bar.x, bar.y - 6); ctx.restore(); });
        },
      };
      var granActiva = D.gran || 'dia';
      var d0 = buckets(granActiva);
      var chart = new Chart(canvas, {
        type: 'bar',
        data: { labels: d0.labels, datasets: [{ data: d0.valores, backgroundColor: '#16a34a', borderRadius: 6, maxBarThickness: 46 }] },
        options: {
          responsive: true, maintainAspectRatio: true,
          layout: { padding: { top: 18 } },
          plugins: { legend: { display: false }, tooltip: { callbacks: { label: function (it) { return fmt(it.raw); } } } },
          scales: { y: { beginAtZero: true, ticks: { callback: function (v) { return v >= 1000000 ? '$' + (v / 1000000) + 'M' : '$' + v.toLocaleString('es-CO'); } } }, x: { grid: { display: false } } },
        },
        plugins: [labelPlugin],
      });

      function rangoDePeriodo(p) {
        var hoy = new Date(); hoy.setHours(0,0,0,0);
        var iso = function(d) { return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0'); };
        var lunes = function(d) { var x=new Date(d); x.setDate(x.getDate()-((x.getDay()+6)%7)); return x; };
        if (p==='hoy') return { desde: iso(hoy), hasta: iso(hoy) };
        if (p==='ayer') { var a=new Date(hoy); a.setDate(a.getDate()-1); return { desde: iso(a), hasta: iso(a) }; }
        if (p==='esta_semana') { var s=lunes(hoy),e=new Date(s); e.setDate(s.getDate()+6); return { desde: iso(s), hasta: iso(e) }; }
        if (p==='este_mes') return { desde: iso(new Date(hoy.getFullYear(),hoy.getMonth(),1)), hasta: iso(new Date(hoy.getFullYear(),hoy.getMonth()+1,0)) };
        if (p==='este_anio') return { desde: iso(new Date(hoy.getFullYear(),0,1)), hasta: iso(new Date(hoy.getFullYear(),11,31)) };
        return { desde: D.desde, hasta: D.hasta };
      }

      function aplicarRangoChart(desde, hasta, gran) {
        var filtrado = D.pagosAll.filter(function(p) { return p.f >= desde && p.f <= hasta; });
        var tempD = D.desde, tempH = D.hasta, tempP = D.pagos;
        D.desde = desde; D.hasta = hasta; D.pagos = filtrado;
        var dd = buckets(gran || 'dia');
        D.desde = tempD; D.hasta = tempH; D.pagos = tempP;
        chart.data.labels = dd.labels;
        chart.data.datasets[0].data = dd.valores;
        chart.update();
      }

      var btnAplicar = document.getElementById('chart-aplicar');
      var btnLimpiar = document.getElementById('chart-limpiar');
      var claseActiva = 'chart-periodo-btn rounded-lg px-3 py-1.5 text-sm font-medium transition bg-blue-600 text-white';
      var claseInactiva = 'chart-periodo-btn rounded-lg px-3 py-1.5 text-sm font-medium transition text-slate-500 hover:bg-slate-100';

      if (btnAplicar) {
        btnAplicar.addEventListener('click', function () {
          var d = document.getElementById('chart-desde').value;
          var h = document.getElementById('chart-hasta').value;
          if (!d || !h) return;
          document.querySelectorAll('.chart-periodo-btn').forEach(function (x) { x.className = claseInactiva; });
          if (btnLimpiar) btnLimpiar.classList.remove('hidden');
          aplicarRangoChart(d, h, 'dia');
        });
      }

      if (btnLimpiar) {
        btnLimpiar.addEventListener('click', function () {
          btnLimpiar.classList.add('hidden');
          document.getElementById('chart-desde').value = '';
          document.getElementById('chart-hasta').value = '';
          aplicarRangoChart(D.desde, D.hasta, D.gran || 'dia');
        });
      }

      document.querySelectorAll('.chart-periodo-btn').forEach(function (b) {
        b.addEventListener('click', function () {
          document.querySelectorAll('.chart-periodo-btn').forEach(function (x) { x.className = claseInactiva; });
          b.className = claseActiva;
          if (btnLimpiar) btnLimpiar.classList.add('hidden');
          var rango = rangoDePeriodo(b.dataset.chartperiodo);
          var gran = b.dataset.chartperiodo === 'este_anio' ? 'mes' : 'dia';
          aplicarRangoChart(rango.desde, rango.hasta, gran);
        });
      });
    }

    // Toggles persistidos en localStorage
    var TOGGLE_DUR = 280;
    function initToggle(btnId, sectionId, icoId, lblId, key, displayVal) {
      var btn = document.getElementById(btnId);
      var sec = document.getElementById(sectionId);
      var ico = document.getElementById(icoId);
      var lbl = document.getElementById(lblId);
      if (!btn || !sec) return;
      var collapsed = false;
      var busy = false;
      sec.style.transition = 'opacity ' + TOGGLE_DUR + 'ms ease';

      function setBusy(on) {
        busy = on;
        btn.disabled = on;
        btn.style.opacity = on ? '0.45' : '';
        btn.style.cursor = on ? 'not-allowed' : '';
        // spinner: swap label text momentáneamente
        if (lbl) lbl.textContent = on ? '...' : (collapsed ? 'Mostrar' : 'Ocultar');
      }

      function aplicar(col, animate) {
        collapsed = col;
        localStorage.setItem(key, col ? '1' : '0');
        if (ico) ico.style.transform = col ? 'rotate(180deg)' : 'rotate(0deg)';
        if (!animate) {
          sec.style.display = col ? 'none' : (displayVal || 'block');
          if (lbl) lbl.textContent = col ? 'Mostrar' : 'Ocultar';
          return;
        }
        setBusy(true);
        if (col) {
          sec.style.opacity = '0';
          setTimeout(function () {
            sec.style.display = 'none';
            sec.style.opacity = '';
            setBusy(false);
          }, TOGGLE_DUR);
        } else {
          sec.style.opacity = '0';
          sec.style.display = displayVal || 'block';
          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              sec.style.opacity = '1';
              setTimeout(function () {
                sec.style.opacity = '';
                setBusy(false);
              }, TOGGLE_DUR);
            });
          });
        }
      }

      aplicar(localStorage.getItem(key) === '1', false);
      btn.addEventListener('click', function () { if (!busy) aplicar(!collapsed, true); });
    }
    initToggle('btn-toggle-stats', 'pagos-stats', 'ico-stats', 'lbl-stats', 'pagos-stats-v', 'grid');
    initToggle('btn-toggle-chart', 'pagos-chart-body', 'ico-chart', 'lbl-chart', 'pagos-chart-v', 'block');
  })();
</script>
