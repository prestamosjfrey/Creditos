<div class="max-w-lg mx-auto">
  <div class="mb-6 text-center">
    <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-blue-100 text-blue-600 text-xl font-semibold">
      <%= (usuario.nombre_completo || 'A').charAt(0).toUpperCase() %>
    </div>
    <h1 class="mt-3 text-xl font-semibold text-slate-800"><%= usuario.nombre_completo %></h1>
    <p class="text-sm text-slate-400">Administrador</p>
  </div>

  <div class="card divide-y divide-slate-100">
    <div class="py-3 flex justify-between">
      <span class="text-sm text-slate-400">Correo</span>
      <span class="text-sm font-medium text-slate-800"><%= usuario.email || '—' %></span>
    </div>
    <div class="py-3 flex justify-between">
      <span class="text-sm text-slate-400">Teléfono</span>
      <span class="text-sm font-medium text-slate-800"><%= usuario.telefono || '—' %></span>
    </div>
    <div class="py-3 flex justify-between">
      <span class="text-sm text-slate-400">Cédula</span>
      <span class="text-sm font-medium text-slate-800"><%= usuario.numero_documento || '—' %></span>
    </div>
  </div>

  <div class="card mt-6">
    <div class="flex items-center justify-between mb-4">
      <div>
        <p class="text-sm text-slate-400">Disponible para préstamo</p>
        <p class="num text-2xl font-semibold text-slate-800"><%= formatCOP(saldoDisponible) %></p>
      </div>
      <a href="/admin/caja" class="text-sm font-medium text-blue-600 hover:underline">Ver historial completo</a>
    </div>

    <form action="/admin/caja" method="POST" class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <input type="hidden" name="volver_a" value="/admin/configuracion" />
      <div>
        <label class="label-field" for="tipo">Tipo</label>
        <select class="input-field" id="tipo" name="tipo" required>
          <option value="ingreso">Ingreso (entra dinero)</option>
          <option value="egreso">Egreso (sale dinero)</option>
        </select>
      </div>
      <div>
        <label class="label-field" for="monto">Monto</label>
        <input class="input-field input-moneda" type="text" inputmode="numeric" id="monto" name="monto" required />
      </div>
      <div class="sm:col-span-2">
        <label class="label-field" for="concepto">Concepto</label>
        <input class="input-field" type="text" id="concepto" name="concepto" maxlength="200" placeholder="Ej. Saldo inicial de caja" required />
      </div>
      <div class="sm:col-span-2">
        <button type="submit" class="btn-primary w-full justify-center">Registrar movimiento</button>
      </div>
    </form>
  </div>

  <form action="/auth/logout" method="POST" class="mt-6">
    <button type="submit" class="btn-secondary w-full">Cerrar sesión</button>
  </form>
</div>
