
<style>
  @keyframes ct-float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
  @keyframes ct-orbit  { from{transform:rotateX(72deg) rotateZ(0deg)}   to{transform:rotateX(72deg) rotateZ(360deg)} }
  @keyframes ct-orbit2 { from{transform:rotateX(72deg) rotateZ(180deg)} to{transform:rotateX(72deg) rotateZ(540deg)} }
  @keyframes ct-shadow { 0%,100%{transform:translateX(-50%) scale(1);opacity:.35} 50%{transform:translateX(-50%) scale(.8);opacity:.18} }
  @keyframes ct-glow   { 0%,100%{opacity:.6} 50%{opacity:1} }
</style>

<div class="mb-8 flex flex-col items-center text-center gap-2">
  <div style="width:200px;height:124px;overflow:hidden;display:flex;align-items:center;justify-content:center;margin:0 auto .25rem;animation:ct-float 3s ease-in-out infinite;">
    <img src="/img/creditos%20tomados%20icono.webp" alt="Créditos tomados"
         style="width:224px;height:auto;max-width:none;" />
  </div>

  <h1 class="text-3xl font-bold text-slate-800">Créditos tomados</h1>
  <p class="text-sm text-slate-400"><%= creditos.length %> en total</p>
  <div class="mt-1 h-0.5 w-10 rounded-full bg-orange-500"></div>
</div>

<!-- Botón flotante -->
<a href="/admin/creditos-tomados/nuevo" title="Nuevo crédito"
  style="position:fixed;bottom:2rem;right:2rem;z-index:50;display:inline-flex;align-items:center;justify-content:center;width:3.5rem;height:3.5rem;border-radius:9999px;background:linear-gradient(145deg,#fb923c 0%,#ea580c 45%,#c2410c 100%);color:#fff;text-decoration:none;box-shadow:0 6px 20px rgba(234,88,12,.55),0 2px 6px rgba(0,0,0,.2),inset 0 1px 0 rgba(255,255,255,.25);transition:transform .15s ease,box-shadow .15s ease;"
  onmouseover="this.style.transform='translateY(-3px) scale(1.05)';this.style.boxShadow='0 12px 28px rgba(234,88,12,.65),0 4px 10px rgba(0,0,0,.25),inset 0 1px 0 rgba(255,255,255,.25)'"
  onmouseout="this.style.transform='translateY(0) scale(1)';this.style.boxShadow='0 6px 20px rgba(234,88,12,.55),0 2px 6px rgba(0,0,0,.2),inset 0 1px 0 rgba(255,255,255,.25)'">
  <svg style="width:22px;height:22px;filter:drop-shadow(0 1px 3px rgba(0,0,0,.3))" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M12 5v14M5 12h14"/></svg>
</a>

<!-- Stats -->
<%
  var _esc = function (s) { return String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); };
  function _tablaCred(rows, colLabel, total) {
    if (!rows.length) return '<p class="text-slate-400">Sin registros en esta categoría.</p>';
    var tb = rows.map(function (r) { return '<tr><td class="py-1 pr-2 text-slate-600">' + _esc(r[0]) + '</td><td class="py-1 text-right num text-slate-700 whitespace-nowrap">' + r[1] + '</td></tr>'; }).join('');
    var foot = total != null ? '<tfoot><tr><td class="pt-1 border-t border-slate-200 font-semibold text-slate-700">Total</td><td class="pt-1 border-t border-slate-200 text-right num font-semibold text-slate-800 whitespace-nowrap">' + total + '</td></tr></tfoot>' : '';
    return '<div class="rounded-lg border border-slate-100 bg-slate-50/60 p-2 mt-2"><p class="text-[11px] font-semibold uppercase tracking-wide text-slate-400 mb-1">' + colLabel + '</p><table class="w-full text-xs"><tbody>' + tb + '</tbody>' + foot + '</table></div>';
  }
  var _act = creditos.filter(function (c) { return c.estado === 'activo'; });
  var _moraCred = creditos.filter(function (c) { return c.estado === 'activo' && c.en_mora; });
  var _detActivos = '<p><strong>Créditos activos</strong></p><p>Créditos que tomaste y siguen vigentes (con saldo por pagar).</p>' + _tablaCred(_act.map(function (c) { return [c.acreedor, formatCOP(c.saldo_pendiente)]; }), 'Acreedor · saldo pendiente');
  var _detCapital = '<p><strong>Capital recibido (activos)</strong></p><p>Suma del capital que recibiste de tus créditos activos.</p>' + _tablaCred(_act.map(function (c) { return [c.acreedor, formatCOP(c.monto_capital)]; }), 'Acreedor · capital', formatCOP(stats.totalCapital));
  var _detDeuda = '<p><strong>Saldo por pagar</strong></p><p>Lo que aún debes de tus créditos activos (total pactado − abonado).</p>' + _tablaCred(_act.map(function (c) { return [c.acreedor, formatCOP(c.saldo_pendiente)]; }), 'Acreedor · saldo', formatCOP(stats.totalDeuda));
  var _detMora = '<p><strong>En mora</strong></p><p>Créditos activos con cuotas vencidas sin pagar.</p>' + _tablaCred(_moraCred.map(function (c) { return [c.acreedor, formatCOP(c.saldo_pendiente)]; }), 'Acreedor · saldo');
%>
<div class="flex items-center justify-between mb-2">
  <span class="text-xs font-semibold text-slate-400 uppercase tracking-wide">Resumen</span>
  <button id="btn-toggle-ct-stats" title="Mostrar / ocultar" class="flex items-center gap-1 rounded-lg px-2 py-1 text-xs text-slate-400 hover:bg-slate-100 transition">
    <svg id="ico-ct-stats" style="width:14px;height:14px;transition:transform .25s" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m18 15-6-6-6 6"/></svg>
    <span id="lbl-ct-stats">Ocultar</span>
  </button>
</div>
<div id="ct-stats" class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <%- include('../../partials/kpi-card', { titulo: 'Créditos activos', valor: stats.activos, explicaHtml: _detActivos }) %>
  <%- include('../../partials/kpi-card', { titulo: 'Capital recibido (activos)', valor: formatCOP(stats.totalCapital), explicaHtml: _detCapital }) %>
  <%- include('../../partials/kpi-card', { titulo: 'Saldo por pagar', valor: formatCOP(stats.totalDeuda), explicaHtml: _detDeuda }) %>
  <%- include('../../partials/kpi-card', { titulo: 'En mora', valor: stats.enMora, nota: 'créditos con cuotas vencidas', explicaHtml: _detMora }) %>
</div>
<script>
  (function () {
    var DUR = 220, KEY = 'ct-stats-v';
    var btn = document.getElementById('btn-toggle-ct-stats'), sec = document.getElementById('ct-stats');
    var ico = document.getElementById('ico-ct-stats'), lbl = document.getElementById('lbl-ct-stats');
    if (!btn || !sec) return;
    var collapsed = false, busy = false;
    sec.style.transition = 'opacity ' + DUR + 'ms ease';
    function estilo(col) {
      btn.style.background = col ? '#fbf4d6' : ''; btn.style.color = col ? '#15803d' : '';
      btn.style.fontWeight = col ? '600' : ''; btn.style.boxShadow = col ? 'inset 0 0 0 1px #e4c451' : '';
      btn.classList.toggle('text-slate-400', !col);
    }
    function setBusy(on) { busy = on; btn.disabled = on; btn.style.opacity = on ? '0.45' : ''; if (lbl) lbl.textContent = on ? '...' : (collapsed ? 'Mostrar' : 'Ocultar'); }
    function aplicar(col, animate) {
      collapsed = col;
      try { localStorage.setItem(KEY, col ? '1' : '0'); } catch (e) {}
      if (ico) ico.style.transform = col ? 'rotate(180deg)' : 'rotate(0deg)';
      estilo(col);
      if (!animate) { sec.style.display = col ? 'none' : 'grid'; if (lbl) lbl.textContent = col ? 'Mostrar' : 'Ocultar'; return; }
      setBusy(true);
      if (col) { sec.style.opacity = '0'; setTimeout(function () { sec.style.display = 'none'; sec.style.opacity = ''; setBusy(false); }, DUR); }
      else { sec.style.opacity = '0'; sec.style.display = 'grid'; requestAnimationFrame(function () { requestAnimationFrame(function () { sec.style.opacity = '1'; setTimeout(function () { sec.style.opacity = ''; setBusy(false); }, DUR); }); }); }
    }
    var g = false; try { g = localStorage.getItem(KEY) === '1'; } catch (e) {}
    aplicar(g, false);
    btn.addEventListener('click', function () { if (!busy) aplicar(!collapsed, true); });
  })();
</script>

<!-- Tabla -->
<% if (creditos.length === 0) { %>
  <div class="card text-center py-16 text-slate-400">
    <svg class="mx-auto h-12 w-12 mb-3 opacity-30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125h17.25c.621 0 1.125.504 1.125 1.125v.375m-19.5 0v8.25a1.125 1.125 0 0 0 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-8.25"/></svg>
    <p class="font-medium">Sin créditos registrados</p>
    <p class="text-sm mt-1">Registra el primer crédito que hayas tomado</p>
  </div>
<% } else { %>
  <div class="card overflow-x-auto">
    <table class="w-full text-sm" data-datatable>
      <thead>
        <tr class="border-b border-slate-100 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">
          <th class="pb-3 pr-4">N°</th>
          <th class="pb-3 pr-4">Acreedor</th>
          <th class="pb-3 pr-4">Capital</th>
          <th class="pb-3 pr-4">Cuota</th>
          <th class="pb-3 pr-4">Saldo</th>
          <th class="pb-3 pr-4">Próx. venc.</th>
          <th class="pb-3 pr-4">Estado</th>
          <th class="pb-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-50">
        <% creditos.forEach(function(c) { %>
          <tr class="hover:bg-slate-50 transition">
            <td class="py-3 pr-4 font-mono text-xs text-slate-400"><%= String(c.numero).padStart(3,'0') %></td>
            <td class="py-3 pr-4 font-medium text-slate-800"><%= c.acreedor %></td>
            <td class="py-3 pr-4 text-slate-700"><%= formatCOP(c.monto_capital) %></td>
            <td class="py-3 pr-4 text-slate-600">
              <%= formatCOP(c.valor_cuota) %>
              <span class="text-xs text-slate-400 block"><%= c.frecuencia_pago %></span>
            </td>
            <td class="py-3 pr-4 font-semibold text-slate-800"><%= formatCOP(c.saldo_pendiente) %></td>
            <td class="py-3 pr-4 text-slate-600">
              <% if (c.prox_vencimiento) { %>
                <%= c.prox_vencimiento %>
              <% } else { %>
                <span class="text-slate-300">—</span>
              <% } %>
            </td>
            <td class="py-3 pr-4">
              <% if (c.estado === 'pagado') { %>
                <span class="badge-exito">Pagado</span>
              <% } else if (c.en_mora) { %>
                <span class="badge-peligro">Mora</span>
              <% } else { %>
                <span class="badge-neutro">Activo</span>
              <% } %>
            </td>
            <td class="py-3">
              <a href="/admin/creditos-tomados/<%= c.id %>" class="text-blue-600 hover:underline text-xs font-medium">Ver</a>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
<% } %>
