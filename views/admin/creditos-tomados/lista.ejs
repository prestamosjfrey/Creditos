
<style>
  @keyframes ct-float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
  @keyframes ct-orbit  { from{transform:rotateX(72deg) rotateZ(0deg)}   to{transform:rotateX(72deg) rotateZ(360deg)} }
  @keyframes ct-orbit2 { from{transform:rotateX(72deg) rotateZ(180deg)} to{transform:rotateX(72deg) rotateZ(540deg)} }
  @keyframes ct-shadow { 0%,100%{transform:translateX(-50%) scale(1);opacity:.35} 50%{transform:translateX(-50%) scale(.8);opacity:.18} }
  @keyframes ct-glow   { 0%,100%{opacity:.6} 50%{opacity:1} }
</style>

<div class="mb-8 flex flex-col items-center text-center gap-2">
  <div style="position:relative;width:84px;height:92px;display:flex;align-items:center;justify-content:center;margin-bottom:.25rem">

    <div style="position:absolute;bottom:0;left:50%;width:72px;height:12px;background:radial-gradient(ellipse,rgba(234,88,12,.5) 0%,transparent 70%);border-radius:50%;animation:ct-shadow 3s ease-in-out infinite;"></div>

    <div style="animation:ct-float 3s ease-in-out infinite;position:relative;width:70px;height:70px;">
      <div style="position:absolute;inset:-18px;border-radius:50%;background:radial-gradient(circle,rgba(234,88,12,.22) 0%,transparent 65%);animation:ct-glow 3s ease-in-out infinite;pointer-events:none;"></div>
      <div style="position:absolute;inset:-14px;border-radius:50%;border:2px solid transparent;border-top:2px solid rgba(251,146,60,.85);border-bottom:2px solid rgba(251,146,60,.2);transform:rotateX(72deg);animation:ct-orbit 3.5s linear infinite;pointer-events:none;"></div>
      <div style="position:absolute;inset:-6px;border-radius:50%;border:1.5px solid transparent;border-right:1.5px solid rgba(253,186,116,.7);border-left:1.5px solid rgba(253,186,116,.15);transform:rotateX(72deg) rotateZ(180deg);animation:ct-orbit2 5s linear infinite;pointer-events:none;"></div>

      <div style="width:70px;height:70px;border-radius:50%;background:radial-gradient(circle at 33% 28%,#fde68a 0%,#f97316 28%,#ea580c 52%,#c2410c 70%,#7c2d12 88%,#431407 100%);box-shadow:0 12px 36px rgba(234,88,12,.65),0 4px 12px rgba(0,0,0,.25),inset 0 -8px 16px rgba(0,0,0,.35),inset 2px 2px 6px rgba(255,255,255,.08);position:relative;display:flex;align-items:center;justify-content:center;"
        onmouseover="this.parentElement.style.animationPlayState='paused';this.style.transform='scale(1.07)'"
        onmouseout="this.parentElement.style.animationPlayState='running';this.style.transform='scale(1)'">
        <div style="position:absolute;top:12%;left:16%;width:38%;height:30%;background:radial-gradient(ellipse at 40% 40%,rgba(255,255,255,.7) 0%,rgba(255,255,255,.15) 55%,transparent 100%);border-radius:50%;filter:blur(3px);pointer-events:none;"></div>
        <svg style="width:30px;height:30px;color:white;filter:drop-shadow(0 2px 6px rgba(0,0,0,.4));position:relative;z-index:1;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125h17.25c.621 0 1.125.504 1.125 1.125v.375m-19.5 0v8.25a1.125 1.125 0 0 0 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-8.25M12 11.25a2.625 2.625 0 1 1 0-5.25 2.625 2.625 0 0 1 0 5.25Z"/>
        </svg>
      </div>
    </div>
  </div>

  <h1 class="text-3xl font-bold text-slate-800">Créditos tomados</h1>
  <p class="text-sm text-slate-400"><%= creditos.length %> en total</p>
  <div class="mt-1 h-0.5 w-10 rounded-full bg-orange-500"></div>
</div>

<!-- Botón flotante -->
<a href="/admin/creditos-tomados/nuevo" title="Nuevo crédito"
  style="position:fixed;bottom:2rem;right:2rem;z-index:50;display:inline-flex;align-items:center;justify-content:center;width:3.5rem;height:3.5rem;border-radius:9999px;background:linear-gradient(145deg,#fb923c 0%,#ea580c 45%,#c2410c 100%);color:#fff;text-decoration:none;box-shadow:0 6px 20px rgba(234,88,12,.55),0 2px 6px rgba(0,0,0,.2),inset 0 1px 0 rgba(255,255,255,.25);transition:transform .15s ease,box-shadow .15s ease;"
  onmouseover="this.style.transform='translateY(-3px) scale(1.05)';this.style.boxShadow='0 12px 28px rgba(234,88,12,.65),0 4px 10px rgba(0,0,0,.25),inset 0 1px 0 rgba(255,255,255,.25)'"
  onmouseout="this.style.transform='translateY(0) scale(1)';this.style.boxShadow='0 6px 20px rgba(234,88,12,.55),0 2px 6px rgba(0,0,0,.2),inset 0 1px 0 rgba(255,255,255,.25)'">
  <svg style="width:22px;height:22px;filter:drop-shadow(0 1px 3px rgba(0,0,0,.3))" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M12 5v14M5 12h14"/></svg>
</a>

<!-- Stats -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <%- include('../../partials/kpi-card', { titulo: 'Créditos activos', valor: stats.activos }) %>
  <%- include('../../partials/kpi-card', { titulo: 'Capital recibido (activos)', valor: formatCOP(stats.totalCapital) }) %>
  <%- include('../../partials/kpi-card', { titulo: 'Saldo por pagar', valor: formatCOP(stats.totalDeuda) }) %>
  <%- include('../../partials/kpi-card', { titulo: 'En mora', valor: stats.enMora, nota: 'créditos con cuotas vencidas' }) %>
</div>

<!-- Tabla -->
<% if (creditos.length === 0) { %>
  <div class="card text-center py-16 text-slate-400">
    <svg class="mx-auto h-12 w-12 mb-3 opacity-30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125h17.25c.621 0 1.125.504 1.125 1.125v.375m-19.5 0v8.25a1.125 1.125 0 0 0 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-8.25"/></svg>
    <p class="font-medium">Sin créditos registrados</p>
    <p class="text-sm mt-1">Registra el primer crédito que hayas tomado</p>
  </div>
<% } else { %>
  <div class="card overflow-x-auto">
    <table class="w-full text-sm" data-datatable>
      <thead>
        <tr class="border-b border-slate-100 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">
          <th class="pb-3 pr-4">N°</th>
          <th class="pb-3 pr-4">Acreedor</th>
          <th class="pb-3 pr-4">Capital</th>
          <th class="pb-3 pr-4">Cuota</th>
          <th class="pb-3 pr-4">Saldo</th>
          <th class="pb-3 pr-4">Próx. venc.</th>
          <th class="pb-3 pr-4">Estado</th>
          <th class="pb-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-50">
        <% creditos.forEach(function(c) { %>
          <tr class="hover:bg-slate-50 transition">
            <td class="py-3 pr-4 font-mono text-xs text-slate-400"><%= String(c.numero).padStart(3,'0') %></td>
            <td class="py-3 pr-4 font-medium text-slate-800"><%= c.acreedor %></td>
            <td class="py-3 pr-4 text-slate-700"><%= formatCOP(c.monto_capital) %></td>
            <td class="py-3 pr-4 text-slate-600">
              <%= formatCOP(c.valor_cuota) %>
              <span class="text-xs text-slate-400 block"><%= c.frecuencia_pago %></span>
            </td>
            <td class="py-3 pr-4 font-semibold text-slate-800"><%= formatCOP(c.saldo_pendiente) %></td>
            <td class="py-3 pr-4 text-slate-600">
              <% if (c.prox_vencimiento) { %>
                <%= c.prox_vencimiento %>
              <% } else { %>
                <span class="text-slate-300">—</span>
              <% } %>
            </td>
            <td class="py-3 pr-4">
              <% if (c.estado === 'pagado') { %>
                <span class="badge-exito">Pagado</span>
              <% } else if (c.en_mora) { %>
                <span class="badge-peligro">Mora</span>
              <% } else { %>
                <span class="badge-neutro">Activo</span>
              <% } %>
            </td>
            <td class="py-3">
              <a href="/admin/creditos-tomados/<%= c.id %>" class="text-blue-600 hover:underline text-xs font-medium">Ver</a>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
<% } %>
