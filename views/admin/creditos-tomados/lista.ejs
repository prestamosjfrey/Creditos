<%- include('../../partials/header-admin', {
  tituloHeader: 'Créditos tomados',
  subtituloHeader: 'Dinero que has recibido en préstamo de terceros',
}) %>

<style>
  @keyframes ct-float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
  @keyframes ct-orbit { 0%{transform:rotate(0deg) translateX(38px) rotate(0deg)} 100%{transform:rotate(360deg) translateX(38px) rotate(-360deg)} }
  @keyframes ct-orbit2 { 0%{transform:rotate(180deg) translateX(30px) rotate(-180deg)} 100%{transform:rotate(540deg) translateX(30px) rotate(-540deg)} }
  @keyframes ct-shadow { 0%,100%{transform:scaleX(1);opacity:.35} 50%{transform:scaleX(.65);opacity:.18} }
  @keyframes ct-glow { 0%,100%{opacity:.55} 50%{opacity:.9} }
</style>

<!-- Header con esfera 3D naranja -->
<div class="relative flex items-center gap-6 mb-8 p-6 rounded-2xl overflow-hidden"
  style="background:linear-gradient(135deg,#fff7ed 0%,#fed7aa 50%,#fdba74 100%)">
  <div class="relative flex-shrink-0" style="width:90px;height:90px">
    <div style="position:absolute;inset:0;border-radius:50%;
      background:radial-gradient(circle at 33% 28%,#fde68a 0%,#f97316 28%,#ea580c 52%,#c2410c 70%,#7c2d12 88%,#431407 100%);
      box-shadow:0 8px 32px rgba(234,88,12,.45),inset 0 -4px 12px rgba(0,0,0,.25),inset 2px 3px 8px rgba(255,255,255,.35);
      animation:ct-float 3.8s ease-in-out infinite">
      <div style="position:absolute;top:14%;left:18%;width:28%;height:18%;border-radius:50%;
        background:rgba(255,255,255,.55);filter:blur(3px);transform:rotate(-30deg);animation:ct-glow 3.8s ease-in-out infinite"></div>
      <div style="position:absolute;top:0;left:0;right:0;bottom:0;border-radius:50%;display:flex;align-items:center;justify-content:center;animation:ct-orbit 6s linear infinite">
        <div style="width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.55);box-shadow:0 0 6px rgba(255,255,255,.8)"></div>
      </div>
      <div style="position:absolute;top:0;left:0;right:0;bottom:0;border-radius:50%;display:flex;align-items:center;justify-content:center;animation:ct-orbit2 9s linear infinite">
        <div style="width:5px;height:5px;border-radius:50%;background:rgba(255,255,255,.4);box-shadow:0 0 4px rgba(255,255,255,.6)"></div>
      </div>
    </div>
    <div style="position:absolute;bottom:-8px;left:50%;transform:translateX(-50%);width:60px;height:10px;border-radius:50%;
      background:rgba(0,0,0,.18);filter:blur(4px);animation:ct-shadow 3.8s ease-in-out infinite"></div>
  </div>
  <div class="flex-1 min-w-0">
    <h2 class="text-2xl font-bold text-orange-900">Mis créditos</h2>
    <p class="text-orange-700 text-sm mt-1">Registro de todo el dinero que has tomado prestado de terceros</p>
  </div>
  <a href="/admin/creditos-tomados/nuevo"
    class="flex-shrink-0 inline-flex items-center gap-2 rounded-xl bg-orange-600 px-4 py-2.5 font-medium text-white transition hover:bg-orange-700 shadow-sm">
    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 5v14M5 12h14"/></svg>
    Nuevo crédito
  </a>
</div>

<!-- Stats -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <%- include('../../partials/kpi-card', { titulo: 'Créditos activos', valor: stats.activos }) %>
  <%- include('../../partials/kpi-card', { titulo: 'Capital recibido (activos)', valor: formatCOP(stats.totalCapital) }) %>
  <%- include('../../partials/kpi-card', { titulo: 'Saldo por pagar', valor: formatCOP(stats.totalDeuda) }) %>
  <%- include('../../partials/kpi-card', { titulo: 'En mora', valor: stats.enMora, nota: 'créditos con cuotas vencidas' }) %>
</div>

<!-- Tabla -->
<% if (creditos.length === 0) { %>
  <div class="card text-center py-16 text-slate-400">
    <svg class="mx-auto h-12 w-12 mb-3 opacity-30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125h17.25c.621 0 1.125.504 1.125 1.125v.375m-19.5 0v8.25a1.125 1.125 0 0 0 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-8.25"/></svg>
    <p class="font-medium">Sin créditos registrados</p>
    <p class="text-sm mt-1">Registra el primer crédito que hayas tomado</p>
    <a href="/admin/creditos-tomados/nuevo" class="btn-primary mt-4 inline-flex">Registrar crédito</a>
  </div>
<% } else { %>
  <div class="card overflow-x-auto">
    <table class="w-full text-sm" data-datatable>
      <thead>
        <tr class="border-b border-slate-100 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">
          <th class="pb-3 pr-4">N°</th>
          <th class="pb-3 pr-4">Acreedor</th>
          <th class="pb-3 pr-4">Capital</th>
          <th class="pb-3 pr-4">Cuota</th>
          <th class="pb-3 pr-4">Saldo</th>
          <th class="pb-3 pr-4">Próx. venc.</th>
          <th class="pb-3 pr-4">Estado</th>
          <th class="pb-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-50">
        <% creditos.forEach(function(c) { %>
          <tr class="hover:bg-slate-50 transition">
            <td class="py-3 pr-4 font-mono text-xs text-slate-400"><%= String(c.numero).padStart(3,'0') %></td>
            <td class="py-3 pr-4 font-medium text-slate-800"><%= c.acreedor %></td>
            <td class="py-3 pr-4 text-slate-700"><%= formatCOP(c.monto_capital) %></td>
            <td class="py-3 pr-4 text-slate-600">
              <%= formatCOP(c.valor_cuota) %>
              <span class="text-xs text-slate-400 block"><%= c.frecuencia_pago %></span>
            </td>
            <td class="py-3 pr-4 font-semibold text-slate-800"><%= formatCOP(c.saldo_pendiente) %></td>
            <td class="py-3 pr-4 text-slate-600">
              <% if (c.prox_vencimiento) { %>
                <%= c.prox_vencimiento %>
              <% } else { %>
                <span class="text-slate-300">—</span>
              <% } %>
            </td>
            <td class="py-3 pr-4">
              <% if (c.estado === 'pagado') { %>
                <span class="badge-exito">Pagado</span>
              <% } else if (c.en_mora) { %>
                <span class="badge-peligro">Mora</span>
              <% } else { %>
                <span class="badge-neutro">Activo</span>
              <% } %>
            </td>
            <td class="py-3">
              <a href="/admin/creditos-tomados/<%= c.id %>" class="text-blue-600 hover:underline text-xs font-medium">Ver</a>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
<% } %>
