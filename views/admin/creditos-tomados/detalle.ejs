<%
  var hoy = new Date().toISOString().slice(0, 10);
  var pagado = cuotas.filter(function(c){ return c.estado === 'pagada'; }).reduce(function(a,c){ return a + Number(c.monto); }, 0);
  var saldo = Number(credito.monto_total_a_pagar) - pagado;
  var cuotasPend = cuotas.filter(function(c){ return c.estado !== 'pagada'; })
    .sort(function(a,b){ return a.fecha_vencimiento.localeCompare(b.fecha_vencimiento); });
  var proxCuota = cuotasPend[0];
  var enMora = cuotasPend.some(function(c){ return c.fecha_vencimiento < hoy; });
  var cuotasPagadasN = cuotas.filter(function(c){ return c.estado === 'pagada'; }).length;
  var diasRest = proxCuota ? Math.round((new Date(proxCuota.fecha_vencimiento + 'T00:00:00') - new Date(hoy + 'T00:00:00')) / 86400000) : null;
  var diasRestTxt = credito.estado === 'pagado' ? '—' : (diasRest === null ? '—' : (diasRest < 0 ? Math.abs(diasRest) + ' días de mora' : (diasRest === 0 ? 'Hoy' : diasRest + ' días')));
  var METODOS_LBL = { efectivo: 'Efectivo', transferencia: 'Transferencia', nequi: 'Nequi', daviplata: 'Daviplata', otro: 'Otro' };
%>

<%- include('../../partials/header-admin', {
  tituloHeader: credito.acreedor,
  subtituloHeader: 'Crédito tomado · ' + credito.fecha_inicio,
  mostrarVolver: true,
  volverUrl: '/admin/creditos-tomados',
}) %>

<% if (recienCreado) { %>
  <div class="mb-4 rounded-xl bg-emerald-50 border border-emerald-200 px-4 py-3 text-sm text-emerald-700 flex items-center gap-2">
    <svg class="h-4 w-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
    Crédito registrado correctamente. El capital entró a tu caja disponible.
  </div>
<% } %>
<% if (typeof req !== 'undefined' && req.query && req.query.pago === '1') { %>
  <div class="mb-4 rounded-xl bg-blue-50 border border-blue-200 px-4 py-3 text-sm text-blue-700">Pago registrado. Salió de tu caja disponible.</div>
<% } %>
<% if (typeof req !== 'undefined' && req.query && req.query.error) { %>
  <div class="mb-4 rounded-xl bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700"><%= req.query.error %></div>
<% } %>

<!-- Estado y badge -->
<div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
  <div class="flex items-center gap-3">
    <% if (credito.estado === 'pagado') { %>
      <span class="badge-exito text-sm px-3 py-1">Pagado</span>
    <% } else if (enMora) { %>
      <span class="badge-peligro text-sm px-3 py-1">En mora</span>
    <% } else { %>
      <span class="badge-neutro text-sm px-3 py-1">Activo</span>
    <% } %>
    <span class="text-sm text-slate-400"><%= credito.frecuencia_pago %> · <%= credito.numero_cuotas %> cuotas</span>
  </div>
</div>

<!-- KPIs -->
<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
  <%- include('../../partials/kpi-card', { titulo: 'Capital recibido', valor: formatCOP(credito.monto_capital) }) %>
  <%- include('../../partials/kpi-card', { titulo: 'Total a pagar', valor: formatCOP(credito.monto_total_a_pagar) }) %>
  <%- include('../../partials/kpi-card', { titulo: 'Pagado hasta ahora', valor: formatCOP(pagado) }) %>
  <%- include('../../partials/kpi-card', { titulo: 'Saldo por pagar', valor: formatCOP(saldo) }) %>
</div>

<div class="flex flex-col lg:flex-row gap-6 lg:items-start">
  <!-- Plan de cuotas + Historial -->
  <div class="flex-1 min-w-0 flex flex-col gap-6">
   <div>
    <h2 class="font-medium text-slate-700 mb-3">Plan de cuotas</h2>
    <div class="card overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-100 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">
            <th class="pb-3 pr-4">#</th>
            <th class="pb-3 pr-4">Vence</th>
            <th class="pb-3 pr-4 text-right">Monto</th>
            <th class="pb-3 pr-4 text-right">Pagado</th>
            <th class="pb-3 pr-4 text-right">Saldo</th>
            <th class="pb-3">Estado</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-50">
          <% cuotas.forEach(function(c) {
            var pagadaC = c.estado === 'pagada';
            var vencida = !pagadaC && c.fecha_vencimiento < hoy;
            var pag = pagadaC ? Number(c.monto) : 0;
            var sal = pagadaC ? 0 : Number(c.monto);
          %>
            <tr class="<%= pagadaC ? 'opacity-60' : '' %>">
              <td class="py-3 pr-4 font-mono text-xs text-slate-400"><%= String(c.numero_cuota).padStart(2,'0') %></td>
              <td class="py-3 pr-4 text-slate-700 <%= vencida ? 'text-red-600 font-medium' : '' %>"><%= c.fecha_vencimiento %></td>
              <td class="py-3 pr-4 text-right font-semibold text-slate-800"><%= formatCOP(c.monto) %></td>
              <td class="py-3 pr-4 text-right num text-emerald-600"><%= formatCOP(pag) %></td>
              <td class="py-3 pr-4 text-right num <%= sal > 0 ? 'text-slate-700' : 'text-slate-300' %>"><%= formatCOP(sal) %></td>
              <td class="py-3">
                <% if (pagadaC) { %>
                  <span class="badge-exito">Pagada</span>
                <% } else if (vencida) { %>
                  <span class="badge-peligro">Vencida</span>
                <% } else { %>
                  <span class="badge-neutro">Pendiente</span>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 border-t border-slate-100 mt-2 pt-4 text-sm">
        <div><p class="text-xs text-slate-400">Cuotas pagadas</p><p class="font-bold text-slate-800"><%= cuotasPagadasN %> <span class="text-slate-300 font-normal">/ <%= credito.numero_cuotas %></span></p></div>
        <div><p class="text-xs text-slate-400">Total pagado</p><p class="num font-bold text-emerald-600"><%= formatCOP(pagado) %></p></div>
        <div><p class="text-xs text-slate-400">Total pendiente</p><p class="num font-bold text-red-500"><%= formatCOP(saldo) %></p></div>
        <div><p class="text-xs text-slate-400">Días restantes</p><p class="font-bold text-slate-800"><%= diasRestTxt %></p></div>
      </div>
    </div>
   </div>

    <% if (pagos && pagos.length) { %>
   <div>
    <h2 class="font-medium text-slate-700 mb-3">Historial de abonos</h2>
    <div class="card p-0 overflow-x-auto">
      <table class="table-base w-full" data-datatable>
        <thead>
          <tr><th>Fecha</th><th class="text-right">Monto</th><th>Método</th><th>Aplicado a</th></tr>
        </thead>
        <tbody>
          <% pagos.forEach(function(p) {
            var cuotasArr = Array.isArray(p.cuotas) ? p.cuotas : [];
            var cuotasTxt = cuotasArr.length === 0 ? '—' : (cuotasArr.length === 1 ? 'Cuota ' + cuotasArr[0] : 'Cuotas ' + cuotasArr.join(', '));
            var fechaTxt = p.fecha_pago || (p.creado_en ? String(p.creado_en).slice(0,10) : '—');
          %>
            <tr>
              <td class="text-slate-500"><%= fechaTxt %></td>
              <td class="num text-right font-semibold text-slate-800"><%= formatCOP(p.monto) %></td>
              <td><span class="rounded-md bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-500"><%= METODOS_LBL[p.metodo] || p.metodo || '—' %></span></td>
              <td class="text-slate-500"><%= cuotasTxt %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
   </div>
    <% } %>
  </div>

  <!-- Registrar pago + Info -->
  <div class="w-full lg:w-96 lg:shrink-0 space-y-4">
    <!-- Registrar pago (mismo estilo que el abono de préstamos) -->
    <div class="card">
      <h2 class="flex items-center gap-2 font-semibold text-slate-800 mb-4">
        <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-orange-50 text-orange-500"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg></span>
        Registrar pago
      </h2>
      <% if (credito.estado === 'pagado' || cuotasPend.length === 0) { %>
        <div class="rounded-xl bg-emerald-50 px-4 py-6 text-center">
          <p class="font-medium text-emerald-700">Crédito pagado</p>
          <p class="text-xs text-emerald-600/80 mt-1">Ya saldaste este crédito por completo.</p>
        </div>
      <% } else { %>
        <form action="/admin/creditos-tomados/<%= credito.id %>/pagos" method="POST" id="form-pago-credito" data-loading-title="Registrando pago…">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div class="grid grid-cols-1 gap-3">
            <div>
              <label class="label-field" for="pago-monto">Monto a pagar</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">$</span>
                <input class="input-field pl-7 input-moneda" type="text" inputmode="numeric" id="pago-monto" name="monto" placeholder="0" required />
              </div>
            </div>
            <div>
              <label class="label-field" for="pago-metodo">Método de pago</label>
              <select class="input-field" id="pago-metodo" name="metodo">
                <option value="efectivo">Efectivo</option>
                <option value="transferencia">Transferencia</option>
                <option value="nequi">Nequi</option>
                <option value="daviplata">Daviplata</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div>
              <label class="label-field" for="pago-fecha">Fecha de pago</label>
              <input class="input-field" type="date" id="pago-fecha" name="fecha_pago" value="<%= hoy %>" required />
            </div>
            <div>
              <label class="label-field" for="pago-notas">Notas (opcional)</label>
              <input class="input-field" type="text" id="pago-notas" name="notas" maxlength="200" />
            </div>
          </div>

          <p class="label-field mt-4 mb-2">Pagar rápido</p>
          <div class="grid grid-cols-3 gap-2">
            <% cuotasPend.slice(0, 3).forEach(function(c) { %>
              <button type="button" class="chip-cuota-abono" data-monto="<%= c.monto %>">
                <span class="font-semibold text-slate-700">Cuota <%= c.numero_cuota %></span>
                <span class="text-slate-400"><%= formatCOP(c.monto) %></span>
              </button>
            <% }); %>
          </div>

          <!-- Resumen del pago (en vivo) -->
          <div class="mt-4 rounded-xl border border-slate-100 bg-slate-50/70 p-3">
            <p class="flex items-center gap-1.5 text-xs font-semibold text-slate-500 mb-2"><svg class="h-3.5 w-3.5 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path stroke-linecap="round" d="M12 16v-4M12 8h.01"/></svg>Resumen del pago</p>
            <div class="flex justify-between text-sm py-0.5"><span class="text-slate-400">Cuotas que cubre</span><span class="num font-medium text-slate-700" id="pago-cuotas">0</span></div>
            <div class="flex justify-between text-sm py-0.5"><span class="text-slate-400">Monto aplicado</span><span class="num font-medium text-slate-700" id="pago-aplicado">$ 0</span></div>
            <div class="flex justify-between text-sm py-0.5 border-t border-slate-200 mt-1 pt-1.5"><span class="font-medium text-slate-600">Nuevo saldo por pagar</span><span class="num font-bold text-red-500" id="pago-saldo"><%= formatCOP(saldo) %></span></div>
          </div>

          <button type="submit" class="btn-primary w-full mt-4 bg-orange-600 hover:bg-orange-700">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            Registrar pago
          </button>
        </form>
      <% } %>
    </div>
  </div>
</div>

<script>
(function () {
  var input = document.getElementById('pago-monto');
  if (!input) return;
  // Montos de las cuotas pendientes, en orden de vencimiento.
  var pend = <%- JSON.stringify(cuotasPend.map(function(c){ return Number(c.monto); })) %>;
  var saldo = <%- JSON.stringify(saldo) %>;
  var fmt = window.formatearMoneda || function (v) { return String(Math.round(v || 0)); };
  function cop(v) { return '$ ' + Math.round(v || 0).toLocaleString('es-CO'); }

  function actualizar() {
    var monto = window.parseMoneda ? window.parseMoneda(input.value) : (Number(input.value) || 0);
    var restante = monto, cubiertas = 0, aplicado = 0;
    for (var i = 0; i < pend.length; i++) {
      if (restante + 1e-6 >= pend[i]) { cubiertas++; aplicado += pend[i]; restante -= pend[i]; }
      else break;
    }
    document.getElementById('pago-cuotas').textContent = cubiertas;
    document.getElementById('pago-aplicado').textContent = cop(aplicado);
    document.getElementById('pago-saldo').textContent = cop(saldo - aplicado);
  }

  input.addEventListener('input', actualizar);
  document.querySelectorAll('[data-monto]').forEach(function (b) {
    b.addEventListener('click', function () { input.value = fmt(Number(b.dataset.monto)); actualizar(); });
  });
  actualizar();
})();
</script>
