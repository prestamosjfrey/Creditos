<%
  var hoy = new Date().toISOString().slice(0, 10);
  var pagado = cuotas.filter(function(c){ return c.estado === 'pagada'; }).reduce(function(a,c){ return a + Number(c.monto); }, 0);
  var saldo = Number(credito.monto_total_a_pagar) - pagado;
  var cuotasPend = cuotas.filter(function(c){ return c.estado !== 'pagada'; })
    .sort(function(a,b){ return a.fecha_vencimiento.localeCompare(b.fecha_vencimiento); });
  var proxCuota = cuotasPend[0];
  var enMora = cuotasPend.some(function(c){ return c.fecha_vencimiento < hoy; });
  var cuotasPagadasN = cuotas.filter(function(c){ return c.estado === 'pagada'; }).length;
  var diasRest = proxCuota ? Math.round((new Date(proxCuota.fecha_vencimiento + 'T00:00:00') - new Date(hoy + 'T00:00:00')) / 86400000) : null;
  var diasRestTxt = credito.estado === 'pagado' ? '—' : (diasRest === null ? '—' : (diasRest < 0 ? Math.abs(diasRest) + ' días de mora' : (diasRest === 0 ? 'Hoy' : diasRest + ' días')));
  var METODOS_LBL = { efectivo: 'Efectivo', transferencia: 'Transferencia', nequi: 'Nequi', daviplata: 'Daviplata', otro: 'Otro' };
  // Interés por cuota = (total a pagar − capital) ÷ nº de cuotas. Se usa como
  // referencia al pagar SOLO el interés (extensión).
  var interesPorCuota = Math.round(Math.max(0, Number(credito.monto_total_a_pagar) - Number(credito.monto_capital)) / (Number(credito.numero_cuotas) || 1));
%>

<%- include('../../partials/header-admin', {
  tituloHeader: credito.acreedor,
  subtituloHeader: 'Crédito tomado · ' + credito.fecha_inicio,
  mostrarVolver: true,
  volverUrl: '/admin/creditos-tomados',
}) %>

<% if (recienCreado) { %>
  <div class="mb-4 rounded-xl bg-emerald-50 border border-emerald-200 px-4 py-3 text-sm text-emerald-700 flex items-center gap-2">
    <svg class="h-4 w-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
    Crédito registrado correctamente. El capital entró a tu caja disponible.
  </div>
<% } %>
<% if (typeof req !== 'undefined' && req.query && req.query.pago === '1') { %>
  <div class="mb-4 rounded-xl bg-blue-50 border border-blue-200 px-4 py-3 text-sm text-blue-700">Pago registrado. Salió de tu caja disponible.</div>
<% } %>
<% if (typeof req !== 'undefined' && req.query && req.query.ok) { %>
  <div class="mb-4 rounded-xl bg-emerald-50 border border-emerald-200 px-4 py-3 text-sm text-emerald-700"><%= req.query.ok %></div>
<% } %>
<% if (typeof req !== 'undefined' && req.query && req.query.error) { %>
  <div class="mb-4 rounded-xl bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700"><%= req.query.error %></div>
<% } %>

<!-- Estado y badge -->
<div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
  <div class="flex items-center gap-3">
    <% if (credito.estado === 'pagado') { %>
      <span class="badge-exito text-sm px-3 py-1">Pagado</span>
    <% } else if (enMora) { %>
      <span class="badge-peligro text-sm px-3 py-1">En mora</span>
    <% } else { %>
      <span class="badge-neutro text-sm px-3 py-1">Activo</span>
    <% } %>
    <span class="text-sm text-slate-400"><%= credito.frecuencia_pago %> · <%= credito.numero_cuotas %> cuotas</span>
  </div>

  <!-- Acciones: activar el modo edición sobre esta misma pantalla. -->
  <div class="flex items-center gap-2">
    <button type="button" id="btn-modo-edicion" class="accion-detalle">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
      <span id="btn-modo-edicion-txt">Editar</span>
    </button>
    <!-- Solo aparece en modo edición. En rojo: acción destructiva. -->
    <button type="button" id="btn-eliminar-credito" class="solo-edicion oculto accion-detalle accion-detalle-peligro">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M8 6V4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2m3 0v14a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V6h14ZM10 11v6M14 11v6"/></svg>
      Eliminar
    </button>
  </div>
</div>

<!-- ===================== BARRA DEL MODO EDICIÓN ===================== -->
<div id="barra-edicion" class="mb-6 hidden overflow-hidden rounded-xl border border-amber-300 bg-amber-50/70">
  <!-- Encabezado compacto (una línea) -->
  <div class="flex items-start gap-2 px-4 py-2.5 text-amber-800">
    <svg class="mt-0.5 h-4 w-4 shrink-0 text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" /></svg>
    <p class="text-xs leading-relaxed sm:text-sm">
      <span class="font-semibold text-amber-900">Modo edición.</span>
      Edita las cuotas <strong>pendientes</strong>, ajusta el plan, revierte un pago o elimina el crédito. Las pagadas no se editan; todo se audita.
    </p>
  </div>

  <!-- Editar el plan: una sola fila en escritorio -->
  <form action="/admin/creditos-tomados/<%= credito.id %>/plan" method="POST" id="form-plan"
        class="flex flex-col gap-3 border-t border-amber-200/70 bg-white/40 px-4 py-3 sm:flex-row sm:items-end">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="sm:w-48">
      <label class="label-field" for="ed-total">Total a pagar</label>
      <input class="input-field input-moneda" type="text" inputmode="numeric" id="ed-total"
             name="monto_total_a_pagar" value="<%= Math.round(credito.monto_total_a_pagar) %>" required />
    </div>
    <div class="sm:w-40">
      <label class="label-field" for="ed-cuotas">N.º de cuotas</label>
      <input class="input-field" type="number" min="1" max="500" id="ed-cuotas"
             name="numero_cuotas" value="<%= credito.numero_cuotas %>" required />
    </div>
    <button type="submit" class="btn-primary justify-center sm:ml-auto sm:w-auto">Guardar plan</button>
  </form>

  <!-- Formularios ocultos que disparan los botones tras confirmar. -->
  <form action="/admin/creditos-tomados/<%= credito.id %>/eliminar" method="POST" id="form-eliminar" class="hidden">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
  </form>
  <form method="POST" id="form-eliminar-pago" class="hidden">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
  </form>
</div>

<!-- KPIs -->
<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
  <%- include('../../partials/kpi-card', { titulo: 'Capital recibido', valor: formatCOP(credito.monto_capital) }) %>
  <%- include('../../partials/kpi-card', { titulo: 'Total a pagar', valor: formatCOP(credito.monto_total_a_pagar) }) %>
  <%- include('../../partials/kpi-card', { titulo: 'Pagado hasta ahora', valor: formatCOP(pagado) }) %>
  <%- include('../../partials/kpi-card', { titulo: 'Saldo por pagar', valor: formatCOP(saldo) }) %>
</div>

<div class="flex flex-col lg:flex-row gap-6 lg:items-stretch">
  <!-- Plan de cuotas + Historial -->
  <div class="flex-1 min-w-0 flex flex-col gap-6">
   <div>
    <h2 class="font-medium text-slate-700 mb-3">Plan de cuotas</h2>
    <div class="card overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-100 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">
            <th class="pb-3 pr-4">#</th>
            <th class="pb-3 pr-4">Vence</th>
            <th class="pb-3 pr-4 text-right">Monto</th>
            <th class="pb-3 pr-4 text-right">Pagado</th>
            <th class="pb-3 pr-4 text-right">Saldo</th>
            <th class="pb-3">Estado</th>
            <th class="col-edicion hidden pb-3 pl-3 text-right">Editar</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-50">
          <% cuotas.forEach(function(c) {
            var pagadaC = c.estado === 'pagada';
            var vencida = !pagadaC && c.fecha_vencimiento < hoy;
            var pag = pagadaC ? Number(c.monto) : 0;
            var sal = pagadaC ? 0 : Number(c.monto);
          %>
            <tr class="<%= pagadaC ? 'opacity-60' : '' %>">
              <td class="py-3 pr-4 font-mono text-xs text-slate-400"><%= String(c.numero_cuota).padStart(2,'0') %></td>
              <td class="py-3 pr-4 text-slate-700 <%= vencida ? 'text-red-600 font-medium' : '' %>"><%= c.fecha_vencimiento %></td>
              <td class="py-3 pr-4 text-right font-semibold text-slate-800"><%= formatCOP(c.monto) %></td>
              <td class="py-3 pr-4 text-right num text-emerald-600"><%= formatCOP(pag) %></td>
              <td class="py-3 pr-4 text-right num <%= sal > 0 ? 'text-slate-700' : 'text-slate-300' %>"><%= formatCOP(sal) %></td>
              <td class="py-3">
                <% if (pagadaC) { %>
                  <span class="badge-exito">Pagada</span>
                <% } else if (vencida) { %>
                  <span class="badge-peligro">Vencida</span>
                <% } else { %>
                  <span class="badge-neutro">Pendiente</span>
                <% } %>
              </td>
              <!-- Solo visible en modo edición. Las cuotas pagadas no se tocan. -->
              <td class="col-edicion hidden py-3 pl-3 text-right">
                <% if (pagadaC) { %>
                  <span class="text-xs text-slate-300" title="Una cuota pagada no se puede editar">Pagada</span>
                <% } else { %>
                  <button type="button" class="btn-editar-cuota text-xs font-medium text-blue-600 hover:underline"
                          data-cuota="<%= c.id %>"
                          data-numero="<%= c.numero_cuota %>"
                          data-valor="<%= Math.round(c.monto) %>"
                          data-fecha="<%= c.fecha_vencimiento %>">
                    Modificar
                  </button>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
      <!-- Formulario oculto para editar UNA cuota (lo rellena el diálogo). -->
      <form id="form-editar-cuota" method="POST" class="hidden">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="monto" id="ec-monto" />
        <input type="hidden" name="fecha_vencimiento" id="ec-fecha" />
      </form>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 border-t border-slate-100 mt-2 pt-4 text-sm">
        <div><p class="text-xs text-slate-400">Cuotas pagadas</p><p class="font-bold text-slate-800"><%= cuotasPagadasN %> <span class="text-slate-300 font-normal">/ <%= credito.numero_cuotas %></span></p></div>
        <div><p class="text-xs text-slate-400">Total pagado</p><p class="num font-bold text-emerald-600"><%= formatCOP(pagado) %></p></div>
        <div><p class="text-xs text-slate-400">Total pendiente</p><p class="num font-bold text-red-500"><%= formatCOP(saldo) %></p></div>
        <div><p class="text-xs text-slate-400">Días restantes</p><p class="font-bold text-slate-800"><%= diasRestTxt %></p></div>
      </div>
    </div>
   </div>

   <div class="flex flex-1 flex-col">
    <h2 class="font-medium text-slate-700 mb-3">Historial de abonos</h2>
    <% if (pagos && pagos.length) { %>
    <div class="card flex-1 p-0 overflow-x-auto">
      <table class="table-base w-full" data-datatable>
        <thead>
          <tr><th>Fecha</th><th class="text-right">Monto</th><th>Método</th><th>Aplicado a</th><th class="col-edicion hidden text-right" data-no-sort>Revertir</th></tr>
        </thead>
        <tbody>
          <% pagos.forEach(function(p) {
            var cuotasArr = Array.isArray(p.cuotas) ? p.cuotas : [];
            var cuotasTxt = cuotasArr.length === 0 ? '—' : (cuotasArr.length === 1 ? 'Cuota ' + cuotasArr[0] : 'Cuotas ' + cuotasArr.join(', '));
            var fechaTxt = p.fecha_pago || (p.creado_en ? String(p.creado_en).slice(0,10) : '—');
          %>
            <tr>
              <td class="text-slate-500"><%= fechaTxt %></td>
              <td class="num text-right font-semibold text-slate-800"><%= formatCOP(p.monto) %></td>
              <td><span class="rounded-md bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-500"><%= METODOS_LBL[p.metodo] || p.metodo || '—' %></span><% if (p.tipo === 'interes') { %><span class="ml-1 rounded-md bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-600">Solo interés</span><% } %></td>
              <td class="text-slate-500"><%= cuotasTxt %></td>
              <td class="col-edicion hidden text-right">
                <% if (p.id) { %>
                  <button type="button" class="btn-revertir-pago text-xs font-medium text-red-600 hover:underline"
                          data-pago="<%= p.id %>" data-valor="<%= Math.round(p.monto) %>">
                    Revertir
                  </button>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <!-- Sin abonos aún: placeholder que llena el alto para quedar a la par de
         la tarjeta de "Registrar pago" de al lado. -->
    <div class="card flex flex-1 flex-col items-center justify-center gap-2 border border-dashed border-slate-200 py-10 text-center">
      <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-slate-100 text-slate-400">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20M6 15h4"/></svg>
      </span>
      <p class="font-medium text-slate-500">Aún no hay abonos</p>
      <p class="max-w-xs text-xs text-slate-400">Cuando registres un pago aparecerá aquí con su fecha, monto, método y las cuotas que cubrió.</p>
    </div>
    <% } %>
   </div>
  </div>

  <!-- Registrar pago + Info -->
  <div class="w-full lg:w-96 lg:shrink-0 space-y-4">
    <!-- Registrar pago (mismo estilo que el abono de préstamos) -->
    <div class="card">
      <h2 class="flex items-center gap-2 font-semibold text-slate-800 mb-4">
        <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-orange-50 text-orange-500"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg></span>
        Registrar pago
      </h2>
      <% if (credito.estado === 'pagado' || cuotasPend.length === 0) { %>
        <div class="rounded-xl bg-emerald-50 px-4 py-6 text-center">
          <p class="font-medium text-emerald-700">Crédito pagado</p>
          <p class="text-xs text-emerald-600/80 mt-1">Ya saldaste este crédito por completo.</p>
        </div>
      <% } else { %>
        <form action="/admin/creditos-tomados/<%= credito.id %>/pagos" method="POST" id="form-pago-credito" data-loading-title="Registrando pago…">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="cuota_id" id="pago-cuota-id" value="" />
          <div class="grid grid-cols-1 gap-3">
            <div>
              <label class="label-field" for="pago-tipo">Tipo de pago</label>
              <select class="input-field" id="pago-tipo" name="tipo">
                <option value="abono">Abono normal</option>
                <option value="interes">Solo interés</option>
              </select>
            </div>
            <div>
              <label class="label-field" for="pago-monto"><span id="pago-monto-label">Monto a pagar</span></label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">$</span>
                <input class="input-field pl-7 input-moneda" type="text" inputmode="numeric" id="pago-monto" name="monto" placeholder="0" required />
              </div>
            </div>
            <div>
              <label class="label-field" for="pago-metodo">Método de pago</label>
              <select class="input-field" id="pago-metodo" name="metodo">
                <option value="efectivo">Efectivo</option>
                <option value="transferencia">Transferencia</option>
                <option value="nequi">Nequi</option>
                <option value="daviplata">Daviplata</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div>
              <label class="label-field" for="pago-fecha">Fecha de pago</label>
              <input class="input-field" type="date" id="pago-fecha" name="fecha_pago" value="<%= hoy %>" required />
            </div>
            <div>
              <label class="label-field" for="pago-notas">Notas (opcional)</label>
              <input class="input-field" type="text" id="pago-notas" name="notas" maxlength="200" />
            </div>
          </div>

          <!-- Opciones para pago de SOLO INTERÉS -->
          <div id="bloque-interes" class="hidden mt-3 rounded-xl border border-amber-200 bg-amber-50 p-3 space-y-2">
            <div>
              <label class="label-field" for="interes-cuota">Cuota</label>
              <select class="input-field text-sm" id="interes-cuota">
                <% cuotasPend.forEach(function(c) { %>
                  <option value="<%= c.id %>" data-monto="<%= c.monto %>">Cuota <%= c.numero_cuota %> · <%= c.fecha_vencimiento %> · <%= formatCOP(c.monto) %></option>
                <% }); %>
              </select>
            </div>
            <p class="text-sm font-medium text-amber-800 pt-1">¿Qué se hace con el capital de esta cuota?</p>
            <label class="flex items-start gap-2 text-sm text-slate-600">
              <input type="radio" name="accion" value="saldo" class="mt-1" checked />
              <span><span class="font-medium text-slate-700">Dejar el capital para después</span> — el capital se difiere a una cuota nueva al final, sin interés extra.</span>
            </label>
            <label class="flex items-start gap-2 text-sm text-slate-600">
              <input type="radio" name="accion" value="extension" class="mt-1" />
              <span><span class="font-medium text-slate-700">Extender un periodo</span> — se agrega una cuota más con interés de <%= formatCOP(interesPorCuota) %>; el capital se difiere al final.</span>
            </label>
          </div>

          <div id="bloque-abono">
            <p class="label-field mt-4 mb-2">Pagar rápido</p>
            <div class="grid grid-cols-3 gap-2">
              <% cuotasPend.slice(0, 3).forEach(function(c) { %>
                <button type="button" class="chip-cuota-abono" data-monto="<%= c.monto %>">
                  <span class="font-semibold text-slate-700">Cuota <%= c.numero_cuota %></span>
                  <span class="text-slate-400"><%= formatCOP(c.monto) %></span>
                </button>
              <% }); %>
            </div>
          </div>

          <!-- Resumen del pago (en vivo) -->
          <div class="mt-4 rounded-xl border border-slate-100 bg-slate-50/70 p-3">
            <p class="flex items-center gap-1.5 text-xs font-semibold text-slate-500 mb-2"><svg class="h-3.5 w-3.5 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path stroke-linecap="round" d="M12 16v-4M12 8h.01"/></svg>Resumen del pago</p>
            <div class="flex justify-between text-sm py-0.5"><span class="text-slate-400" id="pago-resumen-label">Cuotas que cubre</span><span class="num font-medium text-slate-700" id="pago-cuotas">0</span></div>
            <div class="flex justify-between text-sm py-0.5"><span class="text-slate-400">Monto aplicado</span><span class="num font-medium text-slate-700" id="pago-aplicado">$ 0</span></div>
            <div class="flex justify-between text-sm py-0.5 border-t border-slate-200 mt-1 pt-1.5"><span class="font-medium text-slate-600">Nuevo saldo por pagar</span><span class="num font-bold text-red-500" id="pago-saldo"><%= formatCOP(saldo) %></span></div>
          </div>

          <button type="submit" class="btn-primary w-full mt-4 bg-orange-600 hover:bg-orange-700">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            Registrar pago
          </button>
        </form>
      <% } %>
    </div>
  </div>
</div>

<script>
(function () {
  var input = document.getElementById('pago-monto');
  if (!input) return;
  var tipoSel = document.getElementById('pago-tipo');
  var bloqueInteres = document.getElementById('bloque-interes');
  var bloqueAbono = document.getElementById('bloque-abono');
  var cuotaSel = document.getElementById('interes-cuota');
  var cuotaIdInput = document.getElementById('pago-cuota-id');
  var montoLabel = document.getElementById('pago-monto-label');
  var resumenLabel = document.getElementById('pago-resumen-label');
  // Montos de las cuotas pendientes, en orden de vencimiento.
  var pend = <%- JSON.stringify(cuotasPend.map(function(c){ return Number(c.monto); })) %>;
  var saldo = <%- JSON.stringify(saldo) %>;
  var interesPorCuota = <%- JSON.stringify(interesPorCuota) %>;
  var fmt = window.formatearMoneda || function (v) { return String(Math.round(v || 0)); };
  function cop(v) { return '$ ' + Math.round(v || 0).toLocaleString('es-CO'); }
  function parse(v) { return window.parseMoneda ? window.parseMoneda(v) : (Number(v) || 0); }
  function esInteres() { return tipoSel && tipoSel.value === 'interes'; }

  function actualizar() {
    var monto = parse(input.value);
    if (esInteres()) {
      // Solo interés: el monto es el interés de UNA cuota; el capital se difiere.
      var opt = cuotaSel && cuotaSel.options[cuotaSel.selectedIndex];
      var montoCuota = opt ? Number(opt.dataset.monto) : 0;
      var interes = Math.min(monto, montoCuota);
      document.getElementById('pago-cuotas').textContent = '1';
      document.getElementById('pago-aplicado').textContent = cop(interes);
      // El interés no reduce el capital: el saldo por pagar no baja (se difiere).
      document.getElementById('pago-saldo').textContent = cop(saldo);
    } else {
      var restante = monto, cubiertas = 0, aplicado = 0;
      for (var i = 0; i < pend.length; i++) {
        if (restante + 1e-6 >= pend[i]) { cubiertas++; aplicado += pend[i]; restante -= pend[i]; }
        else break;
      }
      document.getElementById('pago-cuotas').textContent = cubiertas;
      document.getElementById('pago-aplicado').textContent = cop(aplicado);
      document.getElementById('pago-saldo').textContent = cop(saldo - aplicado);
    }
  }

  function pintarModo() {
    var interes = esInteres();
    if (bloqueInteres) bloqueInteres.classList.toggle('hidden', !interes);
    if (bloqueAbono) bloqueAbono.classList.toggle('hidden', interes);
    if (montoLabel) montoLabel.textContent = interes ? 'Monto del interés' : 'Monto a pagar';
    if (resumenLabel) resumenLabel.textContent = interes ? 'Cuota' : 'Cuotas que cubre';
    // Al pasar a "Solo interés" se precarga el interés calculado (para que no se
    // digite el valor completo de la cuota por error). Al volver a abono, se limpia.
    input.value = interes ? fmt(interesPorCuota) : '';
    // cuota_id solo viaja en modo interés (para saber a qué cuota se aplica).
    if (cuotaIdInput) cuotaIdInput.value = (interes && cuotaSel) ? cuotaSel.value : '';
    actualizar();
  }

  if (tipoSel) tipoSel.addEventListener('change', pintarModo);
  if (cuotaSel) cuotaSel.addEventListener('change', function () {
    if (cuotaIdInput) cuotaIdInput.value = cuotaSel.value;
    actualizar();
  });
  input.addEventListener('input', actualizar);
  // Solo los chips de "Pagar rápido" (no las opciones del selector de interés).
  document.querySelectorAll('.chip-cuota-abono[data-monto]').forEach(function (b) {
    b.addEventListener('click', function () { input.value = fmt(Number(b.dataset.monto)); actualizar(); });
  });
  pintarModo();
})();
</script>

<!-- ===================== MODO EDICIÓN ===================== -->
<script>
  (function () {
    var CREDITO_ID = '<%= credito.id %>';

    var btn = document.getElementById('btn-modo-edicion');
    var btnTxt = document.getElementById('btn-modo-edicion-txt');
    var barra = document.getElementById('barra-edicion');
    if (!btn || !barra) return;

    var activo = false;

    function pintar() {
      barra.classList.toggle('hidden', !activo);

      // Columnas "Editar"/"Revertir" de las tablas: celdas normales → `hidden`.
      document.querySelectorAll('.col-edicion').forEach(function (c) {
        c.classList.toggle('hidden', !activo);
      });

      // El botón de eliminar usa `.oculto`: .accion-detalle tiene display:flex
      // fuera de @layer y le ganaría a la utilidad `hidden` de Tailwind.
      document.querySelectorAll('.solo-edicion').forEach(function (c) {
        c.classList.toggle('oculto', !activo);
      });

      if (btnTxt) btnTxt.textContent = activo ? 'Cerrar edición' : 'Editar';
      if (activo) barra.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    btn.addEventListener('click', function () { activo = !activo; pintar(); });

    // --- Editar una cuota ---
    var formCuota = document.getElementById('form-editar-cuota');
    document.querySelectorAll('.btn-editar-cuota').forEach(function (b) {
      b.addEventListener('click', function () {
        var d = b.dataset;
        Swal.fire({
          title: 'Cuota #' + d.numero,
          html:
            '<div style="text-align:left">' +
            '<label style="display:block;font-size:12px;color:#64748b;margin-bottom:4px">Valor de la cuota</label>' +
            '<input id="swal-monto" type="number" min="1" value="' + d.valor + '" class="swal2-input" style="margin:0 0 14px;width:100%">' +
            '<label style="display:block;font-size:12px;color:#64748b;margin-bottom:4px">Fecha de vencimiento</label>' +
            '<input id="swal-fecha" type="date" value="' + d.fecha + '" class="swal2-input" style="margin:0;width:100%">' +
            '</div>',
          showCancelButton: true,
          confirmButtonText: 'Guardar cambios',
          cancelButtonText: 'Cancelar',
          confirmButtonColor: '#16a34a',
          focusConfirm: false,
          preConfirm: function () {
            var monto = document.getElementById('swal-monto').value;
            var fecha = document.getElementById('swal-fecha').value;
            if (!monto || Number(monto) <= 0) { Swal.showValidationMessage('El valor debe ser mayor que cero.'); return false; }
            if (!fecha) { Swal.showValidationMessage('Elige la fecha de vencimiento.'); return false; }
            return { monto: monto, fecha: fecha };
          },
        }).then(function (r) {
          if (!r.isConfirmed) return;
          document.getElementById('ec-monto').value = r.value.monto;
          document.getElementById('ec-fecha').value = r.value.fecha;
          formCuota.action = '/admin/creditos-tomados/' + CREDITO_ID + '/cuotas/' + d.cuota + '/editar';
          formCuota.submit();
        });
      });
    });

    // --- Guardar el plan ---
    var formPlan = document.getElementById('form-plan');
    if (formPlan) {
      formPlan.addEventListener('submit', function (e) {
        e.preventDefault();
        Swal.fire({
          icon: 'question',
          title: '¿Actualizar el plan?',
          html: 'Las cuotas <strong>pendientes</strong> se recalculan con el nuevo total y número de cuotas.<br>Las ya pagadas no se tocan.',
          showCancelButton: true,
          confirmButtonText: 'Sí, actualizar',
          cancelButtonText: 'Cancelar',
          confirmButtonColor: '#16a34a',
        }).then(function (r) { if (r.isConfirmed) formPlan.submit(); });
      });
    }

    // --- Revertir un pago ---
    var formRevertir = document.getElementById('form-eliminar-pago');
    document.querySelectorAll('.btn-revertir-pago').forEach(function (b) {
      b.addEventListener('click', function () {
        var d = b.dataset;
        var montoTxt = '$ ' + Number(d.valor || 0).toLocaleString('es-CO');
        Swal.fire({
          icon: 'warning',
          title: '¿Revertir este pago?',
          html:
            'Se revierte el pago de <strong>' + montoTxt + '</strong>: las cuotas que cubrió ' +
            'vuelven a estar por pagar y el dinero regresa a tu caja.<br><br>' +
            '<strong>Esta acción no se puede deshacer.</strong>',
          showCancelButton: true,
          confirmButtonText: 'Sí, revertir',
          cancelButtonText: 'Cancelar',
          confirmButtonColor: '#dc2626',
        }).then(function (r) {
          if (!r.isConfirmed) return;
          formRevertir.action = '/admin/creditos-tomados/' + CREDITO_ID + '/pagos/' + d.pago + '/eliminar';
          formRevertir.submit();
        });
      });
    });

    // --- Eliminar el crédito: confirmación escribiendo ELIMINAR ---
    var formEliminar = document.getElementById('form-eliminar');
    var btnEliminar = document.getElementById('btn-eliminar-credito');
    if (formEliminar && btnEliminar) {
      btnEliminar.addEventListener('click', function () {
        Swal.fire({
          icon: 'warning',
          title: '¿Eliminar este crédito tomado?',
          html:
            'Se borrarán sus <strong>cuotas y pagos</strong>, y la caja se ajustará ' +
            '(se retira el capital recibido, se revierte lo pagado).<br><br>' +
            '<strong>Esta acción no se puede deshacer.</strong><br>' +
            '<span style="font-size:13px;color:#64748b">Escribe ELIMINAR para confirmar:</span>',
          input: 'text',
          inputPlaceholder: 'ELIMINAR',
          showCancelButton: true,
          confirmButtonText: 'Eliminar definitivamente',
          cancelButtonText: 'Cancelar',
          confirmButtonColor: '#dc2626',
          preConfirm: function (valor) {
            if ((valor || '').trim().toUpperCase() !== 'ELIMINAR') {
              Swal.showValidationMessage('Escribe ELIMINAR para confirmar.');
              return false;
            }
            return true;
          },
        }).then(function (r) { if (r.isConfirmed) formEliminar.submit(); });
      });
    }
  })();
</script>
