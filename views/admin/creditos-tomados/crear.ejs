<%- include('../../partials/header-admin', {
  tituloHeader: 'Nuevo crédito tomado',
  subtituloHeader: 'Registra el dinero que recibiste en préstamo',
  mostrarVolver: true,
  volverUrl: '/admin/creditos-tomados',
}) %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2">
    <!-- Indicador de pasos -->
    <div class="flex items-center mb-6" id="indicador-pasos">
      <div class="flex items-center gap-2" data-indicador="1">
        <span class="step-circle step-circle-activo">1</span>
        <span class="text-sm font-medium text-blue-600">Detalles</span>
      </div>
      <div class="step-line flex-1 mx-3" data-linea="1"></div>
      <div class="flex items-center gap-2" data-indicador="2">
        <span class="step-circle">2</span>
        <span class="text-sm font-medium text-slate-400">Plan de pago</span>
      </div>
      <div class="step-line flex-1 mx-3" data-linea="2"></div>
      <div class="flex items-center gap-2" data-indicador="3">
        <span class="step-circle">3</span>
        <span class="text-sm font-medium text-slate-400">Confirmación</span>
      </div>
    </div>

    <% if (error) { %>
      <div class="mb-4 rounded-xl bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700"><%= error %></div>
    <% } %>

    <form action="/admin/creditos-tomados" method="POST" id="form-credito">

      <!-- Paso 1: Detalles -->
      <div data-paso="1" class="card space-y-6">

        <!-- Acreedor -->
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-orange-100 text-orange-600">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/></svg>
            </span>
            <span class="font-medium text-slate-700">Acreedor</span>
          </div>
          <label class="label-field" for="acreedor">Nombre de quien te prestó el dinero</label>
          <input class="input-field" type="text" id="acreedor" name="acreedor" value="<%= valores.acreedor || '' %>" placeholder="Ej: Juan Pérez, Banco X..." required />
        </div>

        <!-- Monto -->
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125h17.25c.621 0 1.125.504 1.125 1.125v.375m-19.5 0v8.25a1.125 1.125 0 0 0 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-8.25"/></svg>
            </span>
            <span class="font-medium text-slate-700">Monto recibido</span>
          </div>
          <label class="label-field" for="monto_capital">Capital que recibiste</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">$</span>
            <input class="input-field pl-7 input-moneda" type="text" inputmode="numeric" id="monto_capital" name="monto_capital" value="<%= valores.monto_capital || '' %>" required />
          </div>
        </div>

        <!-- Tipo de interés -->
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-violet-100 text-violet-600">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <line x1="19" y1="5" x2="5" y2="19" stroke-linecap="round"/>
                <circle cx="7.5" cy="7.5" r="1.5"/><circle cx="16.5" cy="16.5" r="1.5"/>
              </svg>
            </span>
            <span class="font-medium text-slate-700">Tipo de interés</span>
          </div>
          <select class="input-field" id="tipo_interes" name="tipo_interes" required>
            <option value="fijo_total" <%= (!valores.tipo_interes || valores.tipo_interes==='fijo_total') ? 'selected':'' %>>Interés fijo en pesos sobre el total</option>
            <option value="porcentaje_periodico" <%= valores.tipo_interes==='porcentaje_periodico' ? 'selected':'' %>>Porcentaje por periodo de pago</option>
            <option value="cuota_manual" <%= valores.tipo_interes==='cuota_manual' ? 'selected':'' %>>Yo defino la cuota directamente</option>
          </select>
          <div id="campo-valor-interes" class="mt-3">
            <label class="label-field" for="valor_interes">Interés total en pesos</label>
            <input class="input-field input-moneda" type="text" inputmode="numeric" id="valor_interes" name="valor_interes" value="<%= valores.valor_interes || '' %>" />
          </div>
          <div id="campo-tasa-interes" class="mt-3 hidden">
            <label class="label-field" for="tasa_interes">Tasa de interés por periodo (%)</label>
            <input class="input-field" type="number" step="0.01" min="0" id="tasa_interes" name="tasa_interes" value="<%= valores.tasa_interes || '' %>" />
          </div>
        </div>

        <!-- Fechas y frecuencia -->
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-blue-100 text-blue-600">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"/></svg>
            </span>
            <span class="font-medium text-slate-700">Fechas y frecuencia</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="label-field" for="fecha_inicio">Fecha en que recibiste el dinero</label>
              <input class="input-field" type="date" id="fecha_inicio" name="fecha_inicio" value="<%= valores.fecha_inicio || '' %>" required />
            </div>
            <div>
              <label class="label-field" for="fecha_primer_pago">Fecha de tu primera cuota</label>
              <input class="input-field" type="date" id="fecha_primer_pago" name="fecha_primer_pago" value="<%= valores.fecha_primer_pago || '' %>" required />
            </div>
          </div>
          <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="label-field" for="frecuencia_pago">Frecuencia de pago</label>
              <select class="input-field" id="frecuencia_pago" name="frecuencia_pago" required>
                <option value="diario" <%= valores.frecuencia_pago==='diario' ? 'selected':'' %>>Diario</option>
                <option value="semanal" <%= valores.frecuencia_pago==='semanal' ? 'selected':'' %>>Semanal</option>
                <option value="quincenal" <%= valores.frecuencia_pago==='quincenal' ? 'selected':'' %>>Quincenal</option>
                <option value="mensual" <%= (!valores.frecuencia_pago||valores.frecuencia_pago==='mensual') ? 'selected':'' %>>Mensual</option>
              </select>
            </div>
            <div>
              <label class="label-field" for="numero_cuotas">Número de cuotas</label>
              <input class="input-field" type="number" min="1" id="numero_cuotas" name="numero_cuotas" value="<%= valores.numero_cuotas || '' %>" required />
            </div>
          </div>
        </div>

        <!-- Notas -->
        <div>
          <label class="label-field" for="notas">Notas (opcional)</label>
          <textarea class="input-field" id="notas" name="notas" rows="2" maxlength="300"><%= valores.notas || '' %></textarea>
        </div>

        <div class="flex justify-end pt-2">
          <button type="button" id="btn-paso-2" class="btn-primary">
            Siguiente — Plan de pago
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M13 5l7 7-7 7M5 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>

      <!-- Paso 2: Plan de pago -->
      <div data-paso="2" class="card space-y-6 hidden">
        <p class="text-sm text-slate-500">Valores sugeridos a partir del paso anterior. Puedes ajustarlos si es necesario.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="label-field" for="valor_cuota">Valor de cada cuota</label>
            <input class="input-field input-moneda" type="text" inputmode="numeric" id="valor_cuota" name="valor_cuota" value="<%= valores.valor_cuota || '' %>" required />
          </div>
          <div>
            <label class="label-field" for="monto_total_a_pagar">Total a pagar (capital + interés)</label>
            <input class="input-field input-moneda" type="text" inputmode="numeric" id="monto_total_a_pagar" name="monto_total_a_pagar" value="<%= valores.monto_total_a_pagar || '' %>" required />
          </div>
        </div>
        <div class="flex justify-between pt-2">
          <button type="button" id="btn-volver-1" class="btn-secondary">← Volver</button>
          <button type="button" id="btn-paso-3" class="btn-primary">Siguiente — Confirmar</button>
        </div>
      </div>

      <!-- Paso 3: Confirmación -->
      <div data-paso="3" class="card hidden">
        <h3 class="font-semibold text-slate-700 mb-4">Resumen del crédito tomado</h3>
        <dl class="space-y-3 text-sm">
          <div class="flex justify-between"><dt class="text-slate-400">Acreedor</dt><dd id="res-acreedor" class="font-medium text-slate-800"></dd></div>
          <div class="flex justify-between"><dt class="text-slate-400">Capital recibido</dt><dd id="res-capital" class="font-medium text-slate-800"></dd></div>
          <div class="flex justify-between"><dt class="text-slate-400">Total a pagar</dt><dd id="res-total" class="font-semibold text-orange-700"></dd></div>
          <div class="flex justify-between"><dt class="text-slate-400">Interés total</dt><dd id="res-interes" class="text-slate-600"></dd></div>
          <div class="flex justify-between"><dt class="text-slate-400">Cuotas</dt><dd id="res-cuotas" class="text-slate-600"></dd></div>
          <div class="flex justify-between"><dt class="text-slate-400">Valor cuota</dt><dd id="res-cuota" class="text-slate-600"></dd></div>
          <div class="flex justify-between"><dt class="text-slate-400">Frecuencia</dt><dd id="res-frecuencia" class="text-slate-600"></dd></div>
          <div class="flex justify-between"><dt class="text-slate-400">Primer pago</dt><dd id="res-primer-pago" class="text-slate-600"></dd></div>
        </dl>
        <div class="mt-4 rounded-xl bg-orange-50 border border-orange-200 px-4 py-3 text-sm text-orange-700">
          Al confirmar, <strong id="res-capital-b"></strong> entrarán a tu caja disponible como capital para prestar.
        </div>
        <div class="flex justify-between pt-4">
          <button type="button" id="btn-volver-2" class="btn-secondary">← Volver</button>
          <button type="button" id="btn-confirmar" class="btn-primary bg-orange-600 hover:bg-orange-700">Confirmar y registrar</button>
        </div>
      </div>

    </form>
  </div>

  <!-- Panel lateral de ayuda -->
  <div class="space-y-4">
    <div class="card bg-orange-50 border border-orange-100">
      <h3 class="font-semibold text-orange-800 mb-2">¿Qué pasa al registrar?</h3>
      <ul class="space-y-2 text-sm text-orange-700">
        <li class="flex gap-2"><span class="text-orange-400 mt-0.5">•</span> El capital entra a tu caja disponible</li>
        <li class="flex gap-2"><span class="text-orange-400 mt-0.5">•</span> Se genera el plan de cuotas automáticamente</li>
        <li class="flex gap-2"><span class="text-orange-400 mt-0.5">•</span> Cada cuota que pagues saldrá de tu caja</li>
        <li class="flex gap-2"><span class="text-orange-400 mt-0.5">•</span> Queda todo registrado en auditoría</li>
      </ul>
    </div>
    <div class="card">
      <h3 class="font-semibold text-slate-700 mb-2 text-sm">Tipos de interés</h3>
      <div class="space-y-2 text-xs text-slate-500">
        <p><strong>Fijo en pesos:</strong> Defines el total del interés ya en pesos. Ej: te prestaron $1M y pagas $1.2M → interés $200k.</p>
        <p><strong>Porcentaje periódico:</strong> Defines la tasa por periodo. El sistema calcula el total.</p>
        <p><strong>Cuota manual:</strong> Defines tú mismo cuánto pagas por cuota y cuántas.</p>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  var form = document.getElementById('form-credito');
  if (!form) return;

  var pasos = [1, 2, 3];
  var paso = 1;

  var FREQ = { diario: 'Diario', semanal: 'Semanal', quincenal: 'Quincenal', mensual: 'Mensual' };
  var fmt = function (v) { return new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(v || 0); };
  var leer = function (id) { return window.parseMoneda ? window.parseMoneda(document.getElementById(id)?.value) : Number((document.getElementById(id)?.value || '').replace(/\./g, '').replace(',', '.')) || 0; };
  var escribir = function (id, n) { var el = document.getElementById(id); if (!el) return; el.value = window.formatearMoneda ? window.formatearMoneda(n) : String(Math.round(n || 0)); };

  function mostrarPaso(n) {
    paso = n;
    pasos.forEach(function (p) {
      var el = form.querySelector('[data-paso="' + p + '"]');
      if (el) el.classList.toggle('hidden', p !== n);
    });
    // Indicadores
    document.querySelectorAll('[data-indicador]').forEach(function (el) {
      var p = Number(el.dataset.indicador);
      var circulo = el.querySelector('.step-circle');
      if (!circulo) return;
      circulo.classList.toggle('step-circle-activo', p === n);
      circulo.classList.toggle('step-circle-completo', p < n);
    });
    document.querySelectorAll('[data-linea]').forEach(function (el) {
      el.classList.toggle('step-line-activa', Number(el.dataset.linea) < n);
    });
  }

  // Visibilidad campos interés
  var tipoInt = document.getElementById('tipo_interes');
  function actualizarCamposInteres() {
    var tipo = tipoInt.value;
    document.getElementById('campo-valor-interes').classList.toggle('hidden', tipo !== 'fijo_total');
    document.getElementById('campo-tasa-interes').classList.toggle('hidden', tipo !== 'porcentaje_periodico');
  }
  tipoInt.addEventListener('change', actualizarCamposInteres);
  actualizarCamposInteres();

  // Sugerir cuota
  function sugerirCuota() {
    var capital = leer('monto_capital');
    var cuotas = Number(document.getElementById('numero_cuotas')?.value) || 0;
    if (capital <= 0 || cuotas <= 0) return;
    var tipo = tipoInt.value;
    var total = capital;
    if (tipo === 'fijo_total') {
      var interes = leer('valor_interes');
      total = capital + interes;
    } else if (tipo === 'porcentaje_periodico') {
      var tasa = Number(document.getElementById('tasa_interes')?.value) || 0;
      total = capital * Math.pow(1 + tasa / 100, cuotas);
    }
    escribir('valor_cuota', Math.round(total / cuotas));
    escribir('monto_total_a_pagar', Math.round(total));
  }

  ['monto_capital', 'numero_cuotas'].forEach(function (id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('input', sugerirCuota);
  });
  document.getElementById('valor_interes')?.addEventListener('input', sugerirCuota);
  document.getElementById('tasa_interes')?.addEventListener('input', sugerirCuota);

  // Paso 2
  document.getElementById('btn-paso-2')?.addEventListener('click', function () {
    var paso1 = form.querySelector('[data-paso="1"]');
    var inputs = paso1.querySelectorAll('[required]');
    var valido = true;
    inputs.forEach(function (i) { if (!i.value.trim()) valido = false; });
    if (!valido) { inputs.forEach(function (i) { i.reportValidity(); }); return; }
    sugerirCuota();
    mostrarPaso(2);
  });
  document.getElementById('btn-volver-1')?.addEventListener('click', function () { mostrarPaso(1); });

  // Paso 3 — resumen
  document.getElementById('btn-paso-3')?.addEventListener('click', function () {
    var capital = leer('monto_capital');
    var total = leer('monto_total_a_pagar');
    var cuotas = Number(document.getElementById('numero_cuotas')?.value) || 0;
    document.getElementById('res-acreedor').textContent = document.getElementById('acreedor')?.value || '—';
    document.getElementById('res-capital').textContent = fmt(capital);
    document.getElementById('res-capital-b').textContent = fmt(capital);
    document.getElementById('res-total').textContent = fmt(total);
    document.getElementById('res-interes').textContent = fmt(total - capital);
    document.getElementById('res-cuotas').textContent = cuotas + ' cuotas';
    document.getElementById('res-cuota').textContent = fmt(leer('valor_cuota'));
    document.getElementById('res-frecuencia').textContent = FREQ[document.getElementById('frecuencia_pago')?.value] || '';
    document.getElementById('res-primer-pago').textContent = document.getElementById('fecha_primer_pago')?.value || '—';
    mostrarPaso(3);
  });
  document.getElementById('btn-volver-2')?.addEventListener('click', function () { mostrarPaso(2); });

  // Envío con fetch + SweetAlert
  document.getElementById('btn-confirmar')?.addEventListener('click', async function () {
    var btnConf = this;
    btnConf.disabled = true;
    btnConf.textContent = 'Registrando…';

    try {
      var datos = new FormData(form);
      var resp = await fetch(form.action, {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
        body: new URLSearchParams(datos),
      });
      var json = await resp.json();

      if (json.ok) {
        await Swal.fire({
          icon: 'success',
          title: '¡Crédito registrado!',
          text: 'El capital entró a tu caja disponible.',
          confirmButtonText: 'Ver detalle',
          confirmButtonColor: '#ea580c',
          allowOutsideClick: false,
        });
        window.location.href = json.redirigir;
      } else {
        await Swal.fire({
          icon: 'error',
          title: 'No se pudo crear el crédito',
          text: json.mensaje || 'Ocurrió un error inesperado.',
          confirmButtonText: 'Entendido',
          confirmButtonColor: '#ea580c',
        });
        btnConf.disabled = false;
        btnConf.textContent = 'Confirmar y registrar';
      }
    } catch (e) {
      await Swal.fire({
        icon: 'error',
        title: 'Error de conexión',
        text: 'No se pudo conectar con el servidor. Intenta de nuevo.',
        confirmButtonText: 'Entendido',
        confirmButtonColor: '#ea580c',
      });
      btnConf.disabled = false;
      btnConf.textContent = 'Confirmar y registrar';
    }
  });

  // Al volver con "Atrás", el navegador restaura esta página desde el bfcache con
  // el botón en "Registrando…" y deshabilitado. Lo devolvemos a su estado normal.
  window.addEventListener('pageshow', function (e) {
    if (!e.persisted) return;
    var b = document.getElementById('btn-confirmar');
    if (b) { b.disabled = false; b.textContent = 'Confirmar y registrar'; }
  });
})();
</script>
