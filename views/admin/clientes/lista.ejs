   onmouseout="this.style.background='#2563eb';this.style.transform='scale(1)';this.style.boxShadow='0 8px 24px rgba(37,99,235,0.45)'"
   title="Nuevo cliente">
  <svg style="width:22px;height:22px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M12 5v14M5 12h14"/></svg>
