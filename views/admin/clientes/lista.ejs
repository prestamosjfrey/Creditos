   style="position:fixed;bottom:2rem;right:2rem;z-index:50;display:inline-flex;align-items:center;justify-content:center;background:#2563eb;color:#fff;width:3.5rem;height:3.5rem;border-radius:9999px;box-shadow:0 8px 24px rgba(37,99,235,0.45);text-decoration:none;transition:background 0.15s,transform 0.15s,box-shadow 0.15s;"
