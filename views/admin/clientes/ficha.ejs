<%
  function formatoTamano(bytes) {
    if (!bytes) return '';
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1048576) return (bytes / 1024).toFixed(0) + ' KB';
    return (bytes / 1048576).toFixed(1) + ' MB';
  }
  var tabInicial = (typeof tab !== 'undefined' && tab) ? tab : 'historial';
%>

<div class="mb-4 flex items-center justify-between gap-4">
  <a href="/admin/clientes" class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-500 hover:text-slate-700">
    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    Volver a clientes
  </a>
  <a href="/admin/prestamos/nuevo?cliente_id=<%= cliente.id %>" class="btn-primary">
    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 5v14M5 12h14" /></svg>
    Nuevo préstamo
  </a>
</div>

<div class="mb-6 flex items-start justify-between gap-4">
  <div>
    <h1 class="text-2xl font-semibold text-slate-800"><%= cliente.nombre_completo %></h1>
    <div class="mt-2 flex flex-wrap items-center gap-x-5 gap-y-1 text-sm text-slate-500">
      <span class="inline-flex items-center gap-1.5">
        <svg class="h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><path d="M2 10h20"/></svg>
        Cédula <%= cliente.numero_documento || '—' %>
      </span>
      <span class="inline-flex items-center gap-1.5">
        <svg class="h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <%= cliente.telefono || '—' %>
      </span>
      <span class="inline-flex items-center gap-1.5">
        <svg class="h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        <%= cliente.email || '—' %>
      </span>
      <% if (!cliente.activo) { %>
        <span class="badge-neutro">● Inactivo</span>
      <% } %>
    </div>
  </div>

  <div class="flex items-center gap-2 shrink-0">
    <a href="/admin/clientes/<%= cliente.id %>/editar" class="btn-secondary">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
      Editar cliente
    </a>
    <div class="relative">
      <button type="button" id="btn-menu-ficha" class="icon-btn" aria-label="Más opciones">
        <svg class="h-[18px] w-[18px] text-slate-500" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="12" cy="19" r="1.6"/></svg>
      </button>
      <div id="menu-ficha" class="hidden absolute right-0 top-full mt-2 w-52 rounded-xl border border-slate-100 bg-white py-1 shadow-lg z-50">
        <a href="/admin/clientes/<%= cliente.id %>/editar" class="flex items-center gap-2 px-4 py-2 text-sm text-slate-600 hover:bg-slate-50">
          <svg class="h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
          Editar información
        </a>
        <form action="/admin/clientes/<%= cliente.id %>/estado" method="POST">
          <button type="submit" class="flex w-full items-center gap-2 px-4 py-2 text-sm text-slate-600 hover:bg-slate-50">
            <% if (cliente.activo) { %>
              <svg class="h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18.36 6.64A9 9 0 1 1 5.64 6.64"/><line x1="12" x2="12" y1="2" y2="12"/></svg>
              Desactivar cliente
            <% } else { %>
              <svg class="h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
              Activar cliente
            <% } %>
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
  <div class="card flex items-center gap-3">
    <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-blue-100 text-blue-600">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a2.25 2.25 0 0 0-2.25-2.25H15a3 3 0 1 1-6 0H5.25A2.25 2.25 0 0 0 3 12m18 0v6a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 18v-6m18 0V9a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 9v3"/></svg>
    </span>
    <div>
      <p class="text-sm text-slate-400">Préstamos totales</p>
      <p class="num text-xl font-semibold text-slate-800"><%= prestamos.length %></p>
      <p class="text-xs text-slate-400">Histórico</p>
    </div>
  </div>

  <div class="card flex items-center gap-3">
    <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="m9 16 2 2 4-4"/></svg>
    </span>
    <div>
      <p class="text-sm text-slate-400">Préstamos activos</p>
      <p class="num text-xl font-semibold text-slate-800"><%= prestamos.filter(function(p){ return p.estado === 'activo' || p.estado === 'en_mora'; }).length %></p>
      <p class="text-xs text-slate-400">En curso</p>
    </div>
  </div>

  <%
    var coloresScore = {
      emerald: ['bg-emerald-100', 'text-emerald-600', 'bg-emerald-500'],
      blue:    ['bg-blue-100',    'text-blue-600',    'bg-blue-500'],
      teal:    ['bg-teal-100',    'text-teal-600',    'bg-teal-500'],
      amber:   ['bg-amber-100',   'text-amber-600',   'bg-amber-400'],
      orange:  ['bg-orange-100',  'text-orange-600',  'bg-orange-400'],
      red:     ['bg-red-100',     'text-red-600',     'bg-red-500'],
    };
    var sc = (infoScore && coloresScore[infoScore.color]) ? coloresScore[infoScore.color] : coloresScore.blue;
    var pct = scoreCredito !== null ? Math.round((scoreCredito / 1000) * 100) : 0;
    var fechaScore = scoreActualizadoEn ? new Date(scoreActualizadoEn).toLocaleDateString('es-CO', { day:'2-digit', month:'short', year:'numeric' }) : null;
  %>
  <button type="button" id="btn-ver-score"
    class="card flex items-center gap-3 text-left w-full hover:shadow-md transition cursor-pointer">
    <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full <%= sc[0] %> <%= sc[1] %>">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1Z"/></svg>
    </span>
    <div class="flex-1 min-w-0">
      <p class="text-sm text-slate-400">Score crediticio</p>
      <% if (scoreCredito !== null) { %>
        <div class="flex items-baseline gap-2">
          <p class="num text-2xl font-bold <%= sc[1] %>"><%= scoreCredito %></p>
          <span class="text-xs font-medium text-slate-400">/ 1000</span>
          <span class="text-xs font-semibold <%= sc[1] %>"><%= infoScore.etiqueta %></span>
        </div>
        <div class="mt-1.5 h-1.5 w-full rounded-full bg-slate-100 overflow-hidden">
          <div class="h-full rounded-full <%= sc[2] %> transition-all" style="width:<%= pct %>%"></div>
        </div>
        <% if (fechaScore) { %><p class="text-xs text-slate-300 mt-1">Actualizado: <%= fechaScore %></p><% } %>
      <% } else { %>
        <p class="text-sm font-medium text-slate-400">Sin historial</p>
        <p class="text-xs text-slate-300">Se calculará tras el primer pago</p>
      <% } %>
    </div>
    <% if (scoreCredito !== null) { %>
      <svg class="h-4 w-4 text-slate-300 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg>
    <% } %>
  </button>

  <% if (scoreCredito !== null && scoreDetalle) { %>
  <!-- Modal desglose del score -->
  <div id="modal-score" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/50 p-4 lg:pl-64">
    <div class="card w-full max-w-lg max-h-[90vh] overflow-y-auto relative">
      <button type="button" id="btn-cerrar-score" class="absolute right-4 top-4 text-slate-400 hover:text-slate-600 transition">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6 6 18"/></svg>
      </button>

      <div class="mb-5 text-center">
        <span class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full <%= sc[0] %> <%= sc[1] %>">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1Z"/></svg>
        </span>
        <p class="text-sm text-slate-400">Score crediticio</p>
        <p class="num text-4xl font-bold <%= sc[1] %> mt-1"><%= scoreCredito %> <span class="text-xl text-slate-300">/ 1000</span></p>
        <span class="inline-flex mt-2 rounded-full px-3 py-1 text-sm font-semibold <%= sc[0] %> <%= sc[1] %>"><%= infoScore.etiqueta %></span>
        <div class="mt-3 h-2 w-full rounded-full bg-slate-100 overflow-hidden">
          <div class="h-full rounded-full <%= sc[2] %>" style="width:<%= pct %>%"></div>
        </div>
      </div>

      <!-- Factor A: Puntualidad -->
      <div class="mb-4 rounded-xl border border-slate-100 p-4">
        <div class="flex items-center justify-between mb-3">
          <div class="flex items-center gap-2">
            <span class="flex h-7 w-7 items-center justify-center rounded-full bg-blue-100 text-blue-600 text-xs font-bold">A</span>
            <p class="text-sm font-semibold text-slate-700">Puntualidad en pagos</p>
          </div>
          <span class="num text-sm font-semibold text-slate-700"><%= scoreDetalle.factores.A.puntaje %> / <%= scoreDetalle.factores.A.maximo %> pts</span>
        </div>
        <% if (scoreDetalle.factores.A.grupos.length === 0) { %>
          <p class="text-xs text-slate-400">Sin cuotas pagadas aún.</p>
        <% } else { %>
          <% scoreDetalle.factores.A.grupos.forEach(function(g) { %>
            <div class="mb-2">
              <p class="text-xs font-medium text-slate-500 mb-1"><%= g.ref %> — <span class="num"><%= g.ptsTotales %></span>/<span class="num"><%= g.maxTotales %></span> pts</p>
              <div class="space-y-1">
                <% g.cuotas.forEach(function(c) { %>
                  <div class="flex items-center justify-between text-xs">
                    <span class="text-slate-500">Cuota #<%= c.numero_cuota %></span>
                    <span class="<%= c.dias_atraso === 0 ? 'text-emerald-600' : c.dias_atraso <= 3 ? 'text-amber-600' : 'text-red-500' %>">
                      <%= c.dias_atraso === 0 ? 'A tiempo ✓' : c.dias_atraso + ' día(s) tarde' %>
                    </span>
                    <span class="num font-medium text-slate-600"><%= c.puntos %> pts</span>
                  </div>
                <% }); %>
              </div>
            </div>
          <% }); %>
        <% } %>
      </div>

      <!-- Factor B: Mora -->
      <div class="mb-4 rounded-xl border border-slate-100 p-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="flex h-7 w-7 items-center justify-center rounded-full bg-red-100 text-red-600 text-xs font-bold">B</span>
            <p class="text-sm font-semibold text-slate-700">Cuotas en mora activa</p>
          </div>
          <span class="num text-sm font-semibold text-red-500">−<%= scoreDetalle.factores.B.penalizacion %> pts</span>
        </div>
        <p class="text-xs text-slate-400 mt-2">
          <% if (scoreDetalle.factores.B.mora === 0) { %>
            Sin cuotas en mora. ✓
          <% } else { %>
            <%= scoreDetalle.factores.B.mora %> cuota(s) vencida(s) × −60 pts (máx −<%= scoreDetalle.factores.B.maxPen %> pts)
          <% } %>
        </p>
      </div>

      <!-- Factor C: Bonos -->
      <div class="rounded-xl border border-slate-100 p-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="flex h-7 w-7 items-center justify-center rounded-full bg-emerald-100 text-emerald-600 text-xs font-bold">C</span>
            <p class="text-sm font-semibold text-slate-700">Bonos por préstamos limpios</p>
          </div>
          <span class="num text-sm font-semibold text-emerald-600">+<%= scoreDetalle.factores.C.bonos %> pts</span>
        </div>
        <p class="text-xs text-slate-400 mt-2">
          <% if (scoreDetalle.factores.C.prestamos === 0) { %>
            Ningún préstamo pagado sin atrasos aún.
          <% } else { %>
            <%= scoreDetalle.factores.C.prestamos %> préstamo(s) pagado(s) sin ningún retraso × +50 pts c/u
          <% } %>
        </p>
      </div>

      <p class="mt-4 text-center text-xs text-slate-300">
        Score = (puntualidad + bonos − mora) normalizado a 0–1000
      </p>
    </div>
  </div>
  <script>
    (function () {
      var modal = document.getElementById('modal-score');
      var btn = document.getElementById('btn-ver-score');
      var cerrar = document.getElementById('btn-cerrar-score');
      if (!modal || !btn) return;
      btn.addEventListener('click', function () {
        modal.classList.remove('hidden'); modal.classList.add('flex');
      });
      cerrar.addEventListener('click', function () {
        modal.classList.add('hidden'); modal.classList.remove('flex');
      });
      modal.addEventListener('click', function (e) {
        if (e.target === modal) { modal.classList.add('hidden'); modal.classList.remove('flex'); }
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') { modal.classList.add('hidden'); modal.classList.remove('flex'); }
      });
    })();
  </script>
  <% } %>
</div>

<div class="border-b border-slate-200 mb-5">
  <nav class="flex gap-6">
    <button type="button" class="tab-btn" data-tab="historial">Historial de préstamos</button>
    <button type="button" class="tab-btn" data-tab="info">Información personal</button>
    <button type="button" class="tab-btn" data-tab="notas">Notas</button>
    <button type="button" class="tab-btn" data-tab="documentos">Documentos</button>
  </nav>
</div>

<!-- Tab: Historial de préstamos -->
<div data-panel="historial">
  <% if (prestamos.length === 0) { %>
    <div class="card flex flex-col items-center justify-center py-12 text-center">
      <span class="flex h-14 w-14 items-center justify-center rounded-full bg-slate-100 text-slate-400 mb-4">
        <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/></svg>
      </span>
      <p class="font-medium text-slate-700">Este cliente no tiene préstamos todavía</p>
      <p class="text-sm text-slate-400 mb-4">Crea su primer préstamo para comenzar.</p>
      <a href="/admin/prestamos/nuevo?cliente_id=<%= cliente.id %>" class="btn-primary">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 5v14M5 12h14" /></svg>
        Nuevo préstamo
      </a>
    </div>
  <% } else { %>
    <div class="card p-0">
      <table class="table-base" data-datatable data-no-search>
        <thead>
          <tr>
            <th>Fecha</th>
            <th>Capital</th>
            <th>Total a pagar</th>
            <th>Cuotas</th>
            <th>Estado</th>
            <th data-sortable="false" class="text-right">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% prestamos.forEach(function(p) { %>
            <tr>
              <td><%= p.fecha_inicio %></td>
              <td class="num"><%= formatCOP(p.monto_capital) %></td>
              <td class="num"><%= formatCOP(p.monto_total_a_pagar) %></td>
              <td class="num"><%= p.numero_cuotas %></td>
              <td>
                <% if (p.estado === 'pagado') { %><span class="badge-exito">Pagado</span>
                <% } else if (p.estado === 'en_mora') { %><span class="badge-peligro">En mora</span>
                <% } else if (p.estado === 'cancelado') { %><span class="badge-neutro">Cancelado</span>
                <% } else { %><span class="badge-exito">Activo</span><% } %>
              </td>
              <td>
                <div class="flex items-center justify-end">
                  <a href="/admin/prestamos/<%= p.id %>" class="action-btn" title="Ver préstamo" aria-label="Ver préstamo">
                    <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                  </a>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<!-- Tab: Información personal -->
<div data-panel="info" class="hidden">
  <div class="card divide-y divide-slate-100 max-w-2xl mx-auto">
    <div class="py-3 flex justify-between"><span class="text-sm text-slate-400">Nombre completo</span><span class="text-sm font-medium text-slate-800"><%= cliente.nombre_completo %></span></div>
    <div class="py-3 flex justify-between"><span class="text-sm text-slate-400">Cédula</span><span class="text-sm font-medium text-slate-800"><%= cliente.numero_documento || '—' %></span></div>
    <div class="py-3 flex justify-between"><span class="text-sm text-slate-400">Teléfono</span><span class="text-sm font-medium text-slate-800"><%= cliente.telefono || '—' %></span></div>
    <div class="py-3 flex justify-between"><span class="text-sm text-slate-400">Correo electrónico</span><span class="text-sm font-medium text-slate-800"><%= cliente.email || '—' %></span></div>
    <div class="py-3 flex justify-between"><span class="text-sm text-slate-400">Dirección</span><span class="text-sm font-medium text-slate-800"><%= cliente.direccion || '—' %></span></div>
    <div class="py-3 flex justify-between"><span class="text-sm text-slate-400">Estado</span><span class="text-sm font-medium <%= cliente.activo ? 'text-emerald-600' : 'text-slate-500' %>"><%= cliente.activo ? 'Activo' : 'Inactivo' %></span></div>
    <div class="py-3 flex justify-between"><span class="text-sm text-slate-400">Registrado</span><span class="text-sm font-medium text-slate-800"><%= new Date(cliente.creado_en).toLocaleDateString('es-CO', { day: '2-digit', month: 'long', year: 'numeric' }) %></span></div>
  </div>
</div>

<!-- Tab: Notas -->
<div data-panel="notas" class="hidden">
  <div class="card max-w-2xl">
    <form action="/admin/clientes/<%= cliente.id %>/notas" method="POST">
      <label class="label-field" for="notas_admin">Notas internas sobre el cliente</label>
      <textarea class="input-field" id="notas_admin" name="notas_admin" rows="6" placeholder="Anotaciones privadas: acuerdos, referencias, recordatorios..."><%= cliente.notas_admin || '' %></textarea>
      <p class="mt-1 text-xs text-slate-400">Solo tú ves estas notas; el cliente no tiene acceso.</p>
      <div class="mt-4 flex justify-end">
        <button type="submit" class="btn-primary">Guardar notas</button>
      </div>
    </form>
  </div>
</div>

<!-- Tab: Documentos -->
<div data-panel="documentos" class="hidden">
  <div class="card max-w-2xl">
    <form action="/admin/clientes/<%= cliente.id %>/documentos" method="POST" enctype="multipart/form-data" class="flex flex-col sm:flex-row sm:items-end gap-3 pb-4 border-b border-slate-100">
      <div class="flex-1">
        <label class="label-field" for="documento">Subir documento <span class="text-slate-400">(máx. 10MB)</span></label>
        <input class="input-field" type="file" id="documento" name="documento" required />
      </div>
      <button type="submit" class="btn-primary">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
        Subir
      </button>
    </form>

    <% if (documentos.length === 0) { %>
      <p class="text-center text-sm text-slate-400 py-8">No hay documentos para este cliente.</p>
    <% } else { %>
      <ul class="divide-y divide-slate-100">
        <% documentos.forEach(function(doc) { %>
          <li class="py-3 flex items-center justify-between gap-3">
            <div class="flex items-center gap-3 min-w-0">
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-slate-100 text-slate-400">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/></svg>
              </span>
              <div class="min-w-0">
                <p class="text-sm font-medium text-slate-800 truncate"><%= doc.nombre %></p>
                <p class="text-xs text-slate-400"><%= formatoTamano(doc.tamano_bytes) %> · <%= new Date(doc.creado_en).toLocaleDateString('es-CO') %></p>
              </div>
            </div>
            <div class="flex items-center gap-1 shrink-0">
              <a href="/admin/clientes/<%= cliente.id %>/documentos/<%= doc.id %>/ver" target="_blank" rel="noopener" class="action-btn" title="Ver / descargar" aria-label="Ver">
                <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
              </a>
              <form action="/admin/clientes/<%= cliente.id %>/documentos/<%= doc.id %>/eliminar" method="POST" class="form-eliminar-doc">
                <button type="submit" class="action-btn hover:text-red-500" title="Eliminar" aria-label="Eliminar">
                  <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                </button>
              </form>
            </div>
          </li>
        <% }); %>
      </ul>
    <% } %>
  </div>
</div>

<script>
  // Pestañas de la ficha
  (function () {
    var tabInicial = <%- JSON.stringify(tabInicial) %>;
    var botones = document.querySelectorAll('.tab-btn');
    var paneles = document.querySelectorAll('[data-panel]');

    function activar(nombre) {
      botones.forEach(function (b) { b.classList.toggle('tab-btn-activo', b.dataset.tab === nombre); });
      paneles.forEach(function (p) { p.classList.toggle('hidden', p.dataset.panel !== nombre); });
    }
    botones.forEach(function (b) {
      b.addEventListener('click', function () { activar(b.dataset.tab); });
    });
    activar(tabInicial);
  })();

  // Menú (⋮) de la ficha
  (function () {
    var btn = document.getElementById('btn-menu-ficha');
    var menu = document.getElementById('menu-ficha');
    if (!btn || !menu) return;
    btn.addEventListener('click', function (e) { e.stopPropagation(); menu.classList.toggle('hidden'); });
    document.addEventListener('click', function () { menu.classList.add('hidden'); });
  })();

  // Confirmar eliminación de documento
  document.querySelectorAll('.form-eliminar-doc').forEach(function (f) {
    f.addEventListener('submit', function (e) {
      if (window.Swal) {
        e.preventDefault();
        Swal.fire({
          icon: 'warning', title: '¿Eliminar documento?', text: 'Esta acción no se puede deshacer.',
          showCancelButton: true, confirmButtonText: 'Sí, eliminar', cancelButtonText: 'Cancelar',
          confirmButtonColor: '#dc2626',
        }).then(function (r) { if (r.isConfirmed) { if (window.mostrarCargando) window.mostrarCargando('Eliminando…'); f.submit(); } });
      }
    });
  });
</script>
