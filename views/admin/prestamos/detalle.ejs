<%
  // Arma el número para WhatsApp: solo dígitos; si son 10 (celular CO) le
  // antepone el 57; si ya empieza por 57 lo deja igual.
  var telDigitos = (prestamo.perfiles?.telefono || '').replace(/\D/g, '');
  var telWa = telDigitos.length === 10 ? '57' + telDigitos : telDigitos;
  var tieneTel = telDigitos.length >= 10;
  var mensajeWa = 'Hola ' + (prestamo.perfiles?.nombre_completo || '') + ', te comparto el comprobante de tu préstamo:\n\n' +
    '• Capital prestado: ' + formatCOP(prestamo.monto_capital) + '\n' +
    '• Total a pagar: ' + formatCOP(prestamo.monto_total_a_pagar) + '\n' +
    '• N° de cuotas: ' + prestamo.numero_cuotas + ' (' + prestamo.frecuencia_pago + ')\n' +
    '• Valor de cada cuota: ' + formatCOP(prestamo.valor_cuota) + '\n' +
    '• Primer pago: ' + prestamo.fecha_primer_pago + '\n\n' +
    'Adjunto el comprobante en PDF. ¡Gracias!';
  var waUrl = 'https://wa.me/' + telWa + '?text=' + encodeURIComponent(mensajeWa);
%>
<div class="mb-6 flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
  <div>
    <h1 class="text-xl font-semibold text-slate-800"><%= prestamo.perfiles?.nombre_completo %></h1>
    <p class="text-sm text-slate-400">
      Préstamo del <%= prestamo.fecha_inicio %> ·
      <% if (prestamo.estado === 'pagado') { %><span class="badge-exito">Pagado</span>
      <% } else if (prestamo.estado === 'en_mora') { %><span class="badge-peligro">En mora</span>
      <% } else if (prestamo.estado === 'cancelado') { %><span class="badge-neutro">Cancelado</span>
      <% } else { %><span class="badge-neutro">Activo</span><% } %>
    </p>
  </div>
  <div class="flex flex-wrap items-center gap-2">
    <a href="/admin/clientes/<%= prestamo.cliente_id %>" class="btn-secondary">Ver cliente</a>
    <a href="/admin/prestamos/<%= prestamo.id %>/comprobante" target="_blank" rel="noopener" class="btn-secondary">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 16.5V3m0 13.5-4-4m4 4 4-4M4.5 16.5V18a2.25 2.25 0 0 0 2.25 2.25h10.5A2.25 2.25 0 0 0 19.5 18v-1.5"/></svg>
      Comprobante PDF
    </a>
    <% if (tieneTel) { %>
      <button type="button" id="btn-compartir-plan" class="inline-flex items-center justify-center gap-2 rounded-xl bg-green-500 px-4 py-2.5 font-medium text-white transition hover:bg-green-600">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413"/></svg>
        Enviar plan por WhatsApp
      </button>
    <% } else { %>
      <span class="inline-flex items-center gap-1.5 text-xs text-slate-400">Cliente sin teléfono para WhatsApp</span>
    <% } %>
  </div>
</div>

<div class="grid grid-cols-2 sm:grid-cols-5 gap-4 mb-8">
  <%- include('../../partials/kpi-card', { titulo: 'Capital', valor: formatCOP(prestamo.monto_capital) }) %>
  <%- include('../../partials/kpi-card', { titulo: 'Interés', valor: formatCOP(prestamo.monto_total_a_pagar - prestamo.monto_capital), nota: 'Cobrado en total' }) %>
  <%- include('../../partials/kpi-card', { titulo: 'Total a pagar', valor: formatCOP(prestamo.monto_total_a_pagar) }) %>
  <%- include('../../partials/kpi-card', { titulo: 'Cuota', valor: formatCOP(prestamo.valor_cuota), nota: prestamo.frecuencia_pago }) %>
  <%- include('../../partials/kpi-card', {
    titulo: 'Saldo pendiente',
    valor: formatCOP(prestamo.monto_total_a_pagar - pagos.reduce(function(acc, p) { return acc + Number(p.monto); }, 0))
  }) %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2">
    <h2 class="font-medium text-slate-700 mb-3">Plan de cuotas</h2>
    <%
      // Mapa cuota → decisión del pago de solo interés (extension | saldo),
      // para distinguir esas cuotas en el plan.
      var mapaInteres = {};
      pagos.forEach(function(p) { if (p.tipo === 'interes' && p.cuota_id) mapaInteres[p.cuota_id] = p.accion; });
    %>
    <div class="card overflow-hidden p-0">
      <%- include('../../partials/tabla-cuotas', { cuotas, formatCOP, mapaInteres }) %>
    </div>

    <h2 class="font-medium text-slate-700 mb-3 mt-8">Historial de abonos</h2>
    <div class="card overflow-hidden p-0">
      <table class="table-base" data-datatable>
        <thead>
          <tr><th>Fecha</th><th>Monto</th><th>Método</th><th>Notas</th></tr>
        </thead>
        <tbody>
          <% if (pagos.length === 0) { %>
            <tr><td colspan="4" class="px-3 py-6 text-center text-slate-500">Aún no se han registrado abonos.</td></tr>
          <% } %>
          <% pagos.forEach(function(p) { %>
            <tr>
              <td><%= p.fecha_pago %></td>
              <td class="num"><%= formatCOP(p.monto) %></td>
              <td><%= p.metodo || '—' %></td>
              <td class="text-slate-400"><%= p.notas || '—' %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <%
    var interesTotalP = Number(prestamo.monto_total_a_pagar) - Number(prestamo.monto_capital);
    var interesPorCuota = prestamo.numero_cuotas ? Math.round(interesTotalP / prestamo.numero_cuotas) : 0;
  %>
  <div>
    <h2 class="font-medium text-slate-700 mb-3">Registrar abono</h2>
    <form action="/admin/prestamos/<%= prestamo.id %>/pagos" method="POST" class="card space-y-4" data-loading-title="Registrando pago…">
      <div>
        <label class="label-field" for="tipo_pago">Tipo de pago</label>
        <select class="input-field" id="tipo_pago" name="tipo">
          <option value="abono">Abono normal</option>
          <option value="interes">Solo interés</option>
        </select>
      </div>
      <div>
        <label class="label-field" for="cuota_id">Aplicar a cuota</label>
        <select class="input-field" id="cuota_id" name="cuota_id">
          <option value="">Automático (más antigua pendiente)</option>
          <% cuotas.filter(function(c) { return c.estado !== 'pagada'; }).forEach(function(c) { %>
            <option value="<%= c.id %>">Cuota #<%= c.numero_cuota %> · <%= formatCOP(c.monto_esperado - c.monto_pagado) %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="label-field" for="monto" id="label-monto">Monto abonado</label>
        <input class="input-field input-moneda" type="text" inputmode="numeric" id="monto" name="monto" required />
      </div>
      <div id="bloque-interes" class="hidden rounded-xl border border-amber-200 bg-amber-50 p-3 space-y-2">
        <p class="text-sm font-medium text-amber-800">¿Qué se hace con el capital de esta cuota?</p>
        <label class="flex items-start gap-2 text-sm text-slate-600">
          <input type="radio" name="accion" value="saldo" class="mt-1" checked />
          <span><span class="font-medium text-slate-700">Dejar saldo pendiente</span> — el capital no pagado se cobra después (renegociación). El plan no cambia.</span>
        </label>
        <label class="flex items-start gap-2 text-sm text-slate-600">
          <input type="radio" name="accion" value="extension" class="mt-1" />
          <span><span class="font-medium text-slate-700">Extender un periodo</span> — se agrega una cuota más con interés de <%= formatCOP(interesPorCuota) %>; el capital se difiere al final.</span>
        </label>
      </div>
      <div>
        <label class="label-field" for="fecha_pago">Fecha de pago</label>
        <input class="input-field" type="date" id="fecha_pago" name="fecha_pago" required />
      </div>
      <div>
        <label class="label-field" for="metodo">Método</label>
        <select class="input-field" id="metodo" name="metodo">
          <option value="efectivo">Efectivo</option>
          <option value="transferencia">Transferencia</option>
          <option value="nequi">Nequi</option>
          <option value="daviplata">Daviplata</option>
          <option value="otro">Otro</option>
        </select>
      </div>
      <div>
        <label class="label-field" for="notas">Notas</label>
        <input class="input-field" type="text" id="notas" name="notas" />
      </div>
      <button type="submit" id="btn-registrar-pago" class="btn-primary w-full">Registrar abono</button>
    </form>
  </div>
</div>

<script>
  (function () {
    var tipoSel = document.getElementById('tipo_pago');
    var bloque = document.getElementById('bloque-interes');
    var montoInput = document.getElementById('monto');
    var labelMonto = document.getElementById('label-monto');
    var btn = document.getElementById('btn-registrar-pago');
    var interesCuota = <%= interesPorCuota %>;
    if (!tipoSel) return;
    tipoSel.addEventListener('change', function () {
      var esInteres = tipoSel.value === 'interes';
      bloque.classList.toggle('hidden', !esInteres);
      if (esInteres) {
        if ((!montoInput.value || montoInput.value.trim() === '') && interesCuota > 0) {
          montoInput.value = window.formatearMoneda ? window.formatearMoneda(interesCuota) : String(interesCuota);
        }
        if (labelMonto) labelMonto.textContent = 'Interés a pagar';
        if (btn) btn.textContent = 'Registrar pago de interés';
      } else {
        if (labelMonto) labelMonto.textContent = 'Monto abonado';
        if (btn) btn.textContent = 'Registrar abono';
      }
    });
  })();
</script>

<script>
  // Compartir el PLAN DE PAGO (PDF) por WhatsApp de verdad: usa la API de
  // compartir del dispositivo (navigator.share con archivos), que en celular
  // abre el menú de compartir → eliges WhatsApp → el PDF queda ADJUNTO.
  // En equipos que no soportan adjuntar (escritorio), cae a un respaldo:
  // descarga el PDF y abre el chat del cliente con el texto.
  (function () {
    var comprobanteUrl = <%- JSON.stringify('/admin/prestamos/' + prestamo.id + '/comprobante') %>;
    var nombreArchivo = <%- JSON.stringify('comprobante-' + (prestamo.perfiles && prestamo.perfiles.nombre_completo ? prestamo.perfiles.nombre_completo.replace(/[^\w]+/g, '_') : 'cliente') + '.pdf') %>;
    var texto = <%- JSON.stringify(mensajeWa) %>;
    var waUrl = <%- JSON.stringify(waUrl) %>;

    // Compartidor genérico de PDF por WhatsApp (navigator.share con archivo;
    // respaldo a descargar + abrir chat en equipos sin soporte de adjuntar).
    window.__compartirPDF = async function (url, nombre, mensaje, chatUrl) {
      try {
        var resp = await fetch(url, { credentials: 'same-origin' });
        var blob = await resp.blob();
        var archivo = new File([blob], nombre, { type: 'application/pdf' });
        if (navigator.canShare && navigator.canShare({ files: [archivo] })) {
          await navigator.share({ files: [archivo], text: mensaje });
          return;
        }
      } catch (e) {
        if (e && e.name === 'AbortError') return;
      }
      window.open(url, '_blank');
      if (chatUrl) window.open(chatUrl, '_blank');
      if (window.Swal) {
        Swal.fire({ icon: 'info', title: 'Comparte el PDF manualmente', text: 'Este dispositivo no permite adjuntar el PDF directo a WhatsApp. Descargué el documento y abrí el chat del cliente: adjunta el PDF ahí.', confirmButtonText: 'Entendido' });
      }
    };

    window.__compartirPlan = function () { return window.__compartirPDF(comprobanteUrl, nombreArchivo, texto, waUrl); };

    var btn = document.getElementById('btn-compartir-plan');
    if (btn) btn.addEventListener('click', window.__compartirPlan);
  })();
</script>

