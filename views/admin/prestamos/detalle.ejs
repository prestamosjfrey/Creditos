<%
  // --- WhatsApp (preservado para los modales de compartir) ---
  var telDigitos = (prestamo.perfiles?.telefono || '').replace(/\D/g, '');
  var telWa = telDigitos.length === 10 ? '57' + telDigitos : telDigitos;
  var tieneTel = telDigitos.length >= 10;
  var mensajeWa = 'Hola ' + (prestamo.perfiles?.nombre_completo || '') + ', te comparto el comprobante de tu préstamo:\n\n' +
    '• Capital prestado: ' + formatCOP(prestamo.monto_capital) + '\n' +
    '• Total a pagar: ' + formatCOP(prestamo.monto_total_a_pagar) + '\n' +
    '• N° de cuotas: ' + prestamo.numero_cuotas + ' (' + prestamo.frecuencia_pago + ')\n' +
    '• Valor de cada cuota: ' + formatCOP(prestamo.valor_cuota) + '\n' +
    '• Primer pago: ' + prestamo.fecha_primer_pago + '\n\n' +
    'Adjunto el comprobante en PDF. ¡Gracias!';
  var waUrl = 'https://wa.me/' + telWa + '?text=' + encodeURIComponent(mensajeWa);

  // --- Derivados del préstamo ---
  var cli = prestamo.perfiles || {};
  var capital = Number(prestamo.monto_capital);
  var total = Number(prestamo.monto_total_a_pagar);
  var interes = Math.max(0, total - capital);
  var nCuotas = Number(prestamo.numero_cuotas);
  var valorCuota = Number(prestamo.valor_cuota);
  var abonado = pagos.reduce(function (a, p) { return a + Number(p.monto); }, 0);
  var saldo = total - abonado;
  var cuotasPagadas = cuotas.filter(function (c) { return c.estado === 'pagada'; }).length;
  var cuotasRestantes = Math.max(0, nCuotas - cuotasPagadas);
  var progresoPct = nCuotas ? Math.round(cuotasPagadas / nCuotas * 100) : 0;
  var pctCapital = total ? Math.round(capital / total * 100) : 0;
  var pctInteres = total ? Math.round(interes / total * 100) : 0;
  var pctPagado = total ? Math.round(abonado / total * 100) : 0;
  var pctSaldo = total ? Math.round(saldo / total * 100) : 0;
  var interesPorCuota = nCuotas ? Math.round(interes / nCuotas) : 0;
  var ratioCapital = total ? (capital / total) : 0;

  var hoyD = new Date(); hoyD.setHours(0, 0, 0, 0);
  function difDias(iso) { if (!iso) return 0; return Math.round((new Date(iso + 'T00:00:00') - hoyD) / 86400000); }
  var pend = cuotas.filter(function (c) { return c.estado !== 'pagada'; }).slice()
    .sort(function (a, b) { return String(a.fecha_vencimiento).localeCompare(String(b.fecha_vencimiento)); });
  var proxima = pend[0] || null;
  var diasRestantes = proxima ? difDias(proxima.fecha_vencimiento) : 0;
  var diasMora = 0; cuotas.forEach(function (c) { if (c.estado !== 'pagada') { var d = -difDias(c.fecha_vencimiento); if (d > diasMora) diasMora = d; } });
  var enMora = diasMora > 0 || prestamo.estado === 'en_mora';
  var estaPagado = prestamo.estado === 'pagado' || saldo <= 0.01;
  var fechasPago = pagos.map(function (p) { return p.fecha_pago; }).filter(Boolean).sort();
  var ultimoPago = fechasPago.length ? fechasPago[fechasPago.length - 1] : null;
  var totalPendienteCuotas = cuotas.reduce(function (a, c) { return a + (Number(c.monto_esperado) - Number(c.monto_pagado)); }, 0);

  var MES3 = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
  var MESL = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
  function fCorta(iso) { if (!iso) return '—'; var d = new Date(iso + 'T00:00:00'); return d.getDate() + ' ' + MES3[d.getMonth()] + ' ' + d.getFullYear(); }
  function fLarga(iso) { if (!iso) return '—'; var d = new Date(iso + 'T00:00:00'); return d.getDate() + ' de ' + MESL[d.getMonth()] + ' de ' + d.getFullYear(); }
  function inicial(n) { return (n || '?').trim().slice(0, 1).toUpperCase(); }
  var numCred = 'CRD-' + String(prestamo.fecha_inicio || '2000').slice(0, 4) + '-' + (prestamo.numero != null ? String(prestamo.numero).padStart(4, '0') : String(prestamo.id).replace(/\D/g, '').slice(0, 4));
  var hoyISOv = (function () { var d = new Date(); return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0'); })();
  var METODOS_LBL = { efectivo: 'Efectivo', transferencia: 'Transferencia', nequi: 'Nequi', daviplata: 'Daviplata', otro: 'Otro' };
  var estadoBadge = estaPagado
    ? '<span class="badge-exito">Pagado</span>'
    : (enMora ? '<span class="badge-peligro">En mora</span>' : '<span class="badge-exito">Activo</span>');
%>

<!-- ===================== ENCABEZADO ===================== -->
<div class="mb-6 flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
  <div class="flex items-start gap-4">
    <a href="/admin/prestamos" class="icon-btn shrink-0 mt-1" aria-label="Volver">
      <svg class="h-5 w-5 text-slate-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
    </a>
    <div class="relative shrink-0">
      <span class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-blue-400 to-blue-600 text-2xl font-bold text-white shadow-lg shadow-blue-500/25"><%= inicial(cli.nombre_completo) %></span>
      <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full <%= enMora ? 'bg-red-500' : 'bg-emerald-500' %> text-white ring-2 ring-white">
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
      </span>
    </div>
    <div class="min-w-0">
      <div class="flex flex-wrap items-center gap-2">
        <h1 class="text-2xl font-bold text-slate-800"><%= cli.nombre_completo || 'Cliente' %></h1>
        <%- estadoBadge %>
      </div>
      <p class="text-sm text-slate-500 mt-0.5">C.C. <%= cli.numero_documento || '—' %> · Crédito <span class="font-medium text-slate-600">#<%= numCred %></span></p>
      <p class="text-xs text-slate-400 mt-0.5">Desde el <%= fLarga(prestamo.fecha_inicio) %><% if (proxima) { %> · Próximo pago: <span class="font-medium text-slate-500"><%= fLarga(proxima.fecha_vencimiento) %></span><% } %></p>
    </div>
  </div>

  <div class="flex flex-wrap items-stretch gap-2">
    <% if (tieneTel) { %>
      <a href="tel:<%= telDigitos %>" class="accion-detalle">
        <img src="/img/telefono-removebg-preview.ico" alt="Llamar" class="h-16 w-16 object-contain" style="image-rendering:auto" />
        Llamar
      </a>
      <a href="<%= waUrl %>" target="_blank" rel="noopener" class="accion-detalle">
        <img src="/img/nuevo-icono-wasap.ico" alt="WhatsApp" class="h-16 w-16 object-contain" style="image-rendering:auto" />
        WhatsApp
      </a>
    <% } %>
    <a href="/admin/archivo?prestamo=<%= prestamo.id %>" class="accion-detalle">
      <img src="/img/nuevo%20comprobante.ico" alt="Comprobantes" class="h-16 w-16 object-contain" style="image-rendering:auto" />
      Comprobantes
    </a>
    <a href="/admin/clientes/<%= prestamo.cliente_id %>/editar" class="accion-detalle">
      <img src="/img/nuevo%20editar.ico" alt="Editar" class="h-16 w-16 object-contain" style="image-rendering:auto" />
      Editar
    </a>
  </div>
</div>

<!-- ===================== KPIs ===================== -->
<div class="mb-6 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
  <div class="card">
    <div class="flex items-center gap-2 mb-2"><span class="flex h-9 w-9 items-center justify-center rounded-xl bg-emerald-50 text-emerald-500"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M19 7V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/><path d="M21 12a2 2 0 0 0-2-2h-4a2 2 0 0 0 0 4h4a2 2 0 0 0 2-2Z"/></svg></span><p class="text-xs text-slate-400">Capital</p></div>
    <p class="num text-xl font-bold text-slate-800"><%= formatCOP(capital) %></p>
    <p class="text-[11px] text-slate-400 mt-0.5"><%= pctCapital %>% del total</p>
    <div class="mt-2 h-1.5 rounded-full bg-slate-100"><div class="h-full rounded-full bg-emerald-500" style="width:<%= pctCapital %>%"></div></div>
  </div>
  <div class="card">
    <div class="flex items-center gap-2 mb-2"><span class="flex h-9 w-9 items-center justify-center rounded-xl bg-violet-50 text-violet-500"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 9l-5 5-2-2-4 4"/></svg></span><p class="text-xs text-slate-400">Interés</p></div>
    <p class="num text-xl font-bold text-slate-800"><%= formatCOP(interes) %></p>
    <p class="text-[11px] text-slate-400 mt-0.5"><%= pctInteres %>% del total</p>
    <div class="mt-2 h-1.5 rounded-full bg-slate-100"><div class="h-full rounded-full bg-violet-500" style="width:<%= pctInteres %>%"></div></div>
  </div>
  <div class="card">
    <div class="flex items-center gap-2 mb-2"><span class="flex h-9 w-9 items-center justify-center rounded-xl bg-blue-50 text-blue-500"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/></svg></span><p class="text-xs text-slate-400">Total a pagar</p></div>
    <p class="num text-xl font-bold text-slate-800"><%= formatCOP(total) %></p>
    <p class="text-[11px] text-slate-400 mt-0.5">100% del crédito</p>
    <div class="mt-2 h-1.5 rounded-full bg-slate-100"><div class="h-full rounded-full bg-blue-500" style="width:100%"></div></div>
  </div>
  <div class="card">
    <div class="flex items-center gap-2 mb-2"><span class="flex h-9 w-9 items-center justify-center rounded-xl bg-amber-50 text-amber-500"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg></span><p class="text-xs text-slate-400">Próxima cuota</p></div>
    <p class="num text-lg font-bold text-slate-800"><%= proxima ? fCorta(proxima.fecha_vencimiento) : (estaPagado ? 'Pagado' : '—') %></p>
    <p class="text-[11px] text-slate-400 mt-0.5"><%= formatCOP(valorCuota) %> · <%= (prestamo.frecuencia_pago||'').charAt(0).toUpperCase()+(prestamo.frecuencia_pago||'').slice(1) %></p>
    <div class="mt-2 h-1.5 rounded-full bg-slate-100"><div class="h-full rounded-full bg-amber-500" style="width:<%= progresoPct %>%"></div></div>
  </div>
  <div class="card">
    <div class="flex items-center gap-2 mb-2"><span class="flex h-9 w-9 items-center justify-center rounded-xl bg-red-50 text-red-500"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M19 7V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/><path d="M21 12a2 2 0 0 0-2-2h-4a2 2 0 0 0 0 4h4a2 2 0 0 0 2-2Z"/></svg></span><p class="text-xs text-slate-400">Saldo pendiente</p></div>
    <p class="num text-xl font-bold text-slate-800"><%= formatCOP(saldo) %></p>
    <p class="text-[11px] text-slate-400 mt-0.5"><%= pctSaldo %>% por pagar</p>
    <div class="mt-2 h-1.5 rounded-full bg-slate-100"><div class="h-full rounded-full bg-red-500" style="width:<%= pctSaldo %>%"></div></div>
  </div>
</div>

<!-- ===================== PROGRESO + ESTADO ===================== -->
<div class="mb-6 grid grid-cols-1 lg:grid-cols-3 gap-6 items-stretch">
  <div class="lg:col-span-2 card !py-4">
    <p class="font-semibold text-slate-800 mb-3">Progreso del crédito</p>
    <div class="relative pt-4">
      <div class="h-2.5 rounded-full bg-slate-100">
        <div class="h-full rounded-full bg-gradient-to-r from-emerald-400 to-emerald-600 transition-all" style="width:<%= progresoPct %>%"></div>
      </div>
      <span class="absolute -top-1 flex items-center justify-center rounded-full border border-emerald-200 bg-white px-2 py-0.5 text-[11px] font-bold text-emerald-600 shadow-sm" style="left:<%= progresoPct %>%;transform:translateX(-50%)"><%= progresoPct %>%</span>
    </div>
    <div class="mt-3 flex justify-between text-xs text-slate-400">
      <span><span class="font-medium text-slate-600"><%= cuotasPagadas %></span> de <%= nCuotas %> cuotas pagadas</span>
      <span><span class="font-medium text-slate-600"><%= cuotasRestantes %></span> cuotas restantes</span>
    </div>
  </div>
  <div class="card !py-4 flex items-center gap-4">
    <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl <%= enMora ? 'bg-red-50 text-red-500' : 'bg-emerald-50 text-emerald-500' %>">
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><% if (enMora) { %><path d="M12 8v4M12 16h.01"/><% } else { %><path d="m9 12 2 2 4-4"/><% } %></svg>
    </span>
    <div>
      <p class="text-xs text-slate-400">Estado del crédito</p>
      <p class="text-lg font-bold <%= enMora ? 'text-red-500' : 'text-emerald-600' %>"><%= estaPagado ? 'Pagado' : (enMora ? 'En mora' : 'Al día') %></p>
      <p class="text-xs text-slate-400"><%= enMora ? diasMora + ' día' + (diasMora===1?'':'s') + ' de mora' : 'Sin mora' %></p>
    </div>
  </div>
</div>

<!-- ========== PLAN + HISTORIAL (izq) | ABONO + RESUMEN (der) ========== -->
<div class="mb-6 flex flex-col lg:flex-row gap-6 lg:items-start">
  <!-- Izquierda -->
  <div class="flex-1 min-w-0 flex flex-col gap-6">
    <!-- Plan de cuotas -->
  <div class="card">
    <h2 class="font-semibold text-slate-800 mb-4">Plan de cuotas</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-100 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">
            <th class="pb-3 pr-3">#</th><th class="pb-3 pr-3">Vence</th><th class="pb-3 pr-3 text-right">Monto</th><th class="pb-3 pr-3 text-right">Pagado</th><th class="pb-3 pr-3 text-right">Saldo</th><th class="pb-3 text-right">Estado</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-50">
          <% cuotas.slice().sort(function(a,b){return a.numero_cuota-b.numero_cuota;}).forEach(function(c) {
              var sc = Number(c.monto_esperado) - Number(c.monto_pagado);
              var venc = difDias(c.fecha_vencimiento);
              var esProx = proxima && c.id === proxima.id;
              var badge, fila = '';
              if (c.estado === 'pagada') { badge = '<span class="inline-flex items-center gap-1 rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-semibold text-emerald-600"><svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>Pagada</span>'; }
              else if (venc < 0) { badge = '<span class="inline-flex items-center gap-1 rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-semibold text-red-600"><svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v4"/></svg>Vencida</span>'; fila = 'bg-red-50/40'; }
              else if (esProx) { badge = '<span class="inline-flex items-center gap-1 rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-semibold text-amber-600"><svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>Por vencer</span>'; fila = 'bg-amber-50'; }
              else if (c.estado === 'parcial') { badge = '<span class="rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-semibold text-amber-600">Parcial</span>'; }
              else { badge = '<span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-semibold text-slate-500">Pendiente</span>'; }
          %>
            <tr class="<%= fila %>">
              <td class="py-3 pr-3 font-mono text-xs text-slate-400"><%= c.numero_cuota %></td>
              <td class="py-3 pr-3 text-slate-600 whitespace-nowrap"><%= fCorta(c.fecha_vencimiento) %></td>
              <td class="py-3 pr-3 text-right num text-slate-700"><%= formatCOP(c.monto_esperado) %></td>
              <td class="py-3 pr-3 text-right num text-slate-500"><%= formatCOP(c.monto_pagado) %></td>
              <td class="py-3 pr-3 text-right num font-medium text-slate-800"><%= formatCOP(sc) %></td>
              <td class="py-3 text-right"><%- badge %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <!-- Footer stats -->
    <div class="mt-4 grid grid-cols-2 sm:grid-cols-4 gap-3 border-t border-slate-100 pt-4">
      <div><p class="text-[11px] text-slate-400">Cuotas pagadas</p><p class="num text-base font-bold text-slate-800"><%= cuotasPagadas %></p></div>
      <div><p class="text-[11px] text-slate-400">Total pagado</p><p class="num text-base font-bold text-emerald-600"><%= formatCOP(abonado) %></p></div>
      <div><p class="text-[11px] text-slate-400">Total pendiente</p><p class="num text-base font-bold text-red-500"><%= formatCOP(saldo) %></p></div>
      <div><p class="text-[11px] text-slate-400">Días restantes</p><p class="num text-base font-bold text-blue-600"><%= proxima ? (diasRestantes >= 0 ? diasRestantes + ' días' : 'Vencida') : '—' %></p></div>
    </div>
  </div>
    <!-- Historial de abonos -->
  <div class="card">
    <h2 class="font-semibold text-slate-800 mb-4">Historial de abonos</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm" data-datatable data-no-search>
        <thead>
          <tr class="border-b border-slate-100 text-left text-xs font-semibold uppercase tracking-wide text-slate-400">
            <th class="pb-3 pr-3">Fecha</th><th class="pb-3 pr-3 text-right">Monto</th><th class="pb-3 pr-3">Método</th><th class="pb-3 pr-3">Aplicado a</th><th class="pb-3">Comprobante</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-50">
          <% if (pagos.length === 0) { %>
            <tr><td colspan="5" class="py-8 text-center text-slate-400">Aún no se han registrado abonos.</td></tr>
          <% } %>
          <% pagos.forEach(function(p) {
              var apl = (p.distribucion && Array.isArray(p.distribucion.aplicaciones)) ? p.distribucion.aplicaciones : [];
              var aplTxt = apl.length ? apl.map(function(a){ return 'Cuota ' + a.cuota_numero; }).join(', ') : '—';
              var esInteresPago = p.tipo === 'interes';
          %>
            <tr>
              <td class="py-3 pr-3 whitespace-nowrap text-slate-600"><%= p.fecha_pago %></td>
              <td class="py-3 pr-3 text-right num font-semibold text-slate-800"><%= formatCOP(p.monto) %></td>
              <td class="py-3 pr-3 whitespace-nowrap">
                <span class="rounded-md bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-500"><%= METODOS_LBL[p.metodo] || p.metodo || '—' %></span>
                <% if (esInteresPago) { %><span class="ml-1 rounded-md bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-600">Solo interés</span><% } %>
              </td>
              <td class="py-3 pr-3 text-slate-500"><%= aplTxt %></td>
              <td class="py-3">
                <a href="/admin/prestamos/<%= prestamo.id %>/pagos/<%= p.id %>/comprobante?ver=1" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-blue-600 hover:underline text-xs font-medium">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/></svg>
                  Ver recibo
                </a>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
  </div>
  <!-- Derecha -->
  <div class="w-full lg:w-96 lg:shrink-0 flex flex-col gap-6">
    <!-- Registrar abono -->
  <div class="card">
    <h2 class="flex items-center gap-2 font-semibold text-slate-800 mb-4">
      <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-blue-50 text-blue-500"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg></span>
      Registrar abono
    </h2>
    <% if (estaPagado) { %>
      <div class="rounded-xl bg-emerald-50 px-4 py-6 text-center">
        <p class="font-medium text-emerald-700">Préstamo pagado</p>
        <p class="text-xs text-emerald-600/80 mt-1">Este crédito ya está saldado por completo.</p>
      </div>
    <% } else { %>
      <form action="/admin/prestamos/<%= prestamo.id %>/pagos" method="POST" id="form-abono"
            data-loading-title="Registrando abono…" data-ratio-capital="<%= ratioCapital %>" data-saldo="<%= saldo %>" data-interes-cuota="<%= interesPorCuota %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="fecha_pago" value="<%= hoyISOv %>" />
        <input type="hidden" name="cuota_id" id="abono-cuota-id" value="" />

        <div class="grid grid-cols-1 gap-3">
          <div>
            <label class="label-field" for="abono-tipo">Tipo de pago</label>
            <select class="input-field" id="abono-tipo" name="tipo">
              <option value="abono">Abono normal</option>
              <option value="interes">Solo interés</option>
            </select>
          </div>
          <div>
            <label class="label-field" for="abono-monto"><span id="abono-monto-label">Monto del abono</span></label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">$</span>
              <input class="input-field pl-7 input-moneda" type="text" inputmode="numeric" id="abono-monto" name="monto" placeholder="0" required />
            </div>
          </div>
          <div>
            <label class="label-field" for="abono-metodo">Método de pago</label>
            <select class="input-field" id="abono-metodo" name="metodo">
              <option value="efectivo">Efectivo</option>
              <option value="transferencia">Transferencia</option>
              <option value="nequi">Nequi</option>
              <option value="daviplata">Daviplata</option>
              <option value="otro">Otro</option>
            </select>
          </div>
        </div>

        <!-- Opciones para pago de SOLO INTERÉS -->
        <div id="bloque-interes" class="hidden mt-3 rounded-xl border border-amber-200 bg-amber-50 p-3 space-y-2">
          <p class="text-sm font-medium text-amber-800">¿Qué se hace con el capital de esta cuota?</p>
          <label class="flex items-start gap-2 text-sm text-slate-600">
            <input type="radio" name="accion" value="saldo" class="mt-1" checked />
            <span><span class="font-medium text-slate-700">Dejar saldo pendiente</span> — el capital no pagado se cobra después (renegociación). El plan no cambia.</span>
          </label>
          <label class="flex items-start gap-2 text-sm text-slate-600">
            <input type="radio" name="accion" value="extension" class="mt-1" />
            <span><span class="font-medium text-slate-700">Extender un periodo</span> — se agrega una cuota más con interés de <%= formatCOP(interesPorCuota) %>; el capital se difiere al final.</span>
          </label>
        </div>

        <% if (pend.length > 0) { %>
          <p class="label-field mt-4 mb-2">Aplicar a</p>
          <div class="grid grid-cols-3 gap-2">
            <% pend.slice(0, 3).forEach(function(c) { %>
              <button type="button" class="chip-cuota-abono" data-cuota="<%= c.id %>" data-saldo="<%= Number(c.monto_esperado) - Number(c.monto_pagado) %>">
                <span class="font-semibold text-slate-700">Cuota <%= c.numero_cuota %></span>
                <span class="text-slate-400"><%= fCorta(c.fecha_vencimiento) %></span>
              </button>
            <% }); %>
          </div>
          <% if (pend.length > 3) { %>
            <select class="input-field mt-2 text-sm" id="abono-cuota-mas">
              <option value="">Más cuotas…</option>
              <% pend.slice(3).forEach(function(c) { %>
                <option value="<%= c.id %>" data-saldo="<%= Number(c.monto_esperado) - Number(c.monto_pagado) %>">Cuota <%= c.numero_cuota %> · <%= fCorta(c.fecha_vencimiento) %></option>
              <% }); %>
            </select>
          <% } %>
        <% } %>

        <!-- Resumen del abono (en vivo) -->
        <div class="mt-4 rounded-xl border border-slate-100 bg-slate-50/70 p-3">
          <p class="flex items-center gap-1.5 text-xs font-semibold text-slate-500 mb-2"><svg class="h-3.5 w-3.5 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path stroke-linecap="round" d="M12 16v-4M12 8h.01"/></svg>Resumen del abono</p>
