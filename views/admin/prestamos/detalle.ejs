        <p class="num text-xs text-slate-400 pl-4"><%= formatCOP(capital) %> (<%= pctCapital %>%)</p>
        <div class="flex items-center gap-2"><span class="h-2.5 w-2.5 rounded-full bg-violet-500"></span><span class="text-slate-500">Interés</span></div>
        <p class="num text-xs text-slate-400 pl-4"><%= formatCOP(interes) %> (<%= pctInteres %>%)</p>
