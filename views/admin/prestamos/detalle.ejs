          <div class="flex justify-between text-sm py-0.5 border-t border-slate-200 mt-1 pt-1.5"><span class="font-medium text-slate-600">Nuevo saldo pendiente</span><span class="num font-bold text-red-500" id="abono-saldo"><%= formatCOP(saldo) %></span></div>
        </div>

        <button type="submit" class="btn-primary w-full mt-4">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          Registrar abono
        </button>
      </form>
    <% } %>
  </div>
    <!-- Resumen del crédito -->
  <div class="card">
    <h2 class="font-semibold text-slate-800 mb-4">Resumen del crédito</h2>
    <div class="flex items-center gap-4 mb-4">
