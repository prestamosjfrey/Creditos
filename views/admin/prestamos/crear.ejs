<%- include('../../partials/header-admin', {
  tituloHeader: 'Nuevo préstamo',
  subtituloHeader: 'Completa la información para crear un nuevo préstamo',
  mostrarVolver: true,
  volverUrl: '/admin/prestamos',
}) %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2">
    <div class="flex items-center mb-6" id="indicador-pasos">
      <div class="flex items-center gap-2" data-indicador="1">
        <span class="step-circle step-circle-activo">1</span>
        <span class="text-sm font-medium text-blue-600">Detalles</span>
      </div>
      <div class="step-line flex-1 mx-3" data-linea="1"></div>
      <div class="flex items-center gap-2" data-indicador="2">
        <span class="step-circle">2</span>
        <span class="text-sm font-medium text-slate-400">Plan de pago</span>
      </div>
      <div class="step-line flex-1 mx-3" data-linea="2"></div>
      <div class="flex items-center gap-2" data-indicador="3">
        <span class="step-circle">3</span>
        <span class="text-sm font-medium text-slate-400">Confirmación</span>
      </div>
    </div>

    <form action="/admin/prestamos" method="POST" id="form-prestamo" class="card space-y-6" data-loading-title="Creando préstamo…">

      <!-- Paso 1: Detalles -->
      <div data-paso="1" class="space-y-6">
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-blue-100 text-blue-600">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>
            </span>
            <span class="font-medium text-slate-700">Cliente</span>
          </div>
          <div class="flex flex-col sm:flex-row gap-3">
            <select class="input-field flex-1" id="cliente_id" name="cliente_id" required>
              <option value="">Selecciona un cliente...</option>
              <% clientes.forEach(function(c) { %>
                <option value="<%= c.id %>" <%= valores.cliente_id === c.id ? 'selected' : '' %>>
                  <%= c.nombre_completo %> <%= c.numero_documento ? '· ' + c.numero_documento : '' %>
                </option>
              <% }); %>
            </select>
            <a href="/admin/clientes/nuevo" class="btn-secondary whitespace-nowrap">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 5v14M5 12h14" /></svg>
              Nuevo cliente
            </a>
          </div>
        </div>

        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 0 0-2.25-2.25H15a3 3 0 1 1-6 0H5.25A2.25 2.25 0 0 0 3 12m18 0v6a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 18v-6m18 0V9a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 9v3" /></svg>
            </span>
            <span class="font-medium text-slate-700">Monto del préstamo</span>
          </div>
          <label class="label-field" for="monto_capital">Capital a prestar</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">$</span>
            <input class="input-field pl-7 input-moneda" type="text" inputmode="numeric" id="monto_capital" name="monto_capital" value="<%= valores.monto_capital || '' %>" required />
          </div>
          <p class="mt-1 text-xs text-slate-400">Disponible en caja: <span class="font-medium text-slate-600"><%= formatCOP(saldoDisponible) %></span></p>
          <p id="alerta-saldo-insuficiente" class="mt-2 hidden rounded-lg bg-amber-50 border border-amber-200 px-3 py-2 text-xs text-amber-700">
            ⚠ Esto dejará tu caja en saldo negativo.
          </p>
        </div>

        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-violet-100 text-violet-600">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <line x1="19" y1="5" x2="5" y2="19" stroke-linecap="round" />
                <circle cx="7.5" cy="7.5" r="1.5" />
                <circle cx="16.5" cy="16.5" r="1.5" />
              </svg>
            </span>
            <span class="font-medium text-slate-700">Tipo de interés</span>
          </div>
          <label class="label-field" for="tipo_interes">¿Cómo defines el interés de este préstamo?</label>
          <select class="input-field" id="tipo_interes" name="tipo_interes" required>
            <option value="fijo_total">Interés fijo en pesos sobre el total</option>
            <option value="porcentaje_periodico">Porcentaje por periodo de pago</option>
            <option value="cuota_manual">Yo defino la cuota directamente</option>
          </select>

          <div id="campo-valor-interes" class="mt-3">
            <label class="label-field" for="valor_interes">Interés total en pesos</label>
            <input class="input-field input-moneda" type="text" inputmode="numeric" id="valor_interes" name="valor_interes" value="<%= valores.valor_interes || '' %>" />
          </div>

          <div id="campo-tasa-interes" class="mt-3 hidden">
            <label class="label-field" for="tasa_interes">Tasa de interés por periodo (%)</label>
            <input class="input-field" type="number" step="0.01" min="0" id="tasa_interes" name="tasa_interes" value="<%= valores.tasa_interes || '' %>" />
          </div>
        </div>

        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-orange-100 text-orange-600">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>
            </span>
            <span class="font-medium text-slate-700">Fechas y frecuencia de pago</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="label-field" for="fecha_inicio">Fecha de inicio</label>
              <input class="input-field" type="date" id="fecha_inicio" name="fecha_inicio" value="<%= valores.fecha_inicio || '' %>" required />
            </div>
            <div>
              <label class="label-field" for="fecha_primer_pago">Fecha del primer pago</label>
              <input class="input-field" type="date" id="fecha_primer_pago" name="fecha_primer_pago" value="<%= valores.fecha_primer_pago || '' %>" required />
            </div>
          </div>
          <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="label-field" for="frecuencia_pago">Frecuencia de pago <span class="text-slate-400">— ¿cada cuánto paga?</span></label>
              <select class="input-field" id="frecuencia_pago" name="frecuencia_pago" required>
                <option value="diario" <%= valores.frecuencia_pago === 'diario' ? 'selected' : '' %>>Diario</option>
                <option value="semanal" <%= valores.frecuencia_pago === 'semanal' ? 'selected' : '' %>>Semanal</option>
                <option value="quincenal" <%= valores.frecuencia_pago === 'quincenal' ? 'selected' : '' %>>Quincenal</option>
                <option value="mensual" <%= !valores.frecuencia_pago || valores.frecuencia_pago === 'mensual' ? 'selected' : '' %>>Mensual</option>
              </select>
            </div>
            <div>
              <label class="label-field" for="numero_cuotas">Número de cuotas</label>
              <input class="input-field" type="number" min="1" id="numero_cuotas" name="numero_cuotas" value="<%= valores.numero_cuotas || '' %>" required />
            </div>
          </div>
        </div>

        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-slate-100 text-slate-500">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>
            </span>
            <span class="font-medium text-slate-700">Notas (opcional)</span>
          </div>
          <textarea class="input-field" id="notas" name="notas" rows="2" maxlength="300"><%= valores.notas || '' %></textarea>
          <p class="mt-1 text-right text-xs text-slate-400"><span id="contador-notas">0</span> / 300</p>
        </div>
      </div>

      <!-- Paso 2: Plan de pago -->
      <div data-paso="2" class="space-y-6 hidden">
        <p class="text-sm text-slate-500">Estos valores se sugieren a partir del paso anterior. Puedes ajustarlos a mano si lo necesitas.</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="label-field" for="valor_cuota">Valor de cada cuota <span class="text-slate-400">(sugerido, editable)</span></label>
            <input class="input-field input-moneda" type="text" inputmode="numeric" id="valor_cuota" name="valor_cuota" value="<%= valores.valor_cuota || '' %>" required />
          </div>
          <div>
            <label class="label-field" for="monto_total_a_pagar">Total a pagar <span class="text-slate-400">(sugerido, editable)</span></label>
            <input class="input-field input-moneda" type="text" inputmode="numeric" id="monto_total_a_pagar" name="monto_total_a_pagar" value="<%= valores.monto_total_a_pagar || '' %>" required />
          </div>
        </div>

        <div>
          <p class="label-field mb-2">Cronograma generado</p>
          <div class="rounded-xl border border-slate-100 max-h-72 overflow-y-auto">
            <table class="table-base w-full">
              <thead class="sticky top-0 bg-slate-50">
                <tr><th>#</th><th>Fecha</th><th class="text-right">Capital</th><th class="text-right">Interés</th><th class="text-right">Cuota</th></tr>
              </thead>
              <tbody id="tabla-cuotas-preview"></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Paso 3: Confirmación -->
      <div data-paso="3" class="space-y-6 hidden">
        <p class="text-sm text-slate-500">Revisa los datos antes de crear el préstamo.</p>
        <div class="card divide-y divide-slate-100" id="resumen-confirmacion"></div>
      </div>

      <div class="flex justify-between pt-2">
        <a href="/admin/prestamos" class="btn-secondary">Cancelar</a>
        <div class="flex gap-3">
          <button type="button" id="btn-atras" class="btn-secondary hidden">Atrás</button>
          <button type="button" id="btn-siguiente" class="btn-primary">
            Siguiente
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0-4 4m4-4H3" /></svg>
          </button>
          <button type="submit" id="btn-crear" class="btn-primary hidden">Crear préstamo</button>
        </div>
      </div>
    </form>
  </div>

  <div class="space-y-4">
    <div class="card">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-semibold text-slate-800">Resumen del préstamo</h2>
        <button type="button" onclick="window.print()" class="icon-btn" aria-label="Imprimir">
          <svg class="h-4 w-4 text-slate-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0 1 10.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0 .229 2.523a1.125 1.125 0 0 1-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.32 0H6.34" /></svg>
        </button>
      </div>

      <div class="rounded-xl bg-emerald-50 p-4 mb-4">
        <p class="text-sm text-emerald-700">Total a pagar</p>
        <p class="num text-2xl font-semibold text-emerald-700" id="resumen-total-pagar">$ 0</p>
      </div>

      <dl class="space-y-2 text-sm">
        <div class="flex justify-between"><dt class="text-slate-400">Capital a prestar</dt><dd class="num font-medium text-slate-700" id="resumen-capital">$ 0</dd></div>
        <div class="flex justify-between"><dt class="text-slate-400">Interés total</dt><dd class="num font-medium text-slate-700" id="resumen-interes">$ 0</dd></div>
        <div class="flex justify-between"><dt class="text-slate-400">Número de cuotas</dt><dd class="font-medium text-slate-700" id="resumen-cuotas">—</dd></div>
        <div class="flex justify-between"><dt class="text-slate-400">Valor de cada cuota</dt><dd class="num font-medium text-slate-700" id="resumen-valor-cuota">$ 0</dd></div>
        <div class="flex justify-between"><dt class="text-slate-400">Interés por cuota</dt><dd class="num font-medium text-amber-600" id="resumen-interes-cuota">$ 0</dd></div>
        <div class="flex justify-between"><dt class="text-slate-400">Frecuencia de pago</dt><dd class="font-medium text-slate-700" id="resumen-frecuencia">—</dd></div>
        <div class="flex justify-between"><dt class="text-slate-400">Duración total</dt><dd class="font-medium text-slate-700" id="resumen-duracion">—</dd></div>
      </dl>
    </div>


    <div class="card bg-amber-50 border-amber-100">
      <p class="font-semibold text-amber-700 mb-1 flex items-center gap-2">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>
        Consejo
      </p>
      <p class="text-sm text-amber-700">Verifica que todos los datos sean correctos antes de continuar.</p>
    </div>
  </div>
</div>

<script>
  window.__SALDO_DISPONIBLE__ = <%- JSON.stringify(saldoDisponible) %>;
</script>
<script src="/js/prestamo-form.js"></script>
<%- include('../../partials/flash-script', { flashError: error, flashExito: null }) %>
