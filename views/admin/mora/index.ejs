<%
  var s = centro.stats, salud = centro.salud, series = centro.series, lista = centro.lista, topClientes = centro.topClientes;
  var ahora = new Date();
  var fechaLarga = ahora.toLocaleDateString('es-CO', { day: 'numeric', month: 'long', year: 'numeric' });
  var horaCorta = ahora.toLocaleTimeString('es-CO', { hour: '2-digit', minute: '2-digit', hour12: true });

  // Mini sparkline SVG a partir de un arreglo de valores.
  function spark(data, color) {
    var w = 84, h = 26, n = data.length || 1;
    var max = Math.max.apply(null, data.concat([1]));
    var pts = data.map(function (v, i) {
      var x = (n === 1 ? w : (i / (n - 1)) * w);
      var y = h - 3 - (v / max) * (h - 8);
      return x.toFixed(1) + ',' + y.toFixed(1);
    }).join(' ');
    return '<svg width="' + w + '" height="' + h + '" viewBox="0 0 ' + w + ' ' + h + '" fill="none" class="overflow-visible">' +
      '<polyline points="' + pts + '" stroke="' + color + '" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
  }

  var icoDoc  = '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="M12 11v3"/><path d="M12 17h.01"/></svg>';
  var icoWallet = '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M19 7V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/><path d="M21 12a2 2 0 0 0-2-2h-4a2 2 0 0 0 0 4h4a2 2 0 0 0 2-2Z"/></svg>';
  var icoPct  = '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>';
  var icoUp   = '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M23 6l-9.5 9.5-5-5L1 18"/><path d="M17 6h6v6"/></svg>';
  var icoUsers = '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/></svg>';

  var recuTxt = s.cambioRecuperado === null ? 'Sin base anterior'
    : (s.cambioRecuperado >= 0 ? '+' : '') + s.cambioRecuperado + '% vs mes anterior';
  var recuColor = s.cambioRecuperado === null ? 'text-slate-400' : (s.cambioRecuperado >= 0 ? 'text-emerald-600' : 'text-red-500');

  var tarjetas = [
    { key: 'creditosMora',  label: 'Créditos en mora',   valor: s.creditosMora,              sub: s.creditosMoraPct + '% del total',  subColor: 'text-slate-400', img: '/img/icono%20mora.webp', bg: 'bg-red-50', tx: 'text-red-500', spark: series.creditos, color: '#ef4444' },
    { key: 'capitalVencido', label: 'Capital vencido',    valor: formatCOP(s.capitalVencido), sub: s.capitalVencidoPct + '% del total', subColor: 'text-slate-400', ico: icoWallet, bg: 'bg-orange-50',  tx: 'text-orange-500', spark: series.capital,  color: '#f97316' },
    { key: 'interesVencido', label: 'Intereses vencidos', valor: formatCOP(s.interesVencido), sub: s.interesVencidoPct + '% del total', subColor: 'text-slate-400', ico: icoPct,   bg: 'bg-yellow-50',  tx: 'text-yellow-500', spark: series.interes,  color: '#eab308' },
    { key: 'recuperadoMes', label: 'Recuperado este mes', valor: formatCOP(s.recuperadoMes), sub: recuTxt,                             subColor: recuColor,        ico: icoUp,    bg: 'bg-blue-50',    tx: 'text-blue-500',   spark: [2,3,2.5,4,5],   color: '#3b82f6' },
    { key: 'clientesMora',  label: 'Clientes en mora',   valor: s.clientesMora,              sub: s.clientesMoraPct + '% del total',  subColor: 'text-slate-400', ico: icoUsers, bg: 'bg-violet-50',  tx: 'text-violet-500', spark: series.creditos, color: '#a855f7' },
  ];

  var saludHex = salud.color === 'emerald' ? '#10b981' : (salud.color === 'amber' ? '#f59e0b' : '#ef4444');
  var saludText = salud.color === 'emerald' ? 'text-emerald-600' : (salud.color === 'amber' ? 'text-amber-600' : 'text-red-500');
  var circ = 2 * Math.PI * 40;
  var offset = circ - (salud.pct / 100) * circ;

  var cats = [['todos','Todos'],['1-30','1 - 30 días'],['31-60','31 - 60 días'],['61-90','61 - 90 días'],['90+','+ 90 días']];
  var icoCal = '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>';
  var icoGrid = '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>';
%>

<style>
  @keyframes mor-float  { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
  @keyframes mor-orbit  { from{transform:rotateX(72deg) rotateZ(0deg)}   to{transform:rotateX(72deg) rotateZ(360deg)} }
  @keyframes mor-orbit2 { from{transform:rotateX(72deg) rotateZ(180deg)} to{transform:rotateX(72deg) rotateZ(540deg)} }
  @keyframes mor-shadow { 0%,100%{transform:translateX(-50%) scale(1);opacity:.35} 50%{transform:translateX(-50%) scale(.8);opacity:.18} }
  @keyframes mor-glow   { 0%,100%{opacity:.6} 50%{opacity:1} }
</style>

<!-- Encabezado -->
<div class="mb-6 flex flex-col items-center text-center gap-1">
  <div style="position:relative;width:84px;height:92px;display:flex;align-items:center;justify-content:center;margin-bottom:.25rem">
    <div style="position:absolute;bottom:0;left:50%;width:72px;height:12px;background:radial-gradient(ellipse,rgba(220,38,38,.5) 0%,transparent 70%);border-radius:50%;animation:mor-shadow 3s ease-in-out infinite;"></div>
    <div style="animation:mor-float 3s ease-in-out infinite;position:relative;width:70px;height:70px;">
      <div style="position:absolute;inset:-18px;border-radius:50%;background:radial-gradient(circle,rgba(220,38,38,.22) 0%,transparent 65%);animation:mor-glow 3s ease-in-out infinite;pointer-events:none;"></div>
      <div style="position:absolute;inset:-14px;border-radius:50%;border:2px solid transparent;border-top:2px solid rgba(248,113,113,.85);border-bottom:2px solid rgba(248,113,113,.2);transform:rotateX(72deg);animation:mor-orbit 3.5s linear infinite;pointer-events:none;"></div>
      <div style="position:absolute;inset:-6px;border-radius:50%;border:1.5px solid transparent;border-right:1.5px solid rgba(252,165,165,.7);border-left:1.5px solid rgba(252,165,165,.15);transform:rotateX(72deg) rotateZ(180deg);animation:mor-orbit2 5s linear infinite;pointer-events:none;"></div>
      <div style="width:70px;height:70px;border-radius:50%;background:radial-gradient(circle at 33% 28%,#fecaca 0%,#f87171 28%,#ef4444 52%,#dc2626 70%,#991b1b 88%,#450a0a 100%);box-shadow:0 12px 36px rgba(220,38,38,.65),0 4px 12px rgba(0,0,0,.25),inset 0 -8px 16px rgba(0,0,0,.35),inset 2px 2px 6px rgba(255,255,255,.08);position:relative;display:flex;align-items:center;justify-content:center;">
        <div style="position:absolute;top:12%;left:16%;width:38%;height:30%;background:radial-gradient(ellipse at 40% 40%,rgba(255,255,255,.7) 0%,rgba(255,255,255,.15) 55%,transparent 100%);border-radius:50%;filter:blur(3px);pointer-events:none;"></div>
        <svg style="width:30px;height:30px;color:white;filter:drop-shadow(0 2px 6px rgba(0,0,0,.4));position:relative;z-index:1;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
        </svg>
      </div>
    </div>
  </div>
  <h1 class="text-3xl font-bold text-slate-800">Centro de Mora</h1>
  <p class="text-sm text-slate-400">Monitorea y gestiona los créditos vencidos.</p>
  <div class="mt-1 h-0.5 w-10 rounded-full bg-red-500"></div>
</div>

<!-- Tarjetas de estadísticas -->
<div class="mb-6 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
  <% tarjetas.forEach(function(t) { %>
    <div class="card flex flex-col gap-2">
      <div class="flex items-start justify-between gap-2">
        <% if (t.img) { %>
          <img src="<%= t.img %>" alt="<%= t.label %>" class="h-12 w-12 shrink-0 object-contain" />
        <% } else { %>
          <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl <%= t.bg %> <%= t.tx %>"><%- t.ico %></span>
        <% } %>
        <div class="mt-1"><%- spark(t.spark, t.color) %></div>
      </div>
      <div>
        <p class="text-xs text-slate-400"><%= t.label %></p>
        <p class="num text-2xl font-bold text-slate-800 mt-0.5" data-stat="<%= t.key %>"><%= t.valor %></p>
        <p class="text-[11px] mt-0.5 <%= t.subColor %>" data-stat-sub="<%= t.key %>"><%= t.sub %></p>
      </div>
    </div>
  <% }); %>
</div>

<!-- Toolbar: filtros + búsqueda + exportar -->
<div class="mb-6 flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
  <div class="flex flex-wrap gap-2">
    <% cats.forEach(function(c, i) { %>
      <button type="button" data-rango="<%= c[0] %>"
        class="chip-mora inline-flex items-center gap-1.5 rounded-full px-3.5 py-1.5 text-sm font-medium transition <%= i === 0 ? 'bg-red-500 text-white shadow-sm' : 'bg-white text-slate-500 ring-1 ring-slate-200 hover:bg-slate-50' %>">
        <%- i === 0 ? icoGrid : icoCal %>
        <%= c[1] %>
      </button>
    <% }); %>
  </div>
  <div class="flex items-center gap-2">
    <div class="relative flex-1 lg:w-72">
      <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      </span>
      <input id="buscar-mora" type="text" placeholder="Buscar cliente, cédula o referencia…"
        class="w-full rounded-full border border-slate-200 bg-white py-2 pl-9 pr-4 text-sm text-slate-600 focus:border-red-300 focus:outline-none focus:ring-2 focus:ring-red-100" />
    </div>
    <div class="relative shrink-0">
      <button type="button" id="btn-exportar-mora" class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-600 transition hover:bg-slate-50">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12m0 0-4-4m4 4 4-4M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/></svg>
        Exportar
        <svg class="h-3.5 w-3.5 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
      </button>
      <div id="menu-exportar-mora" class="hidden absolute right-0 top-full z-50 mt-2 w-44 overflow-hidden rounded-xl border border-slate-100 bg-white py-1 shadow-lg">
        <button type="button" id="exportar-mora-json" class="flex w-full items-center gap-2 px-4 py-2 text-sm text-slate-600 transition hover:bg-slate-50">
          <svg class="h-4 w-4 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H7a2 2 0 0 0-2 2v4a2 2 0 0 1-2 2 2 2 0 0 1 2 2v4a2 2 0 0 0 2 2h1M16 3h1a2 2 0 0 1 2 2v4a2 2 0 0 0 2 2 2 2 0 0 0-2 2v4a2 2 0 0 1-2 2h-1"/></svg>
          Formato JSON
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Contenido principal -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Columna izquierda -->
  <div class="lg:col-span-2 flex flex-col">
    <div class="card flex-1 flex flex-col">
      <!-- Estado vacío -->
      <div id="mora-vacio" class="flex flex-1 flex-col items-center justify-center text-center py-10 <%= lista.length === 0 ? '' : 'hidden' %>">
        <img src="/img/imagen_mora_al_dia.webp" alt="Cartera al día, sin mora" class="mb-5 h-36 w-auto object-contain" />
        <h2 class="text-xl font-bold text-slate-800">¡Excelente trabajo!</h2>
        <p class="mt-1 font-medium text-slate-600">No existen créditos en mora.</p>
        <p class="mt-1 text-sm text-slate-400 max-w-xs">Todos los clientes están al día. Tu cartera se encuentra en excelentes condiciones.</p>
        <a href="/admin/prestamos" class="mt-5 inline-flex items-center gap-2 rounded-full border border-red-200 bg-white px-5 py-2.5 text-sm font-semibold text-red-500 transition hover:bg-red-50">
          Ver todos los créditos
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
      <!-- Lista de créditos en mora -->
      <div id="mora-lista-wrap" class="<%= lista.length === 0 ? 'hidden' : '' %>">
        <div id="lista-mora" class="divide-y divide-slate-100">
          <% lista.forEach(function(m) {
              var rango = m.diasAtraso <= 30 ? '1-30' : (m.diasAtraso <= 60 ? '31-60' : (m.diasAtraso <= 90 ? '61-90' : '90+'));
              var buscar = (m.cliente + ' ' + m.documento + ' ' + m.numeroPrestamo).toLowerCase();
          %>
            <div class="fila-mora flex items-center gap-4 py-3" data-rango="<%= rango %>" data-buscar="<%= buscar.replace(/"/g,'') %>">
              <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-red-50 text-red-500 text-sm font-bold"><%= (m.cliente || '?').trim().slice(0,1).toUpperCase() %></span>
              <div class="min-w-0 flex-1">
                <p class="font-medium text-slate-800 truncate"><%= m.cliente %></p>
                <p class="text-xs text-slate-400">Cédula <%= m.documento %> · <%= m.numeroPrestamo %> · Cuota #<%= m.numeroCuota %></p>
              </div>
              <div class="hidden sm:block text-right">
                <p class="num font-semibold text-slate-800"><%= formatCOP(m.saldo) %></p>
                <p class="text-xs text-slate-400">vence <%= m.vencimiento %></p>
              </div>
              <span class="shrink-0 rounded-full bg-red-100 px-2.5 py-1 text-xs font-semibold text-red-600 whitespace-nowrap"><%= m.diasAtraso %> día<%= m.diasAtraso === 1 ? '' : 's' %></span>
              <a href="/admin/prestamos/<%= m.prestamoId %>" class="shrink-0 text-slate-300 transition hover:text-red-500" title="Ver préstamo">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
              </a>
            </div>
          <% }); %>
        </div>
        <p id="mora-sin-resultados" class="hidden py-8 text-center text-sm text-slate-400">Ningún crédito coincide con el filtro.</p>
      </div>
    </div>

  </div>

  <!-- Columna derecha -->
  <div class="space-y-6">
    <!-- Salud de la cartera -->
    <div class="card">
      <div class="flex items-center gap-1.5 mb-4">
        <h3 class="font-semibold text-slate-800">Salud de la cartera</h3>
        <svg class="h-4 w-4 text-slate-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path stroke-linecap="round" d="M12 16v-4M12 8h.01"/></svg>
      </div>
      <div class="flex items-center gap-4">
        <div class="relative shrink-0">
          <svg width="96" height="96" viewBox="0 0 96 96">
            <circle cx="48" cy="48" r="40" fill="none" stroke="#e2e8f0" stroke-width="9"/>
            <circle id="salud-circle" cx="48" cy="48" r="40" fill="none" stroke="<%= saludHex %>" stroke-width="9" stroke-linecap="round" stroke-dasharray="<%= circ.toFixed(1) %>" stroke-dashoffset="<%= offset.toFixed(1) %>" transform="rotate(-90 48 48)"/>
          </svg>
          <span id="salud-pct" class="absolute inset-0 flex items-center justify-center text-lg font-bold text-slate-800"><%= salud.pct %>%</span>
        </div>
        <div class="min-w-0">
          <p id="salud-texto" class="text-lg font-bold <%= saludText %>"><%= salud.texto %></p>
          <p id="salud-desc" class="text-xs text-slate-400 mt-0.5"><%= salud.desc %></p>
          <span id="salud-badge" class="mt-2 inline-flex items-center gap-1 rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-medium text-emerald-600">
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            <span data-badge-txt><%= s.creditosMora === 0 ? 'Sin riesgo de mora' : s.creditosMora + ' crédito' + (s.creditosMora === 1 ? '' : 's') + ' en mora' %></span>
          </span>
        </div>
      </div>
    </div>

    <!-- Mora últimos 30 días -->
    <div class="card">
      <div class="flex items-center justify-between gap-2 mb-3">
        <h3 class="font-semibold text-slate-800">Mora últimos 30 días</h3>
        <select id="metrica-mora" class="rounded-lg border border-slate-200 bg-white px-2.5 py-1.5 text-xs font-medium text-slate-600 focus:outline-none">
          <option value="capital">Capital vencido</option>
          <option value="interes">Intereses vencidos</option>
          <option value="creditos">Créditos en mora</option>
        </select>
      </div>
      <div class="relative h-44"><canvas id="chart-mora"></canvas></div>
    </div>

    <!-- Clientes con mayor mora -->
    <div class="card">
      <div class="flex items-center justify-between gap-2 mb-3">
        <h3 class="font-semibold text-slate-800">Clientes con mayor mora</h3>
        <a href="/admin/clientes" class="text-xs font-medium text-blue-600 hover:underline">Ver todos</a>
      </div>
      <div id="top-clientes">
        <% if (topClientes.length === 0) { %>
          <div class="flex items-center gap-3 rounded-2xl bg-rose-50/60 px-4 py-4">
            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-rose-100 text-rose-400">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </span>
            <div>
              <p class="font-medium text-slate-700">No hay clientes en mora</p>
              <p class="text-xs text-slate-400">Todos tus clientes se encuentran al día.</p>
            </div>
          </div>
        <% } else { %>
          <div class="space-y-2">
            <% topClientes.forEach(function(c) { %>
              <a href="/admin/clientes/<%= c.clienteId %>" class="flex items-center gap-3 rounded-xl px-2 py-2 transition hover:bg-slate-50">
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-red-50 text-red-500 text-sm font-bold"><%= (c.nombre || '?').trim().slice(0,1).toUpperCase() %></span>
                <div class="min-w-0 flex-1">
                  <p class="font-medium text-slate-800 truncate"><%= c.nombre %></p>
                  <p class="text-xs text-slate-400"><%= c.cuotas %> cuota<%= c.cuotas === 1 ? '' : 's' %> · hasta <%= c.maxDias %> días</p>
                </div>
                <p class="num text-sm font-semibold text-red-600 whitespace-nowrap"><%= formatCOP(c.monto) %></p>
              </a>
            <% }); %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script>
  window.__MORA_SERIES__ = <%- JSON.stringify(series).replace(/</g,'\\u003c') %>;
  window.__MORA_LISTA__ = <%- JSON.stringify(lista).replace(/</g,'\\u003c') %>;
</script>
<script src="/vendor/socket.io/socket.io.min.js"></script>
<script src="/js/mora.js"></script>
