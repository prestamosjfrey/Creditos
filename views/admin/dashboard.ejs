<%
  var seriesJson = JSON.stringify(seriesPorPeriodo).replace(/<\//g, '<\\/');
%>

<%- include('../partials/header-admin', {
  tituloHeader: 'Hola, ' + (usuario.nombre_completo || 'Admin').split(' ')[0] + ' 👋',
  subtituloHeader: 'Aquí tienes el resumen de tu cartera al día de hoy.',
  mostrarVolver: false,
}) %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-6">
  <%
    var capitalPropio = saldoDisponible - creditosTomados.capitalRecibido;
    var tieneDeuda = creditosTomados.activos > 0;
  %>
  <div class="hero-card lg:col-span-2">
    <!-- Fila superior: saldo y deuda -->
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-white/60">Saldo en caja</p>
        <p class="num mt-1 text-3xl font-bold">
          <%= formatCOP(saldoDisponible) %>
        </p>
        <span class="mt-2 inline-flex items-center gap-1 text-xs text-white/70">
          👥 <%= resumenDestacado.clientesActivos %> cliente<%= resumenDestacado.clientesActivos !== 1 ? 's' : '' %> activo<%= resumenDestacado.clientesActivos !== 1 ? 's' : '' %>
        </span>
      </div>
      <% if (tieneDeuda) { %>
      <a href="/admin/creditos-tomados" class="flex flex-col items-end text-right hover:opacity-80 transition shrink-0">
        <p class="text-xs font-semibold uppercase tracking-wide text-orange-300">Deuda propia</p>
        <p class="num text-xl font-bold text-orange-200 mt-0.5"><%= formatCOP(creditosTomados.totalDeuda) %></p>
        <p class="text-[11px] text-white/50 mt-0.5">
          <%= creditosTomados.activos %> crédito<%= creditosTomados.activos > 1 ? 's' : '' %> tomado<%= creditosTomados.activos > 1 ? 's' : '' %> activo<%= creditosTomados.activos > 1 ? 's' : '' %>
        </p>
      </a>
      <% } else { %>
      <div class="flex flex-col items-end text-right shrink-0">
        <p class="text-xs text-white/60">Este mes</p>
        <p class="text-sm font-semibold">+<%= formatCOP(resumenDestacado.interesesEsteMes) %></p>
        <p class="text-[11px] text-white/50">Intereses generados</p>
      </div>
      <% } %>
    </div>

    <!-- Fila inferior: descomposición del saldo -->
    <% if (tieneDeuda) { %>
    <div class="mt-4 grid grid-cols-2 gap-3 border-t border-white/10 pt-4">
      <div class="rounded-xl bg-white/10 px-3 py-2.5">
        <p class="text-[11px] font-semibold uppercase tracking-wide text-white/50">Capital propio en caja</p>
        <p class="num text-base font-bold mt-0.5 <%= capitalPropio < 0 ? 'text-red-300' : 'text-white' %>">
          <%= formatCOP(capitalPropio) %>
        </p>
        <% if (capitalPropio < 0) { %>
          <p class="text-[11px] text-red-300/70 mt-0.5">Todo tu capital está en cartera</p>
        <% } else { %>
          <p class="text-[11px] text-white/40 mt-0.5">Sin deuda de acreedores</p>
        <% } %>
      </div>
      <div class="rounded-xl bg-white/10 px-3 py-2.5">
        <p class="text-[11px] font-semibold uppercase tracking-wide text-white/50">Capital de acreedores</p>
        <p class="num text-base font-bold mt-0.5 text-orange-200"><%= formatCOP(creditosTomados.capitalRecibido) %></p>
        <p class="text-[11px] text-white/40 mt-0.5">Debes pagar <%= formatCOP(creditosTomados.totalDeuda) %></p>
      </div>
    </div>
    <% } %>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-2 gap-3">
    <a href="/admin/prestamos/nuevo" class="quick-action">
      <span class="flex h-10 w-10 items-center justify-center rounded-full bg-blue-100 text-blue-600">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" d="M12 5v14M5 12h14" /></svg>
      </span>
      <span class="text-xs text-slate-600">Nuevo préstamo</span>
    </a>
    <a href="/admin/prestamos" class="quick-action">
      <span class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182.553-.439 1.278-.659 2.003-.659.725 0 1.45.22 2.003.659l.659.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
      </span>
      <span class="text-xs text-slate-600">Registrar pago</span>
    </a>
    <a href="/admin/clientes" class="quick-action">
      <span class="flex h-10 w-10 items-center justify-center rounded-full bg-violet-100 text-violet-600">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>
      </span>
      <span class="text-xs text-slate-600">Ver clientes</span>
    </a>
    <a href="/admin/reportes" class="quick-action">
      <span class="flex h-10 w-10 items-center justify-center rounded-full bg-orange-100 text-orange-600">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>
      </span>
      <span class="text-xs text-slate-600">Generar reporte</span>
    </a>
  </div>
</div>

<%
  // Botón de ayuda reutilizable para las tarjetas del dashboard.
  function btnExplica(titulo, contenidoHtml) {
    return '<button type="button" class="explica-btn absolute top-3 right-3 text-slate-300 transition hover:text-blue-500" data-explica-titulo="' + titulo + '" aria-label="¿Cómo se calcula?" title="¿Cómo se calcula?">' +
      '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 16v-4M12 8h.01"/></svg>' +
      '<template class="explica-contenido">' + contenidoHtml + '</template></button>';
  }

  // Tabla de desglose por préstamo: muestra de dónde sale el total.
  // valorFn devuelve el aporte de cada préstamo (o null para omitirlo).
  var _desglose = (kpis && kpis.desglose) ? kpis.desglose : [];
  function tablaDesglose(valorFn, total) {
    var filas = '';
    _desglose.forEach(function (it) {
      var v = valorFn(it);
      if (v === null || v === undefined) return;
      filas += '<tr>' +
        '<td class="py-0.5 pr-2 text-slate-500">N° ' + String(it.numero || 0).padStart(5, '0') + ' · ' + it.cliente + '</td>' +
        '<td class="py-0.5 text-right num text-slate-700 whitespace-nowrap">' + formatCOP(v) + '</td></tr>';
    });
    if (!filas) filas = '<tr><td colspan="2" class="py-1 text-slate-400">Aún no hay préstamos que sumen aquí.</td></tr>';
    return '<div class="rounded-lg border border-slate-100 bg-slate-50/60 p-2 mt-1">' +
      '<p class="text-[11px] font-semibold uppercase tracking-wide text-slate-400 mb-1">Desglose por préstamo</p>' +
      '<table class="w-full text-xs"><tbody>' + filas + '</tbody>' +
      '<tfoot><tr><td class="pt-1.5 border-t border-slate-200 font-semibold text-slate-700">Total</td>' +
      '<td class="pt-1.5 border-t border-slate-200 text-right num font-semibold text-slate-800 whitespace-nowrap">' + formatCOP(total) + '</td></tr></tfoot></table></div>';
  }
%>
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <div class="card flex items-start gap-3 relative">
    <%- btnExplica('Capital prestado', '<p><strong>Capital prestado (histórico)</strong></p><p>Suma del capital de <strong>todos</strong> los préstamos creados: <strong>' + formatCOP(kpis.capitalPrestado) + '</strong>.</p><p class="text-slate-400">Es cuánto dinero has entregado en total, sin importar si ya te lo pagaron.</p>' + tablaDesglose(function(it){ return it.capital; }, kpis.capitalPrestado)) %>
    <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-blue-100 text-blue-600">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 0 0-2.25-2.25H15a3 3 0 1 1-6 0H5.25A2.25 2.25 0 0 0 3 12m18 0v6a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 18v-6m18 0V9a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 9v3" /></svg>
    </span>
    <div>
      <p class="text-sm text-slate-400">Capital prestado</p>
      <p class="num mt-1 text-xl font-semibold text-slate-800"><%= formatCOP(kpis.capitalPrestado) %></p>
      <p class="text-xs text-slate-400 mt-0.5">Histórico total</p>
    </div>
  </div>

  <div class="card flex items-start gap-3 relative">
    <%- btnExplica('Total recuperado', '<p><strong>Total recuperado</strong></p><p>Suma de <strong>todos los abonos</strong> registrados en todos los préstamos: <strong>' + formatCOP(kpis.totalRecuperado) + '</strong>.</p><p class="text-slate-400">Es todo el dinero que ha vuelto a la caja (capital + interés juntos).</p>' + tablaDesglose(function(it){ return it.pagado; }, kpis.totalRecuperado)) %>
    <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182.553-.439 1.278-.659 2.003-.659.725 0 1.45.22 2.003.659l.659.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
    </span>
    <div>
      <p class="text-sm text-slate-400">Total recuperado</p>
      <p class="num mt-1 text-xl font-semibold text-slate-800"><%= formatCOP(kpis.totalRecuperado) %></p>
      <p class="text-xs text-slate-400 mt-0.5">Abonos registrados</p>
    </div>
  </div>

  <div class="card flex items-start gap-3 relative">
    <%- btnExplica('Interés cobrado', '<p><strong>Interés cobrado (aproximado)</strong></p><p>Por cada préstamo se toma su interés pactado y se multiplica por el <strong>% ya pagado</strong>. Ejemplo: si un préstamo va al 60% de su total, se cuenta el 60% de su interés.</p><p>La suma de todos da <strong>' + formatCOP(kpis.interesesCobrados) + '</strong>.</p><p class="text-slate-400">Es una estimación del interés real que ya entró a caja.</p>' + tablaDesglose(function(it){ return it.interesCobrado; }, kpis.interesesCobrados)) %>
    <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-violet-100 text-violet-600">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
        <line x1="19" y1="5" x2="5" y2="19" stroke-linecap="round" />
        <circle cx="7.5" cy="7.5" r="1.5" />
        <circle cx="16.5" cy="16.5" r="1.5" />
      </svg>
    </span>
    <div>
      <p class="text-sm text-slate-400">Interés cobrado</p>
      <p class="num mt-1 text-xl font-semibold text-slate-800"><%= formatCOP(kpis.interesesCobrados) %></p>
      <p class="text-xs text-slate-400 mt-0.5">Interés real ya recibido</p>
    </div>
  </div>

  <div class="card flex items-start gap-3 relative">
    <%- btnExplica('Pendiente por cobrar', '<p><strong>Pendiente por cobrar = Total − Abonado</strong></p><p>Suma de los saldos pendientes (Total a pagar menos lo abonado) de todos los préstamos que aún deben: <strong>' + formatCOP(kpis.carteraActiva) + '</strong>.</p><p class="text-slate-400">Es el dinero que todavía te falta por recibir de la cartera activa.</p>' + tablaDesglose(function(it){ return it.saldo > 0 ? it.saldo : null; }, kpis.carteraActiva)) %>
    <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-orange-100 text-orange-600">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 0 0-2.25-2.25H15a3 3 0 1 1-6 0H5.25A2.25 2.25 0 0 0 3 12m18 0v6a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 18v-6m18 0V9a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 9v3" /></svg>
    </span>
    <div>
      <p class="text-sm text-slate-400">Pendiente por cobrar</p>
      <p class="num mt-1 text-xl font-semibold text-slate-800"><%= formatCOP(kpis.carteraActiva) %></p>
      <p class="text-xs text-slate-400 mt-0.5">Saldo pendiente por cobrar</p>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
  <div class="card lg:col-span-2">
    <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
      <p class="font-medium text-slate-700">Ingresos del mes</p>
      <div class="flex items-center gap-1 rounded-lg bg-slate-100 p-1 text-sm" id="filtros-periodo">
        <button type="button" data-periodo="7d" class="periodo-btn">7 días</button>
        <button type="button" data-periodo="30d" class="periodo-btn periodo-btn-activo">30 días</button>
        <button type="button" data-periodo="3m" class="periodo-btn">3 meses</button>
        <button type="button" data-periodo="12m" class="periodo-btn">12 meses</button>
      </div>
    </div>
    <canvas id="chart-ingresos" height="110"></canvas>
    <div class="mt-5 grid grid-cols-3 gap-3 border-t border-slate-100 pt-4 text-sm">
      <div>
        <p class="text-slate-400">Total ingresos</p>
        <p id="stat-total" class="num font-semibold text-slate-800"><%= formatCOP(seriesPorPeriodo['30d'].estadisticas.total) %></p>
      </div>
      <div>
        <p class="text-slate-400">Promedio diario</p>
        <p id="stat-promedio" class="num font-semibold text-slate-800"><%= formatCOP(seriesPorPeriodo['30d'].estadisticas.promedioDiario) %></p>
      </div>
      <div>
        <p class="text-slate-400">Días con ingresos</p>
        <p id="stat-dias" class="num font-semibold text-slate-800"><%= seriesPorPeriodo['30d'].estadisticas.diasConIngresos %> de <%= seriesPorPeriodo['30d'].estadisticas.diasTotales %></p>
      </div>
    </div>
  </div>

  <div class="flex flex-col gap-6">
    <section>
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-medium text-slate-700">Próximos cobros</h2>
        <a href="/admin/cobros" class="text-sm text-blue-600 hover:underline">Ver todos</a>
      </div>
      <%
        var LIMITE_COBROS = 5;
        var cobrosVisibles = proximosCobros.slice(0, LIMITE_COBROS);
        var cobrosOcultos = proximosCobros.slice(LIMITE_COBROS);
        var totalOcultos = cobrosOcultos.length;
      %>
      <div class="card divide-y divide-slate-100 p-0">
        <% if (proximosCobros.length === 0) { %>
          <p class="px-5 py-6 text-center text-sm text-slate-400">No hay cobros programados.</p>
        <% } %>
        <% cobrosVisibles.forEach(function(cuota) {
          var urgente = cuota.etiquetaVencimiento === 'Vence hoy' || cuota.etiquetaVencimiento === 'Vence mañana';
          var inicial = (cuota.prestamos?.perfiles?.nombre_completo || 'C').charAt(0).toUpperCase();
        %>
          <div class="flex items-center justify-between px-5 py-3">
            <div class="flex items-center gap-3">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-slate-100 text-xs font-semibold text-slate-500"><%= inicial %></span>
              <div>
                <p class="text-sm font-medium text-slate-800"><%= cuota.prestamos?.perfiles?.nombre_completo || 'Cliente' %></p>
                <span class="<%= urgente ? 'badge-peligro' : 'badge-mora' %>"><%= cuota.etiquetaVencimiento %></span>
              </div>
            </div>
            <p class="num text-sm font-semibold text-slate-800"><%= formatCOP(cuota.monto_esperado - cuota.monto_pagado) %></p>
          </div>
        <% }); %>

        <% if (totalOcultos > 0) { %>
          <a href="/admin/cobros"
             class="flex w-full items-center justify-center gap-2 px-5 py-2.5 text-sm font-medium text-blue-600 hover:bg-blue-50 transition">
            + <%= totalOcultos %> cobros más
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        <% } %>
      </div>
    </section>

    <section>
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-medium text-slate-700">Actividad reciente</h2>
        <a href="/admin/pagos" class="text-sm text-blue-600 hover:underline">Ver todo</a>
      </div>
      <div class="card divide-y divide-slate-100 p-0">
        <% if (actividadReciente.length === 0) { %>
          <p class="px-5 py-6 text-center text-sm text-slate-400">Sin actividad reciente.</p>
        <% } %>
        <% actividadReciente.forEach(function(ev) { %>
          <div class="flex items-center justify-between px-5 py-3">
            <div class="flex items-center gap-3">
              <% if (ev.tipo === 'pago') { %>
                <span class="flex h-8 w-8 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                </span>
              <% } else if (ev.tipo === 'prestamo') { %>
                <span class="flex h-8 w-8 items-center justify-center rounded-full bg-blue-100 text-blue-600">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 5v14M5 12h14" /></svg>
                </span>
              <% } else { %>
                <span class="flex h-8 w-8 items-center justify-center rounded-full bg-red-100 text-red-500">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0 3.75h.007M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0Z" /></svg>
                </span>
              <% } %>
              <div>
                <p class="text-sm text-slate-700">
                  <%= ev.tipo === 'pago' ? 'Pago recibido' : ev.tipo === 'prestamo' ? 'Nuevo préstamo' : 'Cliente en mora' %>
                  · <%= ev.cliente %>
                </p>
                <p class="text-xs text-slate-400"><%= ev.hace %></p>
              </div>
            </div>
            <p class="num text-sm font-semibold <%= ev.tipo === 'mora' ? 'text-red-500' : 'text-emerald-600' %>">
              <%= ev.tipo === 'mora' ? '' : '+' %><%= formatCOP(ev.monto) %>
            </p>
          </div>
        <% }); %>
      </div>
    </section>
  </div>
</div>

<script>
  window.__SERIES_INGRESOS__ = <%- seriesJson %>;
</script>
