<%
  var mostrarVolver = typeof mostrarVolver !== 'undefined' && mostrarVolver;
  var volverUrl = typeof volverUrl !== 'undefined' ? volverUrl : '#';
%>
<div class="mb-6 flex items-center justify-between gap-4">
  <div class="flex items-center gap-3">
    <% if (mostrarVolver) { %>
      <a href="<%= volverUrl %>" class="icon-btn" aria-label="Volver">
        <svg class="h-5 w-5 text-slate-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" /></svg>
      </a>
    <% } %>
    <div>
      <h1 class="text-xl font-semibold text-slate-800"><%= tituloHeader %></h1>
      <% if (typeof subtituloHeader !== 'undefined' && subtituloHeader) { %>
        <p class="text-sm text-slate-400"><%= subtituloHeader %></p>
      <% } %>
    </div>
  </div>

  <div class="flex items-center gap-3 shrink-0">
    <button type="button" class="icon-btn relative" aria-label="Notificaciones">
      <svg class="h-5 w-5 text-slate-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.4-1.4A2 2 0 0 1 18 14.2V11a6 6 0 1 0-12 0v3.2a2 2 0 0 1-.6 1.4L4 17h5m6 0v1a3 3 0 1 1-6 0v-1m6 0H9" /></svg>
      <% if (typeof moraCount !== 'undefined' && moraCount > 0) { %>
        <span class="absolute -right-1 -top-1 flex h-5 min-w-[1.25rem] items-center justify-center rounded-full bg-red-500 px-1 text-[10px] font-semibold text-white"><%= moraCount %></span>
      <% } %>
    </button>

    <div class="relative">
      <button type="button" id="btn-avatar-menu" class="flex items-center gap-2">
        <span class="flex h-9 w-9 items-center justify-center rounded-full bg-blue-100 text-sm font-semibold text-blue-600">
          <%= (usuario.nombre_completo || 'A').charAt(0).toUpperCase() %>
        </span>
        <span class="hidden sm:block text-left">
          <span class="block text-sm font-medium text-slate-700"><%= usuario.nombre_completo %></span>
          <span class="block text-xs text-slate-400">Administrador</span>
        </span>
        <svg class="h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6" /></svg>
      </button>
      <div id="menu-avatar" class="hidden absolute right-0 top-full mt-2 w-48 rounded-xl border border-slate-100 bg-white py-1 shadow-lg z-50">
        <a href="/admin/configuracion" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50">Configuración</a>
        <form action="/auth/logout" method="POST">
          <button type="submit" class="block w-full text-left px-4 py-2 text-sm text-slate-600 hover:bg-slate-50">Cerrar sesión</button>
        </form>
      </div>
    </div>
  </div>
</div>
