<style>
  :root {
    --verde-900: #0e3b2b;
    --verde-800: #124a35;
    --verde-700: #166534;
    --verde-600: #1c7a43;
    --oro: #d4af37;
    --oro-claro: #eab308;
    --tinta: #0f3d2e;
    --gris: #6b7280;
    --gris-suave: #9ca3af;
    --linea: #e6ebe8;
  }

  * { box-sizing: border-box; }

  .login-body {
    min-height: 100vh;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    color: var(--tinta);
    background:
      radial-gradient(1100px 520px at 12% 18%, rgba(22, 101, 52, .10), transparent 60%),
      radial-gradient(900px 500px at 88% 82%, rgba(212, 175, 55, .12), transparent 60%),
      linear-gradient(135deg, #f6f9f7 0%, #eef4f0 100%);
  }

  .login-wrap {
    width: 100%;
    max-width: 1180px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 32px;
  }

  /* ---- Columna del logo ---- */
  .brand {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 12px;
    animation: fade-up .7s cubic-bezier(.16, 1, .3, 1) both;
  }
  /* Halo detrás del logo (no se recorta). */
  .brand::before {
    content: "";
    position: absolute;
    width: 78%;
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(22, 101, 52, .13) 0%, transparent 66%);
    z-index: 0;
  }
  /* Marco que ENCUADRA el logo y recorta el margen transparente lateral del
     .webp, para que el dibujo se vea grande y proporcional al login. */
  .brand-frame {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 480px;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: float 6s ease-in-out infinite;
  }
  .brand-frame img {
    height: 132%;
    width: auto;
    max-width: none;
  }

  /* ---- Tarjeta del formulario ---- */
  .login-card {
    background: #fff;
    border: 2px solid var(--oro);
    border-radius: 26px;
    padding: 40px 38px;
    box-shadow:
      0 0 0 5px rgba(212, 175, 55, .10),
      0 30px 60px -20px rgba(14, 59, 43, .25),
      0 8px 24px -12px rgba(14, 59, 43, .12);
    animation: fade-up .7s cubic-bezier(.16, 1, .3, 1) .08s both;
  }

  .eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--verde-600);
  }
  .eyebrow::before, .eyebrow::after {
    content: "";
    width: 22px;
    height: 2px;
    border-radius: 2px;
    background: var(--oro);
  }

  .login-title {
    margin: 10px 0 6px;
    text-align: center;
    font-size: 34px;
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -.02em;
    color: var(--verde-900);
  }
  .login-sub {
    margin: 0 0 26px;
    text-align: center;
    font-size: 14px;
    color: var(--gris);
  }

  .field { margin-bottom: 18px; }
  .field > label {
    display: block;
    margin-bottom: 8px;
    font-size: 13.5px;
    font-weight: 600;
    color: var(--verde-900);
  }
  .control { position: relative; }
  .control .ico {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--gris-suave);
    pointer-events: none;
    display: flex;
  }
  .control input {
    width: 100%;
    height: 52px;
    padding: 0 46px;
    border: 1.5px solid var(--linea);
    border-radius: 14px;
    background: #f8faf9;
    font-size: 15px;
    color: var(--tinta);
    transition: border-color .18s, box-shadow .18s, background .18s;
    outline: none;
  }
  .control input::placeholder { color: var(--gris-suave); }
  .control input:focus {
    border-color: var(--verde-600);
    background: #fff;
    box-shadow: 0 0 0 4px rgba(22, 101, 52, .12);
  }
  .control input:focus + .ico,
  .control:focus-within .ico { color: var(--verde-600); }

  .toggle-eye {
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    color: var(--gris-suave);
    cursor: pointer;
    border-radius: 8px;
    transition: color .15s, background .15s;
  }
  .toggle-eye:hover { color: var(--verde-700); background: rgba(22, 101, 52, .08); }

  .btn-entrar {
    width: 100%;
    height: 54px;
    margin-top: 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    border: none;
    border-radius: 14px;
    cursor: pointer;
    color: #fff;
    font-size: 15.5px;
    font-weight: 700;
    letter-spacing: .01em;
    background: linear-gradient(135deg, var(--verde-600) 0%, var(--verde-800) 55%, var(--verde-900) 100%);
    box-shadow: 0 12px 24px -10px rgba(14, 59, 43, .55);
    transition: transform .15s ease, box-shadow .2s ease, filter .2s ease;
  }
  .btn-entrar .arrow { transition: transform .2s ease; }
  .btn-entrar:hover {
    filter: brightness(1.06);
    box-shadow: 0 18px 30px -10px rgba(14, 59, 43, .6);
    transform: translateY(-1px);
  }
  .btn-entrar:hover .arrow { transform: translateX(4px); }
  .btn-entrar:active { transform: translateY(0); }

  .forgot {
    margin-top: 16px;
    text-align: center;
  }
  .forgot a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13.5px;
    color: var(--gris);
    text-decoration: none;
    transition: color .15s;
  }
  .forgot a:hover { color: var(--verde-700); }

  .divisor {
    height: 1px;
    background: var(--linea);
    margin: 24px 0 18px;
  }
  .foot {
    text-align: center;
    font-size: 12.5px;
    color: var(--gris-suave);
    line-height: 1.7;
  }
  .foot .marca { color: var(--verde-900); font-weight: 700; }
  .foot .oro { color: var(--oro-claro); }

  /* Aviso (éxito / error) dentro de la tarjeta de auth */
  .aviso {
    margin: 0 0 20px;
    padding: 13px 15px;
    border-radius: 13px;
    font-size: 13.5px;
    line-height: 1.5;
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }
  .aviso svg { flex: none; margin-top: 1px; }
  .aviso-ok {
    background: #ecfdf3;
    border: 1px solid #a7f3d0;
    color: #14663a;
  }
  .aviso-err {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #b42318;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-12px); }
  }

  /* ---- Responsive ---- */
  @media (max-width: 920px) {
    .login-wrap { grid-template-columns: 1fr; gap: 8px; max-width: 460px; }
    .brand-frame { max-width: 300px; aspect-ratio: 5 / 4; animation: none; }
    .brand { padding-bottom: 0; }
    .login-card { padding: 32px 24px; }
    .login-title { font-size: 28px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .brand, .login-card, .brand img { animation: none; }
  }
</style>
