<%
  var _exito  = typeof flashExito  !== 'undefined' ? flashExito  : null;
  var _error  = typeof flashError  !== 'undefined' ? flashError  : null;
  var _alerta = typeof flashAlerta !== 'undefined' ? flashAlerta : null;
  var _msg    = _error || _alerta || _exito || '';
  var _mensajeJs = JSON.stringify(_msg).replace(/<\//g, '<\\/');
  var _icon  = _error ? 'error' : (_alerta ? 'warning' : 'success');
  var _title = _error ? 'Algo salió mal' : (_alerta ? 'Aviso' : 'Listo');
%>
<% if (_exito || _error || _alerta) { %>
<script>
  window.addEventListener('DOMContentLoaded', function () {
    if (window.history.replaceState) {
      var _u = new URL(window.location.href);
      _u.searchParams.delete('ok');
      _u.searchParams.delete('error');
      window.history.replaceState({}, '', _u.toString());
    }
    Swal.fire({
      icon: '<%- _icon %>',
      title: '<%- _title %>',
      text: <%- _mensajeJs %>,
      background: '#FFFFFF',
      color: '#1e293b',
      confirmButtonColor: '<%= _alerta ? "#d97706" : "#16a34a" %>',
    });
  });
</script>
<% } %>
