<div class="flex items-center justify-between gap-4 rounded-xl border border-amber-100 bg-amber-50 px-4 py-3">
  <div>
    <p class="font-medium text-slate-800">
      <%= cuota.prestamos?.perfiles?.nombre_completo || 'Cliente' %>
    </p>
    <p class="text-xs text-slate-400">
      Cuota #<%= cuota.numero_cuota %> · vencía el <%= cuota.fecha_vencimiento %>
      <% if (cuota.prestamos?.perfiles?.telefono) { %> · <%= cuota.prestamos.perfiles.telefono %><% } %>
    </p>
  </div>
  <div class="text-right">
    <p class="num text-sm font-semibold text-amber-600"><%= formatCOP(cuota.monto_esperado - cuota.monto_pagado) %></p>
    <p class="badge-mora mt-1"><%= cuota.diasAtraso %> días de atraso</p>
  </div>
  <a href="/admin/prestamos/<%= cuota.prestamo_id %>" class="btn-secondary text-xs py-1.5 px-3 whitespace-nowrap">Ver préstamo</a>
</div>
