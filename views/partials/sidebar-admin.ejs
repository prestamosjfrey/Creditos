<%
  function activo(prefijo) {
    return rutaActual && (rutaActual === prefijo || rutaActual.startsWith(prefijo + '/'));
  }
%>
<aside id="sidebar-admin" class="fixed left-0 top-0 z-40 flex h-screen w-64 flex-col bg-slate-900 py-4">
  <div class="flex items-center justify-between px-5 mb-4">
    <a href="/admin/dashboard" class="flex items-center gap-2">
      <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-blue-600 text-white font-bold">$</span>
      <span class="text-white font-semibold tracking-tight">Cartera</span>
    </a>
    <button type="button" id="btn-cerrar-sidebar" class="text-slate-400 transition hover:text-white" aria-label="Cerrar menú">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6l12 12M18 6 6 18" /></svg>
    </button>
  </div>

  <nav class="flex-1 flex flex-col px-3 overflow-y-auto">
    <div class="space-y-0.5">
      <a href="/admin/dashboard" class="sidebar-link <%= activo('/admin/dashboard') ? 'sidebar-link-activo' : '' %>">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75" /></svg>
        Dashboard
      </a>

      <a href="/admin/clientes" class="sidebar-link <%= activo('/admin/clientes') ? 'sidebar-link-activo' : '' %>">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>
        <span class="flex-1">Clientes</span>
        <% if (typeof clientesCount !== 'undefined' && clientesCount > 0) { %>
          <span class="ml-auto rounded-full bg-red-500 px-2 py-0.5 text-xs font-semibold text-white"><%= clientesCount %></span>
        <% } %>
      </a>

      <a href="/admin/prestamos" class="sidebar-link <%= activo('/admin/prestamos') ? 'sidebar-link-activo' : '' %>">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125h17.25c.621 0 1.125.504 1.125 1.125v.375m-19.5 0v8.25a1.125 1.125 0 0 0 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-8.25M12 11.25a2.625 2.625 0 1 1 0-5.25 2.625 2.625 0 0 1 0 5.25Z" /></svg>
        <span class="flex-1">Préstamos</span>
        <% if (typeof prestamosCount !== 'undefined' && prestamosCount > 0) { %>
          <span class="ml-auto rounded-full bg-red-500 px-2 py-0.5 text-xs font-semibold text-white"><%= prestamosCount %></span>
        <% } %>
      </a>

      <a href="/admin/pagos" class="sidebar-link <%= activo('/admin/pagos') ? 'sidebar-link-activo' : '' %>">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182.553-.439 1.278-.659 2.003-.659.725 0 1.45.22 2.003.659l.659.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
        Pagos
      </a>

      <a href="/admin/caja" class="sidebar-link <%= activo('/admin/caja') ? 'sidebar-link-activo' : '' %>">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 0 0-2.25-2.25H15a3 3 0 1 1-6 0H5.25A2.25 2.25 0 0 0 3 12m18 0v6a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 18v-6m18 0V9a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 9v3" /></svg>
        Disponible
      </a>

      <a href="/admin/creditos-tomados" class="sidebar-link <%= activo('/admin/creditos-tomados') ? 'sidebar-link-activo' : '' %>">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125h17.25c.621 0 1.125.504 1.125 1.125v.375m-19.5 0v8.25a1.125 1.125 0 0 0 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-8.25M12 11.25a2.625 2.625 0 1 1 0-5.25 2.625 2.625 0 0 1 0 5.25Z" /></svg>
        Créditos tomados
      </a>

      <a href="/admin/cobros" class="sidebar-link <%= activo('/admin/cobros') ? 'sidebar-link-activo' : '' %>">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>
        <span class="flex-1">Cobros</span>
        <% if (typeof cobrosHoyCount !== 'undefined' && cobrosHoyCount > 0) { %>
          <span class="ml-auto rounded-full bg-red-500 px-2 py-0.5 text-xs font-semibold text-white"><%= cobrosHoyCount %></span>
        <% } %>
      </a>

      <a href="/admin/mora" class="sidebar-link <%= activo('/admin/mora') ? 'sidebar-link-activo' : '' %>">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" /></svg>
        <span class="flex-1">Mora</span>
        <% if (typeof moraCount !== 'undefined' && moraCount > 0) { %>
          <span class="ml-auto rounded-full bg-red-500 px-2 py-0.5 text-xs font-semibold text-white"><%= moraCount %></span>
        <% } %>
      </a>

      <a href="/admin/renegociados" class="sidebar-link <%= activo('/admin/renegociados') ? 'sidebar-link-activo' : '' %>">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
        <span class="flex-1">Renegociados</span>
        <% if (typeof renegCount !== 'undefined' && renegCount > 0) { %>
          <span class="ml-auto rounded-full bg-red-500 px-2 py-0.5 text-xs font-semibold text-white"><%= renegCount %></span>
        <% } %>
      </a>

      <a href="/admin/reportes" class="sidebar-link <%= activo('/admin/reportes') ? 'sidebar-link-activo' : '' %>">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" /></svg>
        Reportes
      </a>

      <a href="/admin/archivo" class="sidebar-link <%= activo('/admin/archivo') ? 'sidebar-link-activo' : '' %>">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>
        Comprobantes
      </a>

      <a href="/admin/auditoria" class="sidebar-link <%= activo('/admin/auditoria') ? 'sidebar-link-activo' : '' %>">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2Z" /></svg>
        Auditoría
      </a>
    </div>

    <div class="mt-auto pt-3 space-y-0.5">
      <div class="border-t border-white/10 mb-2"></div>

      <a href="/admin/configuracion" class="sidebar-link <%= activo('/admin/configuracion') ? 'sidebar-link-activo' : '' %>">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.241.437-.613.43-.991a7.48 7.48 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.213-1.28Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
        Configuración
      </a>

      <a href="/admin/descargar-app" class="sidebar-link">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
        <span class="flex-1">Descargar app</span>
        <span class="ml-auto rounded-full bg-blue-600/40 px-2 py-0.5 text-xs font-semibold text-blue-300">v1.0</span>
      </a>

      <form action="/auth/logout" method="POST">
        <button type="submit" class="sidebar-link w-full">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M12 9l3 3m0 0-3 3m3-3H3" /></svg>
          Cerrar sesión
        </button>
      </form>
    </div>
  </nav>
</aside>
