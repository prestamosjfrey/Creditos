# =====================================================================
# Configuración de Cartera.
#
# ATENCIÓN: este archivo es solo una PLANTILLA. El .env real nunca se sube al
# repositorio ni se empaqueta en ningún artefacto distribuible: contiene la
# llave de servicio de Supabase, que da acceso TOTAL a la base saltándose las
# políticas de seguridad (RLS).
# =====================================================================

# --- Supabase (obligatorias: sin ellas el servidor no arranca) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Llave de servicio. SOLO en el servidor. Nunca en un cliente ni en un build.
SUPABASE_SERVICE_ROLE_KEY=

# Secreto para firmar las cookies (protección CSRF). Mínimo 32 caracteres.
# Genéralo con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_COOKIE_SECRET=

PORT=3000
# En producción DEBE ser exactamente "production": de eso dependen el flag
# Secure de las cookies y el envío de HSTS.
NODE_ENV=development

# URL pública de la app (sin barra final). Se usa para armar el enlace de
# recuperar contraseña. Si se deja vacío, se deduce del request.
# Ej. en producción: https://cash-r-r.onrender.com
APP_URL=

# Envío de correos (Brevo). La API key es la que empieza por "xkeysib-", de
# Brevo → Ajustes → SMTP y API → API keys. NO es la clave SMTP (xsmtpsib-).
# El remitente debe estar verificado en Brevo → Remitentes, dominios, IP.
BREVO_API_KEY=
BREVO_REMITENTE_EMAIL=
BREVO_REMITENTE_NOMBRE=CASH R&R

# Notificaciones de WhatsApp por CallMeBot. Son los teléfonos del prestamista,
# no de los clientes. Formato: numero1:apikey1,numero2:apikey2
CALLMEBOT_DESTINOS=
# Horas de envío automático diario (HH:MM, 24h). Vacío = desactivado.
CALLMEBOT_HORA_COBROS=
CALLMEBOT_HORA_RECORDATORIO=

# Datos del primer usuario admin, usados solo por scripts/seed-admin.js
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NOMBRE=
